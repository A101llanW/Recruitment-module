@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Page Not Found";
    ViewBag.SuppressPageHero = true;
}

<div style="min-height:60vh; display:flex; align-items:center; justify-content:center;">
    <div style="text-align:center; max-width:500px; padding:2rem;">
        <div style="font-size:6rem; font-weight:900; color:#e9ecef; line-height:1;">404</div>
        <h1 style="font-size:2rem; color:#343a40; margin-bottom:0.5rem;">Page Not Found</h1>
        <p style="color:#6c757d; margin-bottom:2rem;">
            The page you are looking for doesn't exist, has been moved,
            or you don't have permission to view it.
        </p>
        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary">
            <i class="fas fa-home mr-2"></i> Go to Homepage
        </a>
    </div>
</div>
