@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Access Denied";
    ViewBag.SuppressPageHero = true;
}

<div style="min-height:60vh; display:flex; align-items:center; justify-content:center;">
    <div style="text-align:center; max-width:500px; padding:2rem;">
        <div style="font-size:5rem; margin-bottom:1rem;">🔒</div>
        <h1 style="font-size:2rem; color:#856404; margin-bottom:0.5rem;">Access Denied</h1>
        <p style="color:#6c757d; margin-bottom:2rem;">
            You don't have permission to access this page.
            If you believe this is an error, please contact your administrator.
        </p>
        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary mr-2">
            <i class="fas fa-home mr-2"></i> Go to Homepage
        </a>
        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary">
            <i class="fas fa-sign-in-alt mr-2"></i> Login as Different User
        </a>
    </div>
</div>
