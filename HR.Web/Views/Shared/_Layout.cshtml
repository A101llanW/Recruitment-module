    @if (!hideChrome)
    {
    <footer class="app-footer">
        <div class="app-footer__inner">
            <div>
                <p class="app-footer__brand mb-0">@AppConfig.ProductName</p>
                <p class="app-footer__copy mb-0">&copy; @DateTime.UtcNow.Year @AppConfig.PublisherName</p>
            </div>
        @if (ViewBag.HideNavbar != true)
        {
