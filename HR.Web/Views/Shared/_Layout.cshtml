                                <div class="input-group mb-3">
                                    <input type="text" class="form-control" id="secureDownloadUrl" readonly value="@Url.Action("DownloadCredentials", "Companies", new { token = token }, Request.Url.Scheme)" style="background-color: #fff; font-family: monospace;">
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-secondary" type="button" onclick="var copyText = document.getElementById('secureDownloadUrl'); copyText.select(); document.execCommand('copy'); this.innerHTML='<i class=\'fas fa-check\'></i> Copied!'; setTimeout(function(){ document.querySelector('#secureDownloadUrl').nextElementSibling.querySelector('button').innerHTML='<i class=\'fas fa-copy\'></i> Copy'; }, 3000);" title="Copy to clipboard">
