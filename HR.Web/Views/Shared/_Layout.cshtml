@using HR.Web.Helpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - @AppConfig.ProductName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/font-awesome.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/recruitment-theme.css")" />
    @{
        string currentController = ViewContext.RouteData.Values["controller"] != null ? ViewContext.RouteData.Values["controller"].ToString() : null;
        string currentAction = ViewContext.RouteData.Values["action"] != null ? ViewContext.RouteData.Values["action"].ToString() : null;
        bool isAuthPage = (currentController == "Account" && (currentAction == "Login" || currentAction == "Register" || currentAction == "VerifyMFA" || currentAction == "SetupMFA" || currentAction == "ForgotPassword" || currentAction == "ResetPassword" || currentAction == "VerifyEmail"));
        var layoutRolePermissionService = new HR.Web.Services.RolePermissionService();
        string currentModuleKey = HR.Web.Services.RoleModuleCatalog.ResolveModule(currentController, currentAction);
        bool isModuleReadOnlyAccess = layoutRolePermissionService.IsCurrentUserReadOnlyForModule(currentModuleKey);
        bool suppressPageHero = ViewBag.SuppressPageHero == true;
        bool showPageHero = !suppressPageHero && ViewBag.HideNavbar != true && !isAuthPage && !string.IsNullOrWhiteSpace(ViewBag.Title as string);
        string pageTitle = ViewBag.Title as string;
        string pageEyebrow = ViewBag.PageEyebrow as string;
        string pageLead = ViewBag.PageLead as string;
        if (string.IsNullOrWhiteSpace(pageEyebrow))
        {
            pageEyebrow = currentController == "Admin" ? "Administration" : (currentController == "Account" ? "Account" : AppConfig.ProductName);
        }
        if (string.IsNullOrWhiteSpace(pageLead) && !string.IsNullOrWhiteSpace(pageTitle))
        {
            var defaultLeads = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
            {
                { "Positions", "Browse open roles, manage postings, and configure hiring requirements." },
                { "Applications", "Review candidate pipelines, scores, and hiring progress." },
                { "Interviews", "Schedule and track interviews across your open positions." },
                { "Applicants", "Search and manage applicant profiles and contact details." },
                { "Departments", "Organize teams and structure positions by department." },
                { "Companies", "Manage tenant companies, branding, and system-wide settings." },
                { "Dashboard", "Your company hiring overview and quick actions." },
                { "Onboardings", "Track candidates moving from offer to start date." },
                { "Licenses", "View and manage product licenses across tenant companies." },
                { "Reports", "Generate hiring and recruitment analytics reports." },
                { "Questions", "Maintain question banks and scoring configuration." },
                { "User Management", "Invite users and assign roles for your organization." },
                { "Global User Management", "Manage users across all companies in the system." },
                { "Role Management", "Define role templates and module access levels." },
                { "Email Templates", "Customize candidate and HR email wording." },
                { "Security Logs", "Review authentication and security-related events." },
                { "HR CC Emails", "Configure HR contacts copied on candidate emails." },
                { "Privacy", "How we collect, use, and protect personal information." },
                { "Terms", "Terms and conditions for using " + AppConfig.ProductName + "." },
                { "License Management", "View and renew licenses across tenant companies." },
                { "Companies Dashboard", "System-wide company overview, license health, and tenant controls." },
                { "Question Bank", "Curate and generate assessment questions for positions." },
                { "Manage Questions", "Create, edit, and organize your question library." },
                { "Candidate Rankings", "Compare applicant scores and rankings by position." },
                { "Enhanced Candidate Rankings", "Advanced ranking views with scoring breakdowns." },
                { "Application Questionnaire", "Complete the assessment for your application." },
                { "Scoring Statistics", "Analyze scoring trends and passmark performance." },
                { "Login", "Sign in to manage hiring, applications, and interviews." },
                { "Register", "Create an account to apply for positions and track applications." },
                { "Forgot Password", "Request a secure link to reset your password." },
                { "Reset Password", "Choose a new password for your account." }
            };
            string leadText;
            if (defaultLeads.TryGetValue(pageTitle, out leadText))
            {
                pageLead = leadText;
            }
        }
    }
    @if (isAuthPage)
    {
        @Html.Partial("_AuthStyles")
    }
    <style>
        /* Elevation Modal Custom Styles */
        #elevationRequestModal .modal-content {
            border-radius: 12px;
            overflow: hidden;
            border: none;
        }
        #elevationRequestModal .modal-header {
            border-bottom: none;
            padding: 1.5rem;
        }
        #elevationRequestModal .details-box {
            background-color: #f8f9fa;
            border-left: 4px solid #f39c12;
            padding: 1rem;
            margin-bottom: 1rem;
        }
        #elevationRequestModal .modal-footer {
            border-top: none;
            padding: 1.2rem 1.5rem;
        }

        /* Freeze Overlay Styles */
        #performance-freeze-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(13, 44, 74, 0.95);
            z-index: 10000;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: #fff;
            -webkit-backdrop-filter: blur(8px);
            backdrop-filter: blur(8px);
            text-align: center;
            padding: 20px;
        }
        #performance-freeze-overlay .spinner-box {
            margin-bottom: 25px;
        }
        #performance-freeze-overlay h2 {
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 10px;
        }
        #performance-freeze-overlay p {
            font-size: 1.1rem;
            opacity: 0.8;
            max-width: 500px;
        }
        @@keyframes logoPulse {
            0% { transform: scale(1); opacity: 0.9; }
            50% { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(1); opacity: 0.9; }
        }
        .pulse-logo {
            animation: logoPulse 2s infinite ease-in-out;
        }
    </style>
</head>
<body class="recruitment-app@(isAuthPage ? " auth-layout" : "")">
    @if (Session["ImpersonatedCompanyId"] != null)
    {
        <div class="app-impersonation-bar py-2">
            <div class="container d-flex flex-wrap justify-content-between align-items-center">
                <span>
                    <i class="fas fa-user-secret mr-2"></i>
                    <strong>IMPERSONATING:</strong> @(Session["ImpersonatedCompanyName"] ?? "Tenant") 
                    <small class="ml-2">(Reason: @(Session["ImpersonationReason"] ?? "N/A"))</small>
                    <span class="app-impersonation-chip ml-3">
                        <i class="far fa-clock mr-1"></i> <span id="impersonation-countdown">--:--</span> left
                    </span>
                </span>
                <a href="@Url.Action("StopImpersonating", "Companies")" class="btn btn-dark btn-sm shadow-sm font-weight-bold">
                    <i class="fas fa-sign-out-alt mr-1"></i> Return to SuperAdmin role
                </a>
            </div>
        </div>
        
        if (Session["ImpersonationExpiry"] != null) {
            <script>
                window.impersonationExpiry = '@(((DateTime)Session["ImpersonationExpiry"]).ToString("yyyy-MM-ddTHH:mm:ss"))';
            </script>
        }
    }
    
    <div id="performance-freeze-overlay">
        <div class="spinner-box">
            <img src="@Url.Content("~/Content/images/nanosoft-logo-transparent.png")" alt="Nanosoft" style="height: 120px; filter: drop-shadow(0 0 15px rgba(243, 156, 18, 0.4));" class="pulse-logo" />
        </div>
        <h2>System Elevating...</h2>
        <p>A SuperAdmin is currently performing maintenance or support operations on your company context.</p>
        
        <div class="mt-2 text-warning font-weight-bold" style="font-size: 1.5rem;">
            <i class="far fa-clock mr-2"></i> Session expires in: <span id="freeze-countdown">--:--</span>
        </div>

        <div class="mt-4 px-4 py-2 bg-warning text-dark font-weight-bold rounded shadow-sm">
            <i class="fas fa-lock mr-2"></i> CONTEXT LOCKED
        </div>
    </div>
    @{
        var hideChrome = ViewBag.HideNavbar == true || isAuthPage;
    }
    @if (!hideChrome)
    {
        <nav class="navbar navbar-expand-lg app-navbar app-navbar--sticky">
            @if (!isAuthPage)
            {
                var navMenu = new HR.Web.Services.NavMenuBuilder().Build(
                    Context,
                    ViewContext.RequestContext,
                    ViewBag.TenantContext as HR.Web.Models.Company,
                    ViewBag.TenantToken as string,
                    currentController,
                    currentAction,
                    currentModuleKey);
                @Html.Partial("_NavMenu", navMenu)
            }
        </nav>
    }

    <main class="app-main@(isAuthPage ? " app-main--auth" : "")">
    <div class="container app-container@(isAuthPage ? " auth-container" : "")">
        @if (TempData["QuestionnaireSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["QuestionnaireSuccess"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @Html.Raw(TempData["SuccessMessage"].ToString())
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        
        @if (isAuthPage)
        {
            <div class="auth-page">
        @RenderBody()
    </div>
        }
        else
        {
            <div class="app-page">
                @if (showPageHero)
                {
                    ViewBag.PageEyebrow = pageEyebrow;
                    ViewBag.PageLead = pageLead;
                    @Html.Partial("_PageHeader")
                }
                @RenderBody()
