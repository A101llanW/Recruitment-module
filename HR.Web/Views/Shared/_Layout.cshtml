                                        </button>
                                    </div>
                                </div>

                                <a href="@Url.Action("DownloadCredentials", "Companies", new { token = token })" class="btn btn-primary btn-block btn-lg shadow-sm" style="border-radius: 8px; font-weight: 700;">
                                    <i class="fas fa-file-download mr-2"></i> Download Security File
                                </a>
                            </div>
                        </div>

                        <div class="alert alert-warning border-0 text-left" style="border-radius: 8px; background-color: #fff9e6;">
                            <h6 class="font-weight-bold mb-2"><i class="fas fa-exclamation-triangle mr-2"></i>Critical Security Notice:</h6>
                            <ul class="small mb-0 pl-3">
                                <li>This is a <strong>one-time</strong> link. Once downloaded, it cannot be accessed again.</li>
                                <li>The file contains sensitive login details. Store it in a secure location.</li>
                                <li>This link will expire in 60 minutes if not used.</li>
                            </ul>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light p-3">
                        <button type="button" class="btn btn-outline-secondary font-weight-bold" onclick="document.getElementById('adminCredentialsModal').style.display='none'; document.body.style.overflow='auto';" style="border-radius: 6px;">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <script>
            // Stop background scrolling while this custom modal is showing
            document.body.style.overflow = 'hidden';
            
            // Allow clicking outside the modal dialog to close it
            document.getElementById('adminCredentialsModal').addEventListener('click', function(e) {
                if(e.target === this) {
                    this.style.display = 'none'; 
                    document.body.style.overflow='auto';
                }
            });
        </script>
