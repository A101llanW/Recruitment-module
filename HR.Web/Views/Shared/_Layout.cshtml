                    <a href="@Url.Action("Privacy", "Home", new { tenant = ViewBag.TenantToken as string })">Privacy</a>
                    <a href="@Url.Action("Terms", "Home", new { tenant = ViewBag.TenantToken as string })">Terms</a>
                    <a href="https://ntlafrica.com" target="_blank" rel="noopener noreferrer">ntlafrica.com</a>
                    <span class="app-footer__social">
                        <a href="https://www.instagram.com/nanosoft_kenya/" target="_blank" rel="noopener noreferrer" aria-label="@("Instagram @nanosoft_kenya")"><i class="fab fa-instagram"></i></a>
                    </span>
                </nav>
