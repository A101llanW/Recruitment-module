    <script src="@Url.Content("~/Scripts/jquery-3.6.0.min.js")"></script>
    <script src="@Url.Content("~/Scripts/bootstrap.bundle.min.js")"></script>
    
    <script>
        // Security logic to prevent "Back Button" after Logout
        window.addEventListener('pageshow', function (event) {
            if (event.persisted || (typeof window.performance != "undefined" && window.performance.navigation.type === 2)) {
                // If the page was loaded from history/cache, force a reload to trigger auth check
                window.location.reload();
            }
        });
    </script>

    @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
    {
        <!-- Elevation Request Modal -->
        <div class="modal fade" id="elevationRequestModal" tabindex="-1" role="dialog" aria-labelledby="elevationModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content border-warning shadow">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title" id="elevationModalLabel">
                            <i class="fas fa-exclamation-shield mr-2"></i> Elevation Request
                        </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <p id="elevationRequestText">A SuperAdmin is requesting temporary access to your company context.</p>
                        <hr />
                        <div id="elevationRequestDetails" class="details-box">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                    <div class="modal-footer d-flex justify-content-between">
                        @using (Html.BeginForm("HandleImpersonationRequest", "Dashboard", FormMethod.Post, new { id = "denyElevationForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" id="denyRequestId" />
                            <input type="hidden" name="approved" value="false" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fas fa-times mr-1"></i> Deny Access
                            </button>
                        }
                        
                        @using (Html.BeginForm("HandleImpersonationRequest", "Dashboard", FormMethod.Post, new { id = "approveElevationForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" id="approveRequestId" />
                            <input type="hidden" name="approved" value="true" />
                            
                            <div class="d-flex align-items-center">
                                <div class="form-group mb-0 mr-3">
                                    <div class="input-group input-group-sm">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-white"><i class="far fa-clock"></i></span>
                                        </div>
                                        <select name="durationMinutes" class="form-control" style="width: 100px;">
                                            <option value="2">2 min</option>
                                            <option value="5">5 min</option>
                                            <option value="15">15 min</option>
                                            <option value="30">30 min</option>
                                            <option value="60" selected>1 hour</option>
                                            <option value="120">2 hours</option>
                                            <option value="240">4 hours</option>
                                        </select>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-success font-weight-bold">
                                    <i class="fas fa-check mr-1"></i> Grant Access
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <script>
            $(document).ready(function() {
                // Shared timer formatting
                function formatTime(seconds) {
                    var totalSeconds = parseInt(seconds);
                    if (isNaN(totalSeconds) || totalSeconds <= 0) return "00:00";
                    
                    var h = Math.floor(totalSeconds / 3600);
                    var m = Math.floor((totalSeconds % 3600) / 60);
                    var s = totalSeconds % 60;
                    var timeStr = "";
                    if (h > 0) { timeStr += h + ":" + (m < 10 ? "0" : ""); }
                    timeStr += m + ":" + (s < 10 ? "0" : "") + s;
                    return timeStr;
                }

                // AUTHORITATIVE TIMER LOGIC (Using Server Time)
                var impersonationSecondsLeft = -1;
                var impersonationInterval = null;

                function updateImpersonationTimer() {
                    if (impersonationSecondsLeft <= 0) {
                        $('#impersonation-countdown').text("00:00");
                        if (impersonationInterval) {
                            clearInterval(impersonationInterval);
                            impersonationInterval = null;
                        }
                        return;
                    }
                    impersonationSecondsLeft--;
                    $('#impersonation-countdown').text(formatTime(impersonationSecondsLeft));
                    
                    if (impersonationSecondsLeft === 0) {
                        setTimeout(function() { 
                            // Properly stop impersonation and redirect instead of just reloading
                            window.location.href = '@Url.Action("StopImpersonating", "Companies")';
                        }, 1000);
                    }
                }

                function syncImpersonationStatus() {
                    if ($('#impersonation-countdown').length === 0) return;
                    
                    $.get('@Url.Action("GetMyImpersonationStatus", "Dashboard")', function(data) {
                        impersonationSecondsLeft = parseInt(data.secondsLeft) || 0;
                        $('#impersonation-countdown').text(formatTime(impersonationSecondsLeft));
                        
                        if (impersonationSecondsLeft > 0 && !impersonationInterval) {
                            impersonationInterval = setInterval(updateImpersonationTimer, 1000);
                        } else if (impersonationSecondsLeft <= 0 && impersonationInterval) {
                            clearInterval(impersonationInterval);
                            impersonationInterval = null;
                            // Server-side detected expiration, redirect properly
                            window.location.href = '@Url.Action("StopImpersonating", "Companies")';
                        }
                    });
                }

                // Initial sync for SuperAdmin
                syncImpersonationStatus();
                
                // Additional check: If impersonation banner exists but server says no active session, redirect
                if ($('#impersonation-countdown').length > 0) {
                    setInterval(syncImpersonationStatus, 15000); // Re-sync with server every 15s
                    
                    // Immediate check for expired session on page load
                    $.get('@Url.Action("GetMyImpersonationStatus", "Dashboard")', function(data) {
                        if (data.secondsLeft <= 0) {
                            // Session expired on server, redirect properly
                            window.location.href = '@Url.Action("StopImpersonating", "Companies")';
                        }
                    });
                }

                // Only poll if on a page where we want the popup
                function checkElevationRequests() {
                    $.get('@Url.Action("GetPendingRequests", "Dashboard")', function(data) {
                        if (data.count > 0) {
                            var req = data.requests[0]; // Show the first one
                            $('#elevationRequestDetails').html(
                                '<strong>SuperAdmin:</strong> ' + req.requestedBy + '<br/>' +
                                '<strong>Time:</strong> ' + req.requestDate + '<br/>' +
                                (req.reason ? '<strong>Reason:</strong> ' + req.reason : '')
                            );
                            $('#denyRequestId').val(req.id);
                            $('#approveRequestId').val(req.id);
                            
                            // Only show if not already showing
                            if (!$('#elevationRequestModal').hasClass('show')) {
                                $('#elevationRequestModal').modal('show');
                            }
                        }
                    });
                }

                checkElevationRequests();
                setInterval(checkElevationRequests, 30000);

                // --- Freeze Overlay & Countdown ---
                var freezeSecondsLeft = 0;
                var freezeInterval = null;

                function updateFreezeTimer() {
                    if (freezeSecondsLeft <= 0) {
                        $('#freeze-countdown').text("00:00");
                        if (freezeInterval) {
                            clearInterval(freezeInterval);
                            freezeInterval = null;
                        }
                        return;
                    }
                    freezeSecondsLeft--;
                    $('#freeze-countdown').text(formatTime(freezeSecondsLeft));
                }

                // Check for System Freeze (Authoritative Server Time)
                function checkSystemFreeze() {
                    $.get('@Url.Action("GetImpersonationStatus", "Dashboard")', function(data) {
                        if (data.isLocked) {
                            $('#performance-freeze-overlay').css('display', 'flex');
                            
                            // Authoritative sync from server
                            freezeSecondsLeft = parseInt(data.secondsLeft) || 0;
                            $('#freeze-countdown').text(formatTime(freezeSecondsLeft));
                            
                            if (freezeSecondsLeft > 0 && !freezeInterval) {
                                freezeInterval = setInterval(updateFreezeTimer, 1000);
                            }
                        } else {
                            $('#performance-freeze-overlay').hide();
                            if (freezeInterval) {
                                clearInterval(freezeInterval);
                                freezeInterval = null;
                            }
                        }
                    });
                }
                
                checkSystemFreeze();
                setInterval(checkSystemFreeze, 10000); // Check freeze status every 10 seconds
            });
        </script>
    }

    @if (isModuleReadOnlyAccess)
    {
        <style>
            .readonly-module-hidden {
                display: none !important;
            }

            .readonly-module-disabled {
                pointer-events: none !important;
                opacity: 0.65 !important;
            }
        </style>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var root = document.querySelector('.app-page') || document.querySelector('.app-container');
                if (!root) {
                    return;
                }

                function getControlText(element) {
                    var text = (element.innerText || element.textContent || element.value || element.getAttribute('aria-label') || element.getAttribute('title') || '').trim();
                    return text.toLowerCase();
                }

                function isSafeNavigationControl(element) {
                    if (!element) {
                        return false;
                    }

                    if ((element.getAttribute('data-dismiss') || '').length > 0) {
                        return true;
                    }

                    var text = getControlText(element);
                    return /\b(back|return|cancel|close)\b/i.test(text);
                }

                function hideControl(element) {
                    if (!element || isSafeNavigationControl(element)) {
                        return;
                    }

                    element.classList.add('readonly-module-hidden');
                    element.setAttribute('aria-hidden', 'true');
                    element.setAttribute('tabindex', '-1');
                    if ('disabled' in element) {
                        element.disabled = true;
                    }
                }

                var controls = root.querySelectorAll('a[class*="btn"], button, input[type="submit"], input[type="button"]');
                controls.forEach(function (control) {
                    if (control.getAttribute('data-readonly-allow') === 'true' || control.closest('[data-readonly-allow="true"]')) {
                        return;
                    }

                    if (isSafeNavigationControl(control)) {
                        return;
                    }

                    hideControl(control);
                });

                var postForms = root.querySelectorAll('form');
                postForms.forEach(function (form) {
                    var method = (form.getAttribute('method') || 'get').toLowerCase();
                    if (method !== 'post') {
                        return;
                    }

                    var fields = form.querySelectorAll('input, select, textarea, button');
                    fields.forEach(function (field) {
                        if ((field.getAttribute('type') || '').toLowerCase() === 'hidden') {
                            return;
                        }

                        if (field.getAttribute('data-readonly-allow') === 'true' || field.closest('[data-readonly-allow="true"]')) {
                            return;
                        }

                        if (isSafeNavigationControl(field)) {
                            return;
                        }

                        if ('readOnly' in field && field.tagName.toLowerCase() !== 'select') {
                            field.readOnly = true;
                        }

                        if ('disabled' in field) {
                            field.disabled = true;
                        }

                        field.classList.add('readonly-module-disabled');
                    });
                });
            });
        </script>
    }

    @RenderSection("Scripts", required: false)

    <!-- Secure Credential Download Modal -->
    @if (TempData.Peek("CredentialDownloadToken") != null)
    {
        var token = TempData["CredentialDownloadToken"].ToString();
        var companyName = TempData["NewCompanyName"] ?? "the new company";
        
        <div class="modal show" id="adminCredentialsModal" tabindex="-1" role="dialog" aria-labelledby="adminCredentialsModalLabel" aria-hidden="false" style="display: block; background-color: rgba(0,0,0,0.8); z-index: 10001; overflow-y: auto; overflow-x: hidden;">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                    <div class="modal-header border-0 bg-primary text-white p-4">
                        <h5 class="modal-title font-weight-bold" id="adminCredentialsModalLabel">
                            <i class="fas fa-shield-alt mr-2"></i>Secure Access Protected
                        </h5>
                        <button type="button" class="close text-white" aria-label="Close" onclick="document.getElementById('adminCredentialsModal').style.display='none'; document.body.style.overflow='auto';">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body p-4 text-center">
                        <div class="mb-4">
                            <div class="display-4 text-primary mb-3">
                                <i class="fas fa-file-download"></i>
                            </div>
                            <h4 class="font-weight-bold text-dark">Credentials Ready</h4>
                            <p class="text-muted">Administrator credentials for <strong>@companyName</strong> have been generated and encrypted.</p>
                        </div>
                        
                        <div class="card bg-light border-0 mb-4" style="border-radius: 10px;">
                            <div class="card-body p-4">
                                <p class="small text-muted mb-3"><i class="fas fa-info-circle mr-1"></i> You can copy this one-time secure link to share securely, or download the credentials yourself directly.</p>
                                
                                <div class="input-group mb-3">
                                    <input type="text" class="form-control" id="secureDownloadUrl" readonly value="@Url.Action("DownloadCredentials", "Companies", new { token = token }, Request.Url.Scheme)" style="background-color: #fff; font-family: monospace;">
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-secondary" type="button" onclick="var copyText = document.getElementById('secureDownloadUrl'); copyText.select(); document.execCommand('copy'); this.innerHTML='<i class=\'fas fa-check\'></i> Copied!'; setTimeout(function(){ document.querySelector('#secureDownloadUrl').nextElementSibling.querySelector('button').innerHTML='<i class=\'fas fa-copy\'></i> Copy'; }, 3000);" title="Copy to clipboard">
                                            <i class="fas fa-copy"></i> Copy
                                        </button>
                                    </div>
                                </div>

                                <a href="@Url.Action("DownloadCredentials", "Companies", new { token = token })" class="btn btn-primary btn-block btn-lg shadow-sm" style="border-radius: 8px; font-weight: 700;">
                                    <i class="fas fa-file-download mr-2"></i> Download Security File
                                </a>
                            </div>
                        </div>

                        <div class="alert alert-warning border-0 text-left" style="border-radius: 8px; background-color: #fff9e6;">
                            <h6 class="font-weight-bold mb-2"><i class="fas fa-exclamation-triangle mr-2"></i>Critical Security Notice:</h6>
                            <ul class="small mb-0 pl-3">
                                <li>This is a <strong>one-time</strong> link. Once downloaded, it cannot be accessed again.</li>
                                <li>The file contains sensitive login details. Store it in a secure location.</li>
                                <li>This link will expire in 60 minutes if not used.</li>
                            </ul>
                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light p-3">
                        <button type="button" class="btn btn-outline-secondary font-weight-bold" onclick="document.getElementById('adminCredentialsModal').style.display='none'; document.body.style.overflow='auto';" style="border-radius: 6px;">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <script>
            // Stop background scrolling while this custom modal is showing
            document.body.style.overflow = 'hidden';
            
            // Allow clicking outside the modal dialog to close it
            document.getElementById('adminCredentialsModal').addEventListener('click', function(e) {
                if(e.target === this) {
                    this.style.display = 'none'; 
                    document.body.style.overflow='auto';
                }
            });
        </script>
    }

@if (Request.IsAuthenticated)
{
    <!-- ── Idle Session Timeout Modal ──────────────────────────────── -->
    <div id="idleModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:center; justify-content:center; padding:1rem;">
        <div style="background:#fff; border-radius:12px; padding:2.5rem; max-width:420px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.4);">
            <div style="font-size:3rem; margin-bottom:1rem; color:#6c757d;">
                <i class="far fa-clock"></i>
            </div>
            <h4 style="color:#343a40; margin-bottom:0.75rem;">Session Expiring Soon</h4>
            <p style="color:#6c757d; margin-bottom:0.5rem;">
                You have been inactive for a while. For your security, you will be
                automatically signed out in:
            </p>
            <div id="idleCountdown" style="font-size:2.5rem; font-weight:700; color:#dc3545; margin:1rem 0;">60</div>
            <p style="color:#6c757d; font-size:0.875rem; margin-bottom:1.5rem;">seconds</p>
            <button id="idleStayBtn" class="btn btn-primary" style="margin-right:0.5rem;">
                <i class="fas fa-check mr-1"></i> Stay Signed In
            </button>
            <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger">
                <i class="fas fa-sign-out-alt mr-1"></i> Sign Out Now
            </a>
        </div>
    </div>

    <script>
        (function () {
            var IDLE_WARN_MS   = 20 * 60 * 1000;  // 20 min inactivity → show warning
            var COUNTDOWN_SECS = 60;                 // 60 seconds to respond before auto-logout
            var logoutUrl      = '@Url.Action("Logout", "Account")';

            var idleTimer, countdownTimer, secondsLeft;
            var modal = document.getElementById('idleModal');

            function resetIdle() {
                clearTimeout(idleTimer);
                // Only reset if modal is not already visible
                if (modal.style.display === 'none') {
                    idleTimer = setTimeout(showWarning, IDLE_WARN_MS);
                }
            }

            function showWarning() {
                secondsLeft = COUNTDOWN_SECS;
                document.getElementById('idleCountdown').textContent = secondsLeft;
                modal.style.display = 'flex';
                countdownTimer = setInterval(function () {
                    secondsLeft--;
                    document.getElementById('idleCountdown').textContent = secondsLeft;
                    if (secondsLeft <= 0) {
                        clearInterval(countdownTimer);
                        window.location.href = logoutUrl + '?reason=idle_timeout';
                    }
                }, 1000);
            }

            function dismissWarning() {
                clearInterval(countdownTimer);
                modal.style.display = 'none';
                resetIdle();
            }

            document.getElementById('idleStayBtn').addEventListener('click', dismissWarning);

            // Reset timer on any user activity
            ['mousemove', 'keydown', 'mousedown', 'touchstart', 'scroll'].forEach(function (evt) {
                document.addEventListener(evt, resetIdle, { passive: true });
            });

            resetIdle(); // Start the timer
        })();
    </script>
}
</body>
</html>




