<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Recruitment Module</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/font-awesome.min.css")" />
    <style>
        .navbar-nav .nav-item.active > .nav-link {
            box-shadow: 0 0 8px 2px #007bff, 0 0 0 2px #fff inset;
            border-radius: 6px;
            background: rgba(0,123,255,0.08);
            color: #007bff !important;
        }

        /* Company logo styling */
        .navbar-brand img {
            transition: transform 0.2s ease-in-out;
        }
        .navbar-brand:hover img {
            transform: scale(1.05);
        }
        
        .navbar-brand .font-weight-bold {
            font-size: 1.1rem;
        }
        
        .navbar-brand .text-muted {
            font-size: 0.75rem;
            line-height: 1;
        }

        /* Mobile navbar tweaks */
    @@media (max-width: 576px) {
        .navbar-nav .nav-link {
            padding: 0.6rem 0.8rem;
            font-size: 0.95rem;
        }

        .navbar-brand {
            font-size: 0.95rem;
            white-space: normal;
        }
        
        .navbar-brand img {
            height: 30px !important;
            max-height: 30px !important;
        }
        
        .navbar-brand .text-light {
            font-size: 0.7rem;
        }
        
        .navbar-brand .d-flex.flex-column {
            margin-left: 0.5rem !important;
        }
        .navbar-collapse .nav-item {
            margin: 2px 0;
        }
        .nav-link-sa {
            border-radius: 6px;
            padding: 0.5rem 1rem !important;
            margin: 0 5px;
            font-weight: 600;
            transition: all 0.2s;
        }
        /* SA high-visibility colors */
        .sa-companies { background-color: #ff6b6b; color: white !important; }
        .sa-licenses { background-color: #f1c40f; color: #333 !important; }
        .sa-positions { background-color: #6fb8dc; color: #0d2c4a !important; }
        .sa-users { background-color: #9b59b6; color: white !important; }
        
        @@media (max-width: 991px) {
            .nav-link-sa { margin: 5px 0 !important; width: 100%; }
            .dropdown-menu { 
                border: none; 
                background: rgba(255,255,255,0.08); 
                margin-top: 10px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            }
            .dropdown-item { 
                color: rgba(255,255,255,0.9) !important; 
                padding: 12px 20px !important; /* Increased spacing */
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }
            .dropdown-item:last-child { border-bottom: none; }
            .dropdown-item:hover { background: rgba(255,255,255,0.1); }
            .dropdown-item i { margin-right: 12px; opacity: 0.8; }
        }
    }
        /* Shared button styles for blue save and red back */
        .btn-blue {
            background: #6fb8dc;
            color: #0d2c4a;
            border: none;
            transition: all 0.2s;
            font-size: 0.97rem;
            padding: 0.5rem 1.2rem;
            border-radius: 0.4rem;
            font-weight: 600;
            cursor: pointer;
            position: relative;
            z-index: 5;
            display: inline-block;
        }
        .btn-blue:hover { background: #3498db; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .btn-blue:active { transform: translateY(0); }

        .btn-red {
            background: #e05656;
            color: #0d2c4a;
            border: none;
            transition: all 0.2s;
            font-size: 0.97rem;
            padding: 0.5rem 1.2rem;
            border-radius: 0.4rem;
            font-weight: 600;
            cursor: pointer;
            position: relative;
            z-index: 5;
            display: inline-block;
        }
        .btn-red:hover { background: #c0392b; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .btn-red:active { transform: translateY(0); }

        @@media (min-width: 768px) {
        .w-md-50 {
            width: 50% !important;
        }
    }
        /* Elevation Modal Custom Styles */
        #elevationRequestModal .modal-content {
            border-radius: 12px;
            overflow: hidden;
            border: none;
        }
        #elevationRequestModal .modal-header {
            border-bottom: none;
            padding: 1.5rem;
        }
        #elevationRequestModal .details-box {
            background-color: #f8f9fa;
            border-left: 4px solid #f39c12;
            padding: 1rem;
            margin-bottom: 1rem;
        }
        #elevationRequestModal .modal-footer {
            border-top: none;
            padding: 1.2rem 1.5rem;
        }

        /* Freeze Overlay Styles */
        #performance-freeze-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(13, 44, 74, 0.95);
            z-index: 10000;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: #fff;
            backdrop-filter: blur(8px);
            text-align: center;
            padding: 20px;
        }
        #performance-freeze-overlay .spinner-box {
            margin-bottom: 25px;
        }
        #performance-freeze-overlay h2 {
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 10px;
        }
        #performance-freeze-overlay p {
            font-size: 1.1rem;
            opacity: 0.8;
            max-width: 500px;
        }
        @@keyframes logoPulse {
            0% { transform: scale(1); opacity: 0.9; }
            50% { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(1); opacity: 0.9; }
        }
        .pulse-logo {
            animation: logoPulse 2s infinite ease-in-out;
        }
    </style>
</head>
<body>
    @if (Session["ImpersonatedCompanyId"] != null)
    {
        <div class="alert alert-warning mb-0 border-0 rounded-0" style="background-color: #f39c12; color: #fff; z-index: 9999; position: relative;">
            <div class="container d-flex justify-content-between align-items-center">
                <span>
                    <i class="fas fa-user-secret mr-2"></i>
                    <strong>IMPERSONATING:</strong> @(Session["ImpersonatedCompanyName"] ?? "Tenant") 
                    <small class="ml-2">(Reason: @(Session["ImpersonationReason"] ?? "N/A"))</small>
                    <span class="badge badge-dark ml-3 px-2 py-1" style="font-size: 0.85em; border: 1px solid rgba(255,255,255,0.2);">
                        <i class="far fa-clock mr-1"></i> <span id="impersonation-countdown">--:--</span> left
                    </span>
                </span>
                <a href="@Url.Action("StopImpersonating", "Companies")" class="btn btn-dark btn-sm shadow-sm" style="font-weight: bold; border-radius: 4px;">
                    <i class="fas fa-sign-out-alt mr-1"></i> Return to SuperAdmin role
                </a>
            </div>
        </div>
        
        if (Session["ImpersonationExpiry"] != null) {
            <script>
                window.impersonationExpiry = '@(((DateTime)Session["ImpersonationExpiry"]).ToString("yyyy-MM-ddTHH:mm:ss"))';
            </script>
        }
    }
    
    <div id="performance-freeze-overlay">
        <div class="spinner-box">
            <img src="@Url.Content("~/Content/images/nanosoft-logo-transparent.png")" alt="Nanosoft" style="height: 120px; filter: drop-shadow(0 0 15px rgba(243, 156, 18, 0.4));" class="pulse-logo" />
        </div>
        <h2>System Elevating...</h2>
        <p>A SuperAdmin is currently performing maintenance or support operations on your company context.</p>
        
        <div class="mt-2 text-warning font-weight-bold" style="font-size: 1.5rem;">
            <i class="far fa-clock mr-2"></i> Session expires in: <span id="freeze-countdown">--:--</span>
        </div>

        <div class="mt-4 px-4 py-2 bg-warning text-dark font-weight-bold rounded shadow-sm">
            <i class="fas fa-lock mr-2"></i> CONTEXT LOCKED
        </div>
    </div>
    @{
        string currentController = ViewContext.RouteData.Values["controller"] != null ? ViewContext.RouteData.Values["controller"].ToString() : null;
        string currentAction = ViewContext.RouteData.Values["action"] != null ? ViewContext.RouteData.Values["action"].ToString() : null;
        bool isAuthPage = (currentController == "Account" && (currentAction == "Login" || currentAction == "Register" || currentAction == "VerifyMFA" || currentAction == "SetupMFA" || currentAction == "ForgotPassword" || currentAction == "ResetPassword" || currentAction == "VerifyEmail"));
    }

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
        @{
            string tenantToken = ViewBag.TenantToken as string;
            string brandUrl = Url.Action("Index", "Positions", new { tenant = tenantToken });
            
            if (User != null && User.Identity != null && User.Identity.IsAuthenticated)
            {
                if (Session["ImpersonatedCompanyId"] != null) {
                    brandUrl = Url.Action("Index", "Dashboard", new { tenant = tenantToken });
                } else if (User.IsInRole("SuperAdmin")) {
                    brandUrl = Url.Action("Index", "Companies", new { tenant = tenantToken });
                } else if (User.IsInRole("Admin")) {
                    brandUrl = Url.Action("Index", "Dashboard", new { tenant = tenantToken });
                }
            }
        }
        <a class="navbar-brand d-flex align-items-center" href="@brandUrl">
            @if (ViewBag.TenantContext != null)
            {
                <i class="fas fa-building fa-2x mr-2 text-info"></i>
                <div class="d-flex flex-column ml-2">
                    <span style="font-weight: bold; color: white; font-size: 1.2rem;">@ViewBag.TenantContext.Name</span>
                    <small class="text-muted">Branded Recruitment Portal</small>
                </div>
            }
            else
            {
                <img src="@Url.Content("~/Content/images/nanosoft-logo-transparent.png")" alt="Nanosoft Technologies" height="40" class="mr-2" style="max-height: 40px;" onerror="console.log('PNG logo failed, trying JPG'); this.src='@Url.Content("~/Content/images/nanosoft-logo.jpg")';" />
                <div class="d-flex flex-column ml-2" style="border-left: 1px solid rgba(255,255,255,0.2); padding-left: 12px;">
                    <small class="text-light">Welcome</small>
                    @if (User != null && User.Identity != null && User.Identity.IsAuthenticated && !string.IsNullOrEmpty(User.Identity.Name))
                    {
                        var displayName = User.Identity.Name;
                        if (displayName.Length > 0) {
                            displayName = char.ToUpper(displayName[0]) + displayName.Substring(1).ToLower();
                        }
                        <span style="font-weight: bold; color: white;">@displayName</span>
                    }
                    else
                    {
                        <span style="font-weight: bold; color: white;">Guest</span>
                    }
                </div>
            }
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            @if (!isAuthPage) {
            <ul class="navbar-nav">
                @if (User != null && User.Identity != null && User.IsInRole("SuperAdmin") && Session["ImpersonatedCompanyId"] == null)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="saSystemMenu" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="color: #ff7675; font-weight: 800;">
                            <i class="fas fa-server mr-1"></i> System Administration
                        </a>
                        <div class="dropdown-menu" aria-labelledby="saSystemMenu">
                            <a class="dropdown-item" href="@Url.Action("Index","Companies", new { tenant = tenantToken })"><i class="fas fa-building"></i> Companies</a>
                            <a class="dropdown-item" href="@Url.Action("Index","Licenses", new { tenant = tenantToken })"><i class="fas fa-key"></i> Licenses</a>
                            <a class="dropdown-item" href="@Url.Action("Index","Positions", new { tenant = tenantToken })"><i class="fas fa-sitemap"></i> System Positions</a>
                            <a class="dropdown-item" href="@Url.Action("GlobalUserManagement","Admin", new { tenant = tenantToken })"><i class="fas fa-users-cog"></i> System Users</a>
                        </div>
                    </li>
                }
                else
                {
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Positions" ? "active" : "")">
                        <a class="nav-link" href="@Url.Action("Index","Positions", new { tenant = tenantToken })"><i class="fas fa-sitemap"></i> Positions</a>
                    </li>
                }

                @if (User == null || (!User.IsInRole("SuperAdmin") || Session["ImpersonatedCompanyId"] != null))
                {
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Applications" ? "active" : "")"><a class="nav-link" href="@Url.Action("Index","Applications", new { tenant = tenantToken })"><i class="fas fa-file-alt"></i> Applications</a></li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Interviews" ? "active" : "")"><a class="nav-link" href="@Url.Action("Index","Interviews", new { tenant = tenantToken })"><i class="fas fa-comments"></i> Interviews</a></li>
                }

                @if (User != null && User.Identity != null && (User.IsInRole("Admin") || Session["ImpersonatedCompanyId"] != null))
                {
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Admin" && ViewContext.RouteData.Values["action"] != null && ViewContext.RouteData.Values["action"].ToString() == "Questions" ? "active" : "")">
                        <a class="nav-link" href="@Url.Action("Questions","Admin", new { tenant = tenantToken })"><i class="fas fa-question-circle"></i> Questions</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Onboardings" ? "active" : "")"><a class="nav-link" href="@Url.Action("Index","Onboardings", new { tenant = tenantToken })"><i class="fas fa-user-check"></i> Onboardings</a></li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Applicants" ? "active" : "")"><a class="nav-link" href="@Url.Action("Index","Applicants", new { tenant = tenantToken })"><i class="fas fa-users"></i> Applicants</a></li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Admin" && ViewContext.RouteData.Values["action"] != null && ViewContext.RouteData.Values["action"].ToString() == "UserManagement" ? "active" : "")">
                        <a class="nav-link" href="@Url.Action("UserManagement","Admin", new { tenant = tenantToken })"><i class="fas fa-user-shield"></i> User Management</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Admin" && ViewContext.RouteData.Values["action"] != null && ViewContext.RouteData.Values["action"].ToString() == "SecurityLogs" ? "active" : "")">
                        <a class="nav-link" href="@Url.Action("SecurityLogs","Admin", new { tenant = tenantToken })"><i class="fas fa-shield-alt"></i> Security Logs</a>
                    </li>
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "ReportGenerator" ? "active" : "")">
                        <a class="nav-link" href="@Url.Action("Index","ReportGenerator", new { tenant = tenantToken })"><i class="fas fa-chart-bar"></i> Reports</a>
                    </li>
                }

                @if (User == null || (!User.IsInRole("SuperAdmin") || Session["ImpersonatedCompanyId"] != null))
                {
                    <li class="nav-item @(ViewContext.RouteData.Values["controller"] != null && ViewContext.RouteData.Values["controller"].ToString() == "Departments" ? "active" : "")"><a class="nav-link" href="@Url.Action("Index","Departments", new { tenant = tenantToken })"><i class="fas fa-building"></i> Departments</a></li>
                }
            </ul>
            <ul class="navbar-nav ml-auto">
                @if (User != null && User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <i class="fas fa-user-circle"></i> 
                            @{
                                var sideName = (User.Identity != null && !string.IsNullOrEmpty(User.Identity.Name)) ? User.Identity.Name : "User";
                                if (sideName.Length > 0 && sideName != "User") {
                                    sideName = char.ToUpper(sideName[0]) + sideName.Substring(1).ToLower();
                                }
                            }
                            @sideName
                        </a>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userMenu">
                            <a class="dropdown-item" href="@Url.Action("Profile", "Account", new { tenant = tenantToken })"><i class="fas fa-user-circle mr-2"></i> My Profile</a>
                            <a class="dropdown-item" href="@Url.Action("ChangePassword", "Account", new { tenant = tenantToken })"><i class="fas fa-key mr-2"></i> Change Password</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="@Url.Action("Logout", "Account", new { tenant = tenantToken })"><i class="fas fa-sign-out-alt"></i> Logout</a>
                        </div>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Login","Account", new { tenant = tenantToken })"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Register","Account", new { tenant = tenantToken })"><i class="fas fa-user-plus"></i> Register</a></li>
                }
            </ul>
            }
        </div>
    </nav>

    <div class="container" style="padding-bottom: 120px;">
        @if (TempData["QuestionnaireSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["QuestionnaireSuccess"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @Html.Raw(TempData["SuccessMessage"].ToString())
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        
        @RenderBody()
    </div>

    <footer class="bg-dark text-white text-center py-3" style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 1000;">
        <p class="mb-1">&copy; 2026 Recruitment Management System. All rights reserved.</p>
        <p class="mb-0">
            <a href="#" class="text-white mx-2"><i class="fab fa-facebook"></i></a>
            <a href="#" class="text-white mx-2"><i class="fab fa-twitter"></i></a>
            <a href="#" class="text-white mx-2"><i class="fab fa-linkedin"></i></a>
        </p>
    </footer>

    <script src="@Url.Content("~/Scripts/jquery-3.6.0.min.js")"></script>
    <script src="@Url.Content("~/Scripts/bootstrap.bundle.min.js")"></script>
    
    <script>
        // Security logic to prevent "Back Button" after Logout
        window.addEventListener('pageshow', function (event) {
            if (event.persisted || (typeof window.performance != "undefined" && window.performance.navigation.type === 2)) {
                // If the page was loaded from history/cache, force a reload to trigger auth check
                window.location.reload();
            }
        });
    </script>

    @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
    {
        <!-- Elevation Request Modal -->
        <div class="modal fade" id="elevationRequestModal" tabindex="-1" role="dialog" aria-labelledby="elevationModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content border-warning shadow">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title" id="elevationModalLabel">
                            <i class="fas fa-exclamation-shield mr-2"></i> Elevation Request
                        </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <p id="elevationRequestText">A SuperAdmin is requesting temporary access to your company context.</p>
                        <hr />
                        <div id="elevationRequestDetails" class="details-box">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                    <div class="modal-footer d-flex justify-content-between">
                        @using (Html.BeginForm("HandleImpersonationRequest", "Dashboard", FormMethod.Post, new { id = "denyElevationForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" id="denyRequestId" />
                            <input type="hidden" name="approved" value="false" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fas fa-times mr-1"></i> Deny Access
                            </button>
                        }
                        
                        @using (Html.BeginForm("HandleImpersonationRequest", "Dashboard", FormMethod.Post, new { id = "approveElevationForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" id="approveRequestId" />
                            <input type="hidden" name="approved" value="true" />
                            
                            <div class="d-flex align-items-center">
                                <div class="form-group mb-0 mr-3">
                                    <div class="input-group input-group-sm">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-white"><i class="far fa-clock"></i></span>
                                        </div>
                                        <select name="durationMinutes" class="form-control" style="width: 100px;">
                                            <option value="2">2 min</option>
                                            <option value="5">5 min</option>
                                            <option value="15">15 min</option>
                                            <option value="30">30 min</option>
                                            <option value="60" selected>1 hour</option>
                                            <option value="120">2 hours</option>
                                            <option value="240">4 hours</option>
                                        </select>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-success font-weight-bold">
                                    <i class="fas fa-check mr-1"></i> Grant Access
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <script>
            $(document).ready(function() {
                // Shared timer formatting
                function formatTime(seconds) {
                    var totalSeconds = parseInt(seconds);
                    if (isNaN(totalSeconds) || totalSeconds <= 0) return "00:00";
                    
                    var h = Math.floor(totalSeconds / 3600);
                    var m = Math.floor((totalSeconds % 3600) / 60);
                    var s = totalSeconds % 60;
                    var timeStr = "";
                    if (h > 0) { timeStr += h + ":" + (m < 10 ? "0" : ""); }
                    timeStr += m + ":" + (s < 10 ? "0" : "") + s;
                    return timeStr;
                }

                // AUTHORITATIVE TIMER LOGIC (Using Server Time)
                var impersonationSecondsLeft = -1;
                var impersonationInterval = null;

                function updateImpersonationTimer() {
                    if (impersonationSecondsLeft <= 0) {
                        $('#impersonation-countdown').text("00:00");
                        if (impersonationInterval) {
                            clearInterval(impersonationInterval);
                            impersonationInterval = null;
                        }
                        return;
                    }
                    impersonationSecondsLeft--;
                    $('#impersonation-countdown').text(formatTime(impersonationSecondsLeft));
                    
                    if (impersonationSecondsLeft === 0) {
                        setTimeout(function() { 
                            // Properly stop impersonation and redirect instead of just reloading
                            window.location.href = '@Url.Action("StopImpersonating", "Companies")';
                        }, 1000);
                    }
                }

                function syncImpersonationStatus() {
                    if ($('#impersonation-countdown').length === 0) return;
                    
                    $.get('@Url.Action("GetMyImpersonationStatus", "Dashboard")', function(data) {
                        impersonationSecondsLeft = parseInt(data.secondsLeft) || 0;
                        $('#impersonation-countdown').text(formatTime(impersonationSecondsLeft));
                        
                        if (impersonationSecondsLeft > 0 && !impersonationInterval) {
                            impersonationInterval = setInterval(updateImpersonationTimer, 1000);
                        } else if (impersonationSecondsLeft <= 0 && impersonationInterval) {
                            clearInterval(impersonationInterval);
                            impersonationInterval = null;
                            // Server-side detected expiration, redirect properly
                            window.location.href = '@Url.Action("StopImpersonating", "Companies")';
                        }
                    });
                }

                // Initial sync for SuperAdmin
                syncImpersonationStatus();
                
                // Additional check: If impersonation banner exists but server says no active session, redirect
                if ($('#impersonation-countdown').length > 0) {
                    setInterval(syncImpersonationStatus, 15000); // Re-sync with server every 15s
                    
                    // Immediate check for expired session on page load
                    $.get('@Url.Action("GetMyImpersonationStatus", "Dashboard")', function(data) {
                        if (data.secondsLeft <= 0) {
                            // Session expired on server, redirect properly
                            window.location.href = '@Url.Action("StopImpersonating", "Companies")';
                        }
                    });
                }

                // Only poll if on a page where we want the popup
                function checkElevationRequests() {
                    $.get('@Url.Action("GetPendingRequests", "Dashboard")', function(data) {
                        if (data.count > 0) {
                            var req = data.requests[0]; // Show the first one
                            $('#elevationRequestDetails').html(
                                '<strong>SuperAdmin:</strong> ' + req.requestedBy + '<br/>' +
                                '<strong>Time:</strong> ' + req.requestDate + '<br/>' +
                                (req.reason ? '<strong>Reason:</strong> ' + req.reason : '')
                            );
                            $('#denyRequestId').val(req.id);
                            $('#approveRequestId').val(req.id);
                            
                            // Only show if not already showing
                            if (!$('#elevationRequestModal').hasClass('show')) {
                                $('#elevationRequestModal').modal('show');
                            }
                        }
                    });
                }

                checkElevationRequests();
                setInterval(checkElevationRequests, 30000);

                // --- Freeze Overlay & Countdown ---
                var freezeSecondsLeft = 0;
                var freezeInterval = null;

                function updateFreezeTimer() {
                    if (freezeSecondsLeft <= 0) {
                        $('#freeze-countdown').text("00:00");
                        if (freezeInterval) {
                            clearInterval(freezeInterval);
                            freezeInterval = null;
                        }
                        return;
                    }
                    freezeSecondsLeft--;
                    $('#freeze-countdown').text(formatTime(freezeSecondsLeft));
                }

                // Check for System Freeze (Authoritative Server Time)
                function checkSystemFreeze() {
                    $.get('@Url.Action("GetImpersonationStatus", "Dashboard")', function(data) {
                        if (data.isLocked) {
                            $('#performance-freeze-overlay').css('display', 'flex');
                            
                            // Authoritative sync from server
                            freezeSecondsLeft = parseInt(data.secondsLeft) || 0;
                            $('#freeze-countdown').text(formatTime(freezeSecondsLeft));
                            
                            if (freezeSecondsLeft > 0 && !freezeInterval) {
                                freezeInterval = setInterval(updateFreezeTimer, 1000);
                            }
                        } else {
                            $('#performance-freeze-overlay').hide();
                            if (freezeInterval) {
                                clearInterval(freezeInterval);
                                freezeInterval = null;
                            }
                        }
                    });
                }
                
                checkSystemFreeze();
                setInterval(checkSystemFreeze, 10000); // Check freeze status every 10 seconds
            });
        </script>
    }

    @RenderSection("Scripts", required: false)

    <!-- Admin Credentials Modal -->
    @if (TempData["AdminCredentials"] != null)
    {
        var credentials = TempData["AdminCredentials"] as HR.Web.Models.AdminCredentialsViewModel;
        <div class="modal fade show" id="adminCredentialsModal" tabindex="-1" role="dialog" aria-labelledby="adminCredentialsModalLabel" aria-hidden="false" style="display: block; background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title" id="adminCredentialsModalLabel">
                            <i class="fas fa-user-shield mr-2"></i>Company Created Successfully!
                        </h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close" onclick="$('#adminCredentialsModal').modal('hide');">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <!-- Debug Info -->
                        <div class="alert alert-info">
                            <small><strong>DEBUG:</strong> TempData found with @credentials?.CompanyName</small>
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle mr-2"></i>
                            <strong>@credentials.CompanyName</strong> has been created successfully!
                        </div>
                        
                        <div class="card bg-light">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="fas fa-link mr-2"></i>Company URL</h6>
                            </div>
                            <div class="card-body">
                                <div class="input-group">
                                    <input type="text" class="form-control" value="@credentials.CompanyUrl" readonly onclick="this.select();">
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-primary" type="button" onclick="window.open('@credentials.CompanyUrl', '_blank')">
                                            <i class="fas fa-external-link-alt"></i> Open
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card bg-warning">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="fas fa-user-lock mr-2"></i>Admin Credentials</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="font-weight-bold">Username:</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" value="@credentials.AdminUsername" readonly onclick="this.select();">
                                            <div class="input-group-append">
                                                <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('@credentials.AdminUsername')">
                                                    <i class="fas fa-copy"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="font-weight-bold">Password:</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" value="@credentials.AdminPassword" readonly onclick="this.select();">
                                            <div class="input-group-append">
                                                <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('@credentials.AdminPassword')">
                                                    <i class="fas fa-copy"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="alert alert-warning mt-3 mb-0">
                                    <i class="fas fa-exclamation-triangle mr-2"></i>
                                    <strong>Important:</strong> Please save these credentials securely. The admin user should change this password on first login.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-success" onclick="$('#adminCredentialsModal').modal('hide');">
                            <i class="fas fa-check mr-2"></i>I've Saved the Credentials
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // Auto-hide modal after 10 seconds or when user clicks away
            setTimeout(function() {
                $('#adminCredentialsModal').modal('hide');
            }, 10000);

            // Copy to clipboard function
            function copyToClipboard(text) {
                navigator.clipboard.writeText(text).then(function() {
                    // Show brief success message
                    var btn = event.target.closest('button');
                    var originalHtml = btn.innerHTML;
                    btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
                    btn.classList.add('btn-success');
                    btn.classList.remove('btn-outline-secondary');
                    
                    setTimeout(function() {
                        btn.innerHTML = originalHtml;
                        btn.classList.remove('btn-success');
                        btn.classList.add('btn-outline-secondary');
                    }, 2000);
                });
            }
        </script>
    }
    else
    {

    }

@if (Request.IsAuthenticated)
{
    <!-- ── Idle Session Timeout Modal ──────────────────────────────── -->
    <div id="idleModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:#fff; border-radius:12px; padding:2.5rem; max-width:420px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.4);">
            <div style="font-size:3rem; margin-bottom:1rem;">⏱️</div>
            <h4 style="color:#343a40; margin-bottom:0.75rem;">Session Expiring Soon</h4>
            <p style="color:#6c757d; margin-bottom:0.5rem;">
                You have been inactive for a while. For your security, you will be
                automatically signed out in:
            </p>
            <div id="idleCountdown" style="font-size:2.5rem; font-weight:700; color:#dc3545; margin:1rem 0;">60</div>
            <p style="color:#6c757d; font-size:0.875rem; margin-bottom:1.5rem;">seconds</p>
            <button id="idleStayBtn" class="btn btn-primary" style="margin-right:0.5rem;">
                <i class="fas fa-check mr-1"></i> Stay Signed In
            </button>
            <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger">
                <i class="fas fa-sign-out-alt mr-1"></i> Sign Out Now
            </a>
        </div>
    </div>

    <script>
        (function () {
            var IDLE_WARN_MS   = 20 * 60 * 1000;  // 20 min inactivity → show warning
            var COUNTDOWN_SECS = 60;                 // 60 seconds to respond before auto-logout
            var logoutUrl      = '@Url.Action("Logout", "Account")';

            var idleTimer, countdownTimer, secondsLeft;
            var modal = document.getElementById('idleModal');

            function resetIdle() {
                clearTimeout(idleTimer);
                // Only reset if modal is not already visible
                if (modal.style.display === 'none') {
                    idleTimer = setTimeout(showWarning, IDLE_WARN_MS);
                }
            }

            function showWarning() {
                secondsLeft = COUNTDOWN_SECS;
                document.getElementById('idleCountdown').textContent = secondsLeft;
                modal.style.display = 'flex';
                countdownTimer = setInterval(function () {
                    secondsLeft--;
                    document.getElementById('idleCountdown').textContent = secondsLeft;
                    if (secondsLeft <= 0) {
                        clearInterval(countdownTimer);
                        window.location.href = logoutUrl + '?reason=idle_timeout';
                    }
                }, 1000);
            }

            function dismissWarning() {
                clearInterval(countdownTimer);
                modal.style.display = 'none';
                resetIdle();
            }

            document.getElementById('idleStayBtn').addEventListener('click', dismissWarning);

            // Reset timer on any user activity
            ['mousemove', 'keydown', 'mousedown', 'touchstart', 'scroll'].forEach(function (evt) {
                document.addEventListener(evt, resetIdle, { passive: true });
            });

            resetIdle(); // Start the timer
        })();
    </script>
}
</body>
</html>






