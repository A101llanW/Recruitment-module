@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR Application Status</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .status { padding: 15px; margin: 10px 0; border-radius: 8px; }
        .success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .info { background: #d1ecf1; color: #0c5460; border: 1px solid #bee5eb; }
        .warning { background: #fff3cd; color: #856404; border: 1px solid #ffeaa7; }
        .btn { padding: 10px 20px; margin: 5px; text-decoration: none; border-radius: 5px; display: inline-block; }
        .btn-primary { background: #007bff; color: white; }
        .btn-success { background: #28a745; color: white; }
        .btn-secondary { background: #6c757d; color: white; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    
        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr !important; }
            body { margin: 12px; }
            .container { padding: 16px !important; }
        }
    </style>
</head>
<body>
    <h1>🚀 HR Questionnaire System - MCP Integration</h1>
    
    <div class="status success">
        <h3>✅ Application Status</h3>
        <p><strong>IIS Express:</strong> Running on port 5001</p>
        <p><strong>Build:</strong> Successful</p>
        <p><strong>Entity Framework:</strong> Loaded</p>
        <p><strong>MCP Integration:</strong> Ready</p>
    </div>

    <div class="grid">
        <div class="status info">
            <h3>🧪 Test MCP Features</h3>
            <a href="/Admin/MCPTest" class="btn btn-primary">Test MCP Connection</a><br>
            <a href="/Admin/QuestionsWithMCP" class="btn btn-primary">AI Questions</a><br>
            <a href="/Admin/EditQuestionWithMCP" class="btn btn-primary">AI Editor</a>
        </div>
        
        <div class="status info">
            <h3>📊 Questionnaire Features</h3>
            <a href="/Questionnaire/Preview/1" class="btn btn-success">Preview</a><br>
            <a href="/Questionnaire/Test/1" class="btn btn-success">Test Mode</a><br>
            <a href="/Questionnaire/Builder/1" class="btn btn-success">Builder</a>
        </div>
    </div>

    <div class="status info">
        <h3>🎯 Quick Test Steps</h3>
        <ol>
            <li><strong>Test MCP Connection:</strong> Click "Test MCP Connection" above</li>
            <li><strong>Generate Questions:</strong> Try AI question generation</li>
            <li><strong>Test Questionnaire:</strong> Use the test mode to see scoring</li>
            <li><strong>Build Questionnaire:</strong> Create custom questionnaires</li>
        </ol>
    </div>

    <div class="status warning">
        <h3>⚠️ Important Notes</h3>
        <p>• Make sure Node.js is installed for MCP features</p>
        <p>• Database will be created automatically on first use</p>
        <p>• Some features may require admin/HR role authentication</p>
    </div>

    <div class="status success">
        <h3>🎉 Integration Complete!</h3>
        <p>Your HR questionnaire system now has full MCP integration with AI-powered features including:</p>
        <ul>
            <li>✅ AI question generation from job descriptions</li>
            <li>✅ Question validation and bias detection</li>
            <li>✅ Smart point suggestions</li>
            <li>✅ Advanced scoring system</li>
            <li>✅ Interactive questionnaire testing</li>
            <li>✅ Enhanced candidate rankings</li>
        </ul>
    </div>
</body>
</html>
