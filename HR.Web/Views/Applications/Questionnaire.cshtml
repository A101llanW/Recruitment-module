@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Application Questionnaire";
    ViewBag.SuppressPageHero = true;
    var position = ViewBag.Position as HR.Web.Models.Position;
    var applicant = ViewBag.Applicant as HR.Web.Models.Applicant;
    var positionQuestions = ViewBag.PositionQuestions as IEnumerable<HR.Web.Models.PositionQuestion>;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
}
<h3>Application Questionnaire</h3>
@if (position != null)
{
    <div class="alert alert-info">Applying for: <strong>@position.Title</strong></div>
}
@if (applicant != null)
{
    <div class="alert alert-secondary mb-3">Applicant: <strong>@applicant.FullName</strong> (<span>@applicant.Email</span>)</div>
}
<div class="card shadow-sm border-primary mb-4">
    <div class="card-header bg-primary text-white">
        <h3 class="mb-0">Application Questionnaire</h3>
    </div>
    <div class="card-body">
        @if (position != null)
        {
            <div class="alert alert-info">Applying for: <strong>@position.Title</strong></div>
        }
        @if (applicant != null)
        {
            <div class="alert alert-secondary mb-3">Applicant: <strong>@applicant.FullName</strong> (<span>@applicant.Email</span>)</div>
        }
        @using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" })) {
            @Html.AntiForgeryToken()
            
            if (positionQuestions != null && positionQuestions.Any())
            {
                int questionIndex = 1;
                foreach (var pq in positionQuestions.OrderBy(pq => pq.Order))
                {
                    var question = pq.Question;
                    <div class="form-group mb-4">
                        <label class="font-weight-bold">
                            @(questionIndex). @question.Text
                            @if (pq.IsRequired)
                            {
                                <span class="text-danger">*</span>
                            }
                        </label>
                        
                        @if (question.Type == "Text")
                        {
                            <textarea class="form-control" name="question_@question.Id" rows="3" 
                                @(pq.IsRequired ? "required" : "") placeholder="Enter your answer..."></textarea>
                        }
                        else if (question.Type == "Choice")
                        {
                            var options = question.QuestionOptions != null ? question.QuestionOptions.ToList() : new List<HR.Web.Models.QuestionOption>();
                            if (options.Any())
                            {
                                var inputType = question.AllowMultipleChoices ? "checkbox" : "radio";
                                <div class="form-check">
                                    @foreach (var option in options)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="@inputType" 
                                                name="question_@question.Id" value="@option.Text" 
                                                @(pq.IsRequired && !question.AllowMultipleChoices ? "required" : "") id="option_@option.Id">
                                            <label class="form-check-label" for="option_@option.Id">
                                                @option.Text
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <select class="form-control" name="question_@question.Id" @(pq.IsRequired ? "required" : "")>
                                    <option value="">-- Select an option --</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            }
                        }
                        else if (question.Type == "Number")
                        {
                            <input type="number" class="form-control" name="question_@question.Id" 
                                @(pq.IsRequired ? "required" : "") placeholder="Enter a number">
                        }
                        else if (question.Type == "Rating")
                        {
                            <div class="form-check">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <div class="form-check-inline">
                                        <input class="form-check-input" type="radio" 
                                            name="question_@question.Id" value="@i" 
                                            @(pq.IsRequired ? "required" : "") id="rating_@(question.Id)_@i">
                                        <label class="form-check-label" for="rating_@(question.Id)_@i">@i</label>
                                    </div>
                                }
                                <small class="form-text text-muted">(1 = Poor, 5 = Excellent)</small>
                            </div>
                        }
                        else
                        {
                            <input type="text" class="form-control" name="question_@question.Id" 
                                @(pq.IsRequired ? "required" : "") placeholder="Enter your answer...">
                        }
                    </div>
                    questionIndex++;
                }
            }
            else
            {
                <div class="alert alert-warning">
                    No questions have been assigned to this position yet. Please contact HR.
                </div>
            }
            
            <input type="hidden" name="positionId" value="@(position != null ? position.Id.ToString() : "")" />

            <div class="form-group mt-3 mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="acceptLegalTerms" name="acceptLegalTerms" value="true" required />
                    <label class="form-check-label small text-muted" for="acceptLegalTerms">
                        I agree to the
                        <a href="@Url.Action("Terms", "Home", new { tenant = tenantToken })" target="_blank" rel="noopener">Terms &amp; Conditions</a>
                        and
                        <a href="@Url.Action("Privacy", "Home", new { tenant = tenantToken })" target="_blank" rel="noopener">Privacy Policy</a>.
                    </label>
                </div>
            </div>
            
            <button type="submit" class="btn btn-success btn-lg">Submit Application</button>
        }
    </div>
</div>
