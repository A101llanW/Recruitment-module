@model IEnumerable<HR.Web.Models.Application>
@using System.Collections.Generic
@using HR.Web.ViewModels

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Applications";
    ViewBag.SuppressPageHero = true;
    ViewBag.PageEyebrow = "Hiring pipeline";

    var interviewers = ViewBag.Interviewers as List<HR.Web.Models.User>;
    var interviewedAppIds = ViewBag.InterviewedAppIds as List<int> ?? new List<int>();
    var canManageApplications = ViewBag.CanManageApplications != null ? (bool)ViewBag.CanManageApplications : false;
    var canInviteQuestionnaireSecondaryStage = ViewBag.CanInviteQuestionnaireSecondaryStage != null && (bool)ViewBag.CanInviteQuestionnaireSecondaryStage;
    var returnTo = Request != null ? Request.QueryString["returnTo"] : null;
    var shouldReturnToInterviewsAfterBooking = string.Equals(returnTo, "interviews", StringComparison.OrdinalIgnoreCase);

    var bookInterviewApplicationId = 0;
    if (Request != null)
    {
        int.TryParse(Request.QueryString["bookInterviewApplicationId"], out bookInterviewApplicationId);
    }

    var resumeEmailApplicationId = 0;
    if (Request != null)
    {
        int.TryParse(Request.QueryString["resumeEmailApplicationId"], out resumeEmailApplicationId);
    }

    var targetApplicationId = 0;
    if (Request != null)
    {
        int.TryParse(Request.QueryString["targetApplicationId"], out targetApplicationId);
    }

    var panelistsForCc = ViewBag.EmailCcPanelists as List<HR.Web.Models.User> ?? new List<HR.Web.Models.User>();
    var hrContactsForCc = ViewBag.EmailCcHrContacts as List<HR.Web.Models.CompanyHrCcEmail> ?? new List<HR.Web.Models.CompanyHrCcEmail>();
    var manageHrCcUrl = Url.Action("HrCcEmails", "Admin");
    var failedCandidateEmailApplicationIds = ViewBag.FailedCandidateEmailApplicationIds as HashSet<int>
        ?? new HashSet<int>();

    var totalApplications = Model.Count();
    var openPositionCount = Model
        .Where(a => a.Position != null)
        .Select(a => a.PositionId)
        .Distinct()
        .Count();
}

<style>
    .applications-hub {
        margin: 0 -4px;
        padding-bottom: 1rem;
    }

    .applications-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding: 1rem 1.1rem;
        background: var(--app-surface);
        border: 1px solid var(--app-border);
        border-radius: var(--app-radius);
        box-shadow: 0 4px 18px rgba(13, 44, 74, 0.05);
    }

    .applications-toolbar label {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--app-muted);
        margin-bottom: 0.35rem;
        display: block;
    }

    .applications-toolbar select {
        min-width: 220px;
        border-radius: 8px;
        border-color: var(--app-border);
        font-weight: 500;
    }

    .applications-toolbar select:focus {
        border-color: var(--app-accent-deep);
        box-shadow: 0 0 0 3px rgba(111, 184, 220, 0.25);
    }

    .applications-flash {
        border-radius: var(--app-radius);
        border: none;
        padding: 0.85rem 1.1rem;
        font-weight: 500;
        margin-bottom: 1rem;
    }

    .applications-flash--success {
        background: var(--app-success-soft);
        color: var(--app-success);
    }

    .applications-flash--error {
        background: var(--app-danger-soft);
        color: var(--app-danger);
    }

    .applications-empty {
        text-align: center;
        padding: 3rem 1.5rem;
        border-radius: var(--app-radius);
        background: var(--app-paper);
        border: 1px dashed var(--app-border);
    }

    .applications-empty i {
        font-size: 2rem;
        color: var(--app-accent-deep);
        margin-bottom: 0.75rem;
        display: block;
    }

    .position-panel {
        border: 1px solid var(--app-border) !important;
        background: var(--app-paper) !important;
        border-radius: calc(var(--app-radius) + 2px);
        box-shadow: var(--app-shadow);
        animation: applicationsPanelIn 0.55s ease both;
    }

    @@keyframes applicationsPanelIn {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .position-panel__header {
        margin-bottom: 1.25rem;
        padding-bottom: 1.1rem;
        border-bottom: 1px solid var(--app-border);
    }

    .position-panel__title {
        font-family: "Fraunces", Georgia, serif;
        font-size: 1.45rem;
        font-weight: 700;
        color: var(--app-ink);
        margin: 0 0 0.65rem;
        letter-spacing: -0.02em;
    }

    .position-panel__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }

    .position-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        background: var(--app-surface);
        border: 1px solid var(--app-border);
        color: var(--app-muted);
    }

    .position-chip--count {
        background: rgba(111, 184, 220, 0.2);
        border-color: rgba(111, 184, 220, 0.45);
        color: var(--app-ink);
    }

    .passmark-control {
        max-width: 520px;
        margin-top: 1rem;
        padding: 1rem 1.1rem;
        background: var(--app-surface);
        border-radius: var(--app-radius);
        border: 1px solid var(--app-border);
    }

    .passmark-control label {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--app-muted);
    }

    .passmark-control .custom-range::-webkit-slider-thumb {
        background: var(--app-accent-deep);
    }

    .passmark-control .position-passmark-label {
        font-variant-numeric: tabular-nums;
    }

    .needs-review-toggle {
        border-radius: 999px;
        font-weight: 600;
        padding: 0.4rem 1rem;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .needs-review-toggle:hover {
        transform: translateY(-1px);
    }

    .pipeline-column {
        border: 1px solid var(--app-border) !important;
        border-radius: var(--app-radius);
        padding: 1.1rem 1.15rem !important;
        background: var(--app-surface) !important;
        height: 100%;
    }

    .pipeline-column__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 0.65rem;
        border-bottom: 2px solid var(--app-border);
    }

    .pipeline-column__head h5 {
        font-family: "Fraunces", Georgia, serif;
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0;
    }

    .pipeline-column--passed .pipeline-column__head {
        border-bottom-color: rgba(26, 122, 74, 0.35);
    }

    .pipeline-column--passed .pipeline-column__head h5 {
        color: var(--app-success);
    }

    .pipeline-column--review .pipeline-column__head {
        border-bottom-color: rgba(184, 58, 47, 0.35);
    }

    .pipeline-column--review .pipeline-column__head h5 {
        color: var(--app-danger);
    }

    .pipeline-count {
        font-size: 0.8rem;
        font-weight: 700;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        font-variant-numeric: tabular-nums;
    }

    .pipeline-count--passed {
        background: var(--app-success-soft);
        color: var(--app-success);
    }

    .pipeline-count--review {
        background: var(--app-danger-soft);
        color: var(--app-danger);
    }

    .applications-hub .application-card .card {
        border: 1px solid var(--app-border);
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(13, 44, 74, 0.06);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        overflow: hidden;
    }

    .applications-hub .application-card .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(13, 44, 74, 0.1);
        border-color: rgba(111, 184, 220, 0.5);
    }

    .applications-hub .application-card .card-body {
        padding: 1.1rem 1.15rem;
    }

    .applications-hub .application-card h5 {
        font-weight: 700;
        font-size: 1.02rem;
        color: var(--app-ink);
    }

    .score-pill {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        border-radius: 6px;
        font-size: 0.78rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        background: rgba(111, 184, 220, 0.22);
        color: var(--app-ink);
    }

    .rank-pill {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        background: var(--app-ink);
        color: #fff;
    }

    .applications-hub .btn-info {
        background: var(--app-accent);
        border-color: var(--app-accent);
        color: var(--app-ink);
        font-weight: 600;
    }

    .applications-hub .btn-info:hover {
        background: var(--app-accent-deep);
        border-color: var(--app-accent-deep);
        color: #fff;
    }

    .applications-hub .book-interview-row .form-control {
        border-radius: 8px;
        border-color: var(--app-border);
        font-size: 0.85rem;
    }

    .applications-hub .book-interview-row .btn-success {
        background: var(--app-success);
        border-color: var(--app-success);
        font-weight: 600;
        border-radius: 8px;
    }

    .applications-column-empty {
        padding: 1.25rem;
        text-align: center;
        color: var(--app-muted);
        font-size: 0.9rem;
        background: var(--app-paper);
        border-radius: 10px;
        border: 1px dashed var(--app-border);
        margin: 0;
    }

    .force-capitalize {
        text-transform: capitalize;
    }

    .target-application .card {
        border: 2px solid var(--app-danger) !important;
        box-shadow: 0 0 0 4px rgba(184, 58, 47, 0.18), 0 12px 32px rgba(184, 58, 47, 0.15) !important;
        animation: targetPulse 1.2s ease 2;
    }

    @@keyframes targetPulse {
        0%, 100% { box-shadow: 0 0 0 4px rgba(184, 58, 47, 0.18), 0 12px 32px rgba(184, 58, 47, 0.15); }
        50% { box-shadow: 0 0 0 8px rgba(184, 58, 47, 0.12), 0 12px 32px rgba(184, 58, 47, 0.2); }
    }

    .email-workflow-modal .modal-dialog {
        width: 96vw;
        max-width: 920px;
        margin: 1.5vh auto;
    }

    .email-workflow-modal .modal-content {
        display: flex;
        flex-direction: column;
        max-height: 92vh;
        min-height: 0;
        border-radius: 12px;
        overflow: hidden;
    }

    .email-workflow-modal .modal-content > form {
        display: flex;
        flex-direction: column;
        flex: 1 1 auto;
        min-height: 0;
        max-height: 92vh;
        overflow: hidden;
    }

    .email-workflow-modal .modal-body {
        flex: 1 1 auto;
        min-height: 0;
        overflow-x: hidden;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        position: relative;
    }

    .email-workflow-modal .modal-header,
    .email-workflow-modal .modal-footer {
        flex-shrink: 0;
    }

    .email-choice-card {
        border: 1px solid var(--app-border, #dbe5f0);
        border-radius: 12px;
        padding: 18px;
        background: var(--app-paper, #f8fbff);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .email-choice-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(13, 44, 74, 0.08);
    }

    .failed-email-template-compose {
        border: 1px solid #dbe5f0;
        border-radius: 10px;
        background: #fff;
    }

    .email-workflow-modal .tox-tinymce {
        z-index: 10050 !important;
    }

    .email-editor-body {
        min-height: 300px;
    }

    .failed-single-email-editor,
    .failed-bulk-email-editor {
        min-height: 320px;
    }

    .tox-silver-sink,
    .tox-tinymce-aux {
        z-index: 200000 !important;
    }
</style>

<div class="applications-hub">
    <header class="app-page-hero applications-hero">
        <p class="app-page-hero__eyebrow applications-hero__eyebrow">Hiring pipeline</p>
        <h1 class="app-page-hero__title applications-hero__title">Applications</h1>
        <p class="app-page-hero__lead applications-hero__lead">
            @if (canManageApplications)
            {
                @:Review scored candidates by role, adjust passmarks, and move top talent toward interviews.
            }
            else
            {
                @:Track every application you have submitted across open positions.
            }
        </p>
        @if (totalApplications > 0)
        {
            <div class="app-page-hero__stats applications-hero__stats">
                <span class="app-stat-chip applications-stat">
                    <i class="fas fa-file-alt" aria-hidden="true"></i>
                    @totalApplications application@(totalApplications != 1 ? "s" : "")
                </span>
                @if (openPositionCount > 0)
                {
                    <span class="app-stat-chip applications-stat">
                        <i class="fas fa-briefcase" aria-hidden="true"></i>
                        @openPositionCount position@(openPositionCount != 1 ? "s" : "")
                    </span>
                }
            </div>
        }
    </header>

@if (canManageApplications)
{
    <div class="applications-toolbar">
        <div>
            <label for="sortBy">Sort candidates</label>
            <select id="sortBy" class="form-control">
                <option value="score">Score (Highest First)</option>
                <option value="date">Date (Oldest First)</option>
                <option value="name">Name (A-Z)</option>
            </select>
        </div>
    </div>

    using (Html.BeginForm("UpdatePositionPassMark", "Applications", FormMethod.Post, new { id = "positionPassMarkTokenForm", @class = "d-none" }))
    {
        @Html.AntiForgeryToken()
    }

    <div id="passmarkUpdateError" class="alert applications-flash applications-flash--error d-none" role="alert"></div>
}

@if (TempData["ApplicationEmailSuccess"] != null)
{
    <div class="alert applications-flash applications-flash--success" role="status">@TempData["ApplicationEmailSuccess"]</div>
}

@if (TempData["ApplicationEmailError"] != null)
{
    <div class="alert applications-flash applications-flash--error" role="alert">@TempData["ApplicationEmailError"]</div>
}

@if (!Model.Any())
{
    <div class="applications-empty">
        <i class="fas fa-inbox" aria-hidden="true"></i>
        <p class="mb-0 font-weight-bold">No applications yet</p>
        <p class="small text-muted mb-0 mt-1">New submissions will appear here grouped by position.</p>
    </div>
}
else
{
    var applicationsByPosition = Model
        .Where(a => a.Position != null)
        .GroupBy(a => a.Position)
        .OrderBy(g => g.Key.Title)
        .ToList();

    var panelIndex = 0;
    foreach (var positionGroup in applicationsByPosition)
    {
        var position = positionGroup.Key;
        panelIndex++;
        var passMark = position.PassMark;
        var passMarkRounded = (int)Math.Round(passMark, MidpointRounding.AwayFromZero);
        passMarkRounded = Math.Max(0, Math.Min(100, passMarkRounded));
        const int compactRecordLimit = 5;

        var positionApplications = positionGroup
            .OrderByDescending(a => a.Score ?? 0)
            .ThenBy(a => a.AppliedOn)
            .ToList();
        var passedApplications = positionApplications
            .Where(a => (a.Score ?? 0m) >= passMark)
            .ToList();
        var failedApplications = positionApplications
            .Where(a => (a.Score ?? 0m) < passMark)
            .ToList();

        string departmentName = position.Department != null
    ? position.Department.Name
    : null;

        <div class="position-panel mb-5 p-4"
             data-position-container-id="@position.Id"
             style="animation-delay: @((panelIndex - 1) * 90)ms">

            <div class="position-panel__header">
                <h2 class="position-panel__title">@position.Title</h2>

                <div class="position-panel__meta">
                    <span class="position-chip position-chip--count">
                        <i class="fas fa-users" aria-hidden="true"></i>
                        @positionApplications.Count applicant@(positionApplications.Count != 1 ? "s" : "")
                    </span>

                    @if (!string.IsNullOrEmpty(departmentName))
                    {
                        <span class="position-chip">
                            <i class="fas fa-building" aria-hidden="true"></i> @departmentName
                        </span>
                    }
                </div>

                @if (canManageApplications)
                {
                    <div class="passmark-control mt-3"
                         data-position-id="@position.Id">
                        <label class="font-weight-bold mb-1 d-block">
                            <i class="fas fa-sliders-h"></i> Passmark Midpoint
                        </label>
                        <div class="d-flex align-items-center flex-wrap">
                            <input type="range"
                                   class="custom-range mr-3 position-passmark-slider"
                                   min="0"
                                   max="100"
                                   step="1"
                                   value="@passMarkRounded"
                                   style="max-width: 240px;" />
                            <input type="number"
                                   class="form-control form-control-sm position-passmark-number"
                                   min="0"
                                   max="100"
                                   step="1"
                                   value="@passMarkRounded"
                                   style="width: 90px;" />
                            <span class="badge badge-dark ml-2">
                                <span class="position-passmark-label">@passMarkRounded</span>%
                            </span>
                        </div>
                        <small class="text-muted">
                            Top candidates at or above the passmark are shown first. Use &quot;Show Needs Review&quot; to view applicants below the passmark.
                        </small>
                    </div>
                }
            </div>

            @if (canManageApplications)
            {
                var passedContainerId = "passedApplicationsContainer-" + position.Id;
                var passedMetaId = "passedApplicationsMeta-" + position.Id;
                var passedShowMoreId = "passedApplicationsShowMore-" + position.Id;
                var failedContainerId = "failedApplicationsContainer-" + position.Id;
                var failedMetaId = "failedApplicationsMeta-" + position.Id;
                var failedShowMoreId = "failedApplicationsShowMore-" + position.Id;
                var needsReviewColumnId = "needsReviewColumn-" + position.Id;
                var needsReviewToggleId = "needsReviewToggle-" + position.Id;
                var topCandidatesColumnId = "topCandidatesColumn-" + position.Id;
                if (failedApplications.Count > 0)
                {
                    <div class="mb-3">
                        <button type="button"
                                id="@needsReviewToggleId"
                                class="btn btn-sm btn-outline-danger needs-review-toggle"
                                data-position-id="@position.Id"
                                data-failed-count="@failedApplications.Count"
                                onclick="toggleNeedsReviewColumn(@position.Id)">
                            Show Needs Review (@failedApplications.Count)
                        </button>
                    </div>
                }
                <div class="row applications-columns-row"
                     data-position-id="@position.Id"
                     data-needs-review-visible="false">
                    <div class="col-12 mb-3 applications-top-column"
                         id="@topCandidatesColumnId">
                        <div class="pipeline-column pipeline-column--passed h-100">
                            <div class="pipeline-column__head">
                                <h5>Top Candidates</h5>
                                <span class="pipeline-count pipeline-count--passed">@passedApplications.Count</span>
                            </div>
                            <div class="d-flex flex-wrap align-items-center justify-content-between mb-2 applications-compact-controls d-none">
                                <small class="text-muted applications-compact-meta" id="@passedMetaId"></small>
                                <button type="button"
                                        class="btn btn-sm btn-outline-success applications-show-more-btn"
                                        id="@passedShowMoreId"
                                        onclick="showMoreApplications('@passedContainerId')">
                                    Show 5 more
                                </button>
                            </div>
                            <div id="@passedContainerId"
                                 class="applications-column-cards"
                                 data-position-id="@position.Id"
                                 data-compact-limit="@compactRecordLimit"
                                 data-page-size="@compactRecordLimit"
                                 data-visible-count="@compactRecordLimit"
                                 data-meta-id="@passedMetaId"
                                 data-show-more-id="@passedShowMoreId">
                                @if (!passedApplications.Any())
                                {
                                    <div class="applications-column-empty">
                                        No applicants are at or above the passmark.
                                    </div>
                                }
                                else
                                {
                                    var rank = 1;
                                    var passedCardIndex = 0;
                                    foreach (var item in passedApplications)
                                    {
                                        var hasInterview = interviewedAppIds.Contains(item.Id);
                                        var score = item.Score ?? 0m;
                                        var applicantName = item.Applicant != null ? item.Applicant.FullName : "N/A";
                                        var cardClass = passedCardIndex >= compactRecordLimit
                                            ? "application-card mb-3 compact-extra d-none"
                                            : "application-card mb-3";
                                        <div class="@cardClass"
                                             id="application-card-@item.Id"
                                             data-status="@item.Status"
                                             data-date="@item.AppliedOn.ToString("yyyy-MM-dd")"
                                             data-score="@score"
                                             data-name="@applicantName">
                                            <div class="card h-100 shadow-sm">
                                                <div class="card-body d-flex flex-column">
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <div>
                                                            <div class="d-flex align-items-center">
                                                                @if (item.Score.HasValue)
                                                                {
                                                                    <span class="rank-pill mr-2">#@rank</span>
                                                                }
                                                                <h5 class="mb-0 force-capitalize">
                                                                    @applicantName
                                                                </h5>
                                                            </div>
                                                            <small class="text-muted">
                                                                Applied @item.AppliedOn.ToShortDateString()
                                                            </small>
                                                        </div>
                                                        <div class="text-right">
                                                            @if (item.Score.HasValue)
                                                            {
                                                                <div class="mt-1">
                                                                    <span class="score-pill">
                                                                        Score @item.Score.Value.ToString("F1")
                                                                    </span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div class="mt-auto">
                                                        <div class="mb-2">
                                                            <a href="@Url.Action("Details", "Applicants", new { id = item.ApplicantId, returnTo = "applications" })"
                                                               class="btn btn-sm btn-info">
                                                                <i class="fas fa-user"></i> Profile
                                                            </a>
                                                        </div>
                                                        @{
                                                            var questionnaireStageCountPassed = Math.Max(1, position.QuestionnaireStageCount);
                                                            var canInviteNextQuestionnairePassed = questionnaireStageCountPassed > 1
                                                                && item.LastCompletedQuestionnaireStage > 0
                                                                && item.LastCompletedQuestionnaireStage < questionnaireStageCountPassed
                                                                && !item.PendingQuestionnaireStage.HasValue;
                                                        }
                                                        @if (questionnaireStageCountPassed > 1)
                                                        {
                                                            <div class="mb-2 small text-muted">
                                                                Questionnaire: @Math.Max(0, item.LastCompletedQuestionnaireStage) of @questionnaireStageCountPassed stage(s) completed
                                                                @if (item.PendingQuestionnaireStage.HasValue)
                                                                {
                                                                    <span class="badge badge-warning text-dark">Stage @item.PendingQuestionnaireStage.Value open for candidate</span>
                                                                }
                                                            </div>
                                                        }
                                                        @if (canInviteNextQuestionnairePassed && canInviteQuestionnaireSecondaryStage)
                                                        {
                                                            using (Html.BeginForm("InviteNextQuestionnaireStage", "Applications", FormMethod.Post))
                                                            {
                                                                @Html.AntiForgeryToken()
                                                                @Html.Hidden("applicationId", item.Id)
                                                                <button type="submit" class="btn btn-sm btn-outline-primary mb-2">
                                                                    <i class="fas fa-door-open"></i> Open next questionnaire stage
                                                                </button>
                                                            }
                                                        }
                                                        @if (hasInterview)
                                                        {
                                                            <span class="badge badge-success">
                                                                <i class="fas fa-check"></i> Interview Booked
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            using (Html.BeginForm("BookInterview", "Interviews", FormMethod.Post))
                                                            {
                                                                @Html.AntiForgeryToken()
                                                                @Html.Hidden("applicationId", item.Id)
                                                                if (shouldReturnToInterviewsAfterBooking && bookInterviewApplicationId == item.Id)
                                                                {
                                                                    @Html.Hidden("returnTo", "interviews")
                                                                    @Html.Hidden("resumeEmailApplicationId", resumeEmailApplicationId > 0 ? resumeEmailApplicationId : item.Id)
                                                                }

                                                                <div class="form-row book-interview-row">
                                                                    <div class="col-12 col-md-4 mb-2">
                                                                        <select name="interviewerId"
                                                                                class="form-control form-control-sm"
                                                                                required>
                                                                            <option value="">Interviewer</option>
                                                                            @foreach (var i in interviewers ?? new List<HR.Web.Models.User>())
                                                                            {
                                                                                <option value="@i.Id">@i.UserName</option>
                                                                            }
                                                                        </select>
                                                                    </div>

                                                                    <div class="col-12 col-md-4 mb-2">
                                                                        <input type="datetime-local"
                                                                               name="scheduledAt"
                                                                               class="form-control form-control-sm"
                                                                               required
                                                                               value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" />
                                                                    </div>

                                                                    <div class="col-12 col-md-2 mb-2">
                                                                        <select name="mode"
                                                                                class="form-control form-control-sm"
                                                                                required>
                                                                            <option value="Remote">Remote</option>
                                                                            <option value="Onsite">Onsite</option>
                                                                        </select>
                                                                    </div>

                                                                    <div class="col-12 col-md-2">
                                                                        <button type="submit"
                                                                                class="btn btn-sm btn-success btn-block">
                                                                            Book
                                                                        </button>
                                                                    </div>
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        passedCardIndex++;
                                        rank++;
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 mb-3 d-none"
                         id="@needsReviewColumnId">
                        <div class="pipeline-column pipeline-column--review h-100">
                            <div class="pipeline-column__head">
                                <h5>Needs Review</h5>
                                <span class="pipeline-count pipeline-count--review">@failedApplications.Count</span>
                            </div>
                            @if (failedApplications.Any())
                            {
                                var bulkDefaultFailedSubject = string.Format(
                                    "Update on your application for {0}",
                                    string.IsNullOrWhiteSpace(position.Title) ? "this position" : position.Title);
                                <div class="mb-3">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="openFailedBulkEmailChoice(this)"
                                            data-position-id="@position.Id"
                                            data-position-title="@(string.IsNullOrWhiteSpace(position.Title) ? "this position" : position.Title)"
                                            data-failed-count="@failedApplications.Count"
                                            data-default-subject="@bulkDefaultFailedSubject">
                                        <i class="fas fa-envelope"></i> Email All Failed Candidates
                                    </button>
                                </div>
                            }
                            <div class="d-flex flex-wrap align-items-center justify-content-between mb-2 applications-compact-controls d-none">
                                <small class="text-muted applications-compact-meta" id="@failedMetaId"></small>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger applications-show-more-btn"
                                        id="@failedShowMoreId"
                                        onclick="showMoreApplications('@failedContainerId')">
                                    Show 5 more
                                </button>
                            </div>
                            <div id="@failedContainerId"
                                 class="applications-column-cards"
                                 data-position-id="@position.Id"
                                 data-compact-limit="@compactRecordLimit"
                                 data-page-size="@compactRecordLimit"
                                 data-visible-count="@compactRecordLimit"
                                 data-meta-id="@failedMetaId"
                                 data-show-more-id="@failedShowMoreId">
                                @if (!failedApplications.Any())
                                {
                                    <div class="applications-column-empty">
                                        No applicants are below the passmark.
                                    </div>
                                }
                                else
                                {
                                    var rank = 1;
                                    var failedCardIndex = 0;
                                    foreach (var item in failedApplications)
                                    {
                                        var hasInterview = interviewedAppIds.Contains(item.Id);
                                        var score = item.Score ?? 0m;
                                        var applicantName = item.Applicant != null ? item.Applicant.FullName : "N/A";
                                        var cardClass = failedCardIndex >= compactRecordLimit
                                            ? "application-card mb-3 compact-extra d-none"
                                            : "application-card mb-3";
                                        <div class="@cardClass"
                                             id="application-card-@item.Id"
                                             data-status="@item.Status"
                                             data-date="@item.AppliedOn.ToString("yyyy-MM-dd")"
                                             data-score="@score"
                                             data-name="@applicantName">
                                            <div class="card h-100 shadow-sm">
                                                <div class="card-body d-flex flex-column">
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <div>
                                                            <div class="d-flex align-items-center">
                                                                @if (item.Score.HasValue)
                                                                {
                                                                    <span class="rank-pill mr-2" style="background:#5a6b7d;">#@rank</span>
                                                                }
                                                                <h5 class="mb-0 force-capitalize">
                                                                    @applicantName
                                                                </h5>
                                                                @if (failedCandidateEmailApplicationIds.Contains(item.Id))
                                                                {
                                                                    <span class="badge badge-secondary ml-2 align-middle" title="Failed-candidate notification email sent">Emailed</span>
                                                                }
                                                            </div>
                                                            <small class="text-muted">
                                                                Applied @item.AppliedOn.ToShortDateString()
                                                            </small>
                                                        </div>
                                                        <div class="text-right">
                                                            @if (item.Score.HasValue)
                                                            {
                                                                <div class="mt-1">
                                                                    <span class="score-pill">
                                                                        Score @item.Score.Value.ToString("F1")
                                                                    </span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div class="mt-auto">
                                                        <div class="mb-2">
                                                            <a href="@Url.Action("Details", "Applicants", new { id = item.ApplicantId, returnTo = "applications" })"
                                                               class="btn btn-sm btn-info">
                                                                <i class="fas fa-user"></i> Profile
                                                            </a>
                                                        </div>
                                                        @{
                                                            var questionnaireStageCountFailed = Math.Max(1, position.QuestionnaireStageCount);
                                                            var canInviteNextQuestionnaireFailed = questionnaireStageCountFailed > 1
                                                                && item.LastCompletedQuestionnaireStage > 0
                                                                && item.LastCompletedQuestionnaireStage < questionnaireStageCountFailed
                                                                && !item.PendingQuestionnaireStage.HasValue;
                                                        }
                                                        @if (questionnaireStageCountFailed > 1)
                                                        {
                                                            <div class="mb-2 small text-muted">
                                                                Questionnaire: @Math.Max(0, item.LastCompletedQuestionnaireStage) of @questionnaireStageCountFailed stage(s) completed
                                                                @if (item.PendingQuestionnaireStage.HasValue)
                                                                {
                                                                    <span class="badge badge-warning text-dark">Stage @item.PendingQuestionnaireStage.Value open for candidate</span>
                                                                }
                                                            </div>
                                                        }
                                                        @if (canInviteNextQuestionnaireFailed && canInviteQuestionnaireSecondaryStage)
                                                        {
                                                            using (Html.BeginForm("InviteNextQuestionnaireStage", "Applications", FormMethod.Post))
                                                            {
                                                                @Html.AntiForgeryToken()
                                                                @Html.Hidden("applicationId", item.Id)
                                                                <button type="submit" class="btn btn-sm btn-outline-primary mb-2">
                                                                    <i class="fas fa-door-open"></i> Open next questionnaire stage
                                                                </button>
                                                            }
                                                        }
                                                        <div class="mb-2">
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-danger"
                                                                    onclick="openFailedCandidateEmailChoice(this)"
                                                                    data-application-id="@item.Id"
                                                                    data-candidate-name="@applicantName"
                                                                    data-position-title="@(string.IsNullOrWhiteSpace(position.Title) ? "this position" : position.Title)"
                                                                    data-default-subject="@string.Format("Update on your application for {0}", string.IsNullOrWhiteSpace(position.Title) ? "this position" : position.Title)">
                                                                <i class="fas fa-envelope"></i> Email Candidate
                                                            </button>
                                                        </div>
                                                        @if (hasInterview)
                                                        {
                                                            <span class="badge badge-success">
                                                                <i class="fas fa-check"></i> Interview Booked
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            using (Html.BeginForm("BookInterview", "Interviews", FormMethod.Post))
                                                            {
                                                                @Html.AntiForgeryToken()
                                                                @Html.Hidden("applicationId", item.Id)
                                                                if (shouldReturnToInterviewsAfterBooking && bookInterviewApplicationId == item.Id)
                                                                {
                                                                    @Html.Hidden("returnTo", "interviews")
                                                                    @Html.Hidden("resumeEmailApplicationId", resumeEmailApplicationId > 0 ? resumeEmailApplicationId : item.Id)
                                                                }

                                                                <div class="form-row book-interview-row">
                                                                    <div class="col-12 col-md-4 mb-2">
                                                                        <select name="interviewerId"
                                                                                class="form-control form-control-sm"
                                                                                required>
                                                                            <option value="">Interviewer</option>
                                                                            @foreach (var i in interviewers ?? new List<HR.Web.Models.User>())
                                                                            {
                                                                                <option value="@i.Id">@i.UserName</option>
                                                                            }
                                                                        </select>
                                                                    </div>

                                                                    <div class="col-12 col-md-4 mb-2">
                                                                        <input type="datetime-local"
                                                                               name="scheduledAt"
                                                                               class="form-control form-control-sm"
                                                                               required
                                                                               value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" />
                                                                    </div>

                                                                    <div class="col-12 col-md-2 mb-2">
                                                                        <select name="mode"
                                                                                class="form-control form-control-sm"
                                                                                required>
                                                                            <option value="Remote">Remote</option>
                                                                            <option value="Onsite">Onsite</option>
                                                                        </select>
                                                                    </div>

                                                                    <div class="col-12 col-md-2">
                                                                        <button type="submit"
                                                                                class="btn btn-sm btn-success btn-block">
                                                                            Book
                                                                        </button>
                                                                    </div>
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        failedCardIndex++;
                                        rank++;
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                var publicContainerId = "allApplicationsContainer-" + position.Id;
                var publicToggleLabelId = "allApplicationsToggleLabel-" + position.Id;
                var publicToggleIconId = "allApplicationsToggleIcon-" + position.Id;
                if (positionApplications.Count > compactRecordLimit)
                {
                    <div class="mb-3">
                        <button type="button"
                                class="btn btn-sm btn-outline-primary needs-review-toggle"
                                onclick="toggleApplicationsCompact('@publicContainerId', '@publicToggleLabelId', '@publicToggleIconId')">
                            <span id="@publicToggleLabelId">Show all @positionApplications.Count</span>
                            <i id="@publicToggleIconId" class="fas fa-chevron-down ml-1"></i>
                        </button>
                    </div>
                }
                <div id="@publicContainerId"
                     class="row applications-column-cards"
                     data-position-id="@position.Id"
                     data-compact-limit="@compactRecordLimit"
                     data-expanded="false"
                     data-toggle-label-id="@publicToggleLabelId"
                     data-toggle-icon-id="@publicToggleIconId">
                    @{
                        var publicCardIndex = 0;
                    }
                    @foreach (var item in positionApplications)
                    {
                        var score = item.Score ?? 0m;
                        var applicantName = item.Applicant != null ? item.Applicant.FullName : "N/A";
                        var cardClass = publicCardIndex >= compactRecordLimit
                            ? "application-card col-12 col-lg-6 mb-3 compact-extra d-none"
                            : "application-card col-12 col-lg-6 mb-3";
                        <div class="@cardClass"
                             id="application-card-@item.Id"
                             data-status="@item.Status"
                             data-date="@item.AppliedOn.ToString("yyyy-MM-dd")"
                             data-score="@score"
                             data-name="@applicantName">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h5 class="mb-1 force-capitalize">@applicantName</h5>
                                            <small class="text-muted d-block">
                                                Applied @item.AppliedOn.ToShortDateString()
                                            </small>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(item.Status))
                                        {
                                            <span class="position-chip">@item.Status</span>
                                        }
                                    </div>
                                    @if (item.Score.HasValue)
                                    {
                                        <div class="mt-auto">
                                            <span class="score-pill">Score @item.Score.Value.ToString("F1")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        publicCardIndex++;
                    }
                </div>
            }
        </div>
    }
}

</div>

