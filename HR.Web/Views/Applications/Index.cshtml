    <script>
        (function () {
            var highlightedApplicationId = @targetApplicationId;
            if (!highlightedApplicationId) {
                highlightedApplicationId = @bookInterviewApplicationId;
            }
            if (!highlightedApplicationId) return;

            var card = document.getElementById('application-card-' + highlightedApplicationId);
            if (!card) return;

            card.classList.add('target-application');
            card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        })();

        function toggleElementById(id) {
            var element = document.getElementById(id);
            if (!element) return;

            if (element.classList.contains('d-none')) {
                element.classList.remove('d-none');
            } else {
                element.classList.add('d-none');
            }
        }

        function hideElementById(id) {
            var element = document.getElementById(id);
            if (!element) return;
            element.classList.add('d-none');
        }

        function getApplicationsPageSize(container) {
            var pageSize = parseInt(container.getAttribute('data-page-size'), 10);
            if (isNaN(pageSize) || pageSize <= 0) {
                pageSize = parseInt(container.getAttribute('data-compact-limit'), 10) || 5;
            }
            return pageSize;
        }

        function getApplicationsVisibleCount(container) {
            var limit = parseInt(container.getAttribute('data-compact-limit'), 10) || 5;
            var visibleCount = parseInt(container.getAttribute('data-visible-count'), 10);
            if (isNaN(visibleCount) || visibleCount <= 0) {
                visibleCount = limit;
                container.setAttribute('data-visible-count', String(visibleCount));
            }
            return visibleCount;
        }

        function applyCompactState(container) {
            if (!container) return;

            if (container.hasAttribute('data-visible-count')) {
                var visibleCount = getApplicationsVisibleCount(container);
                var cards = Array.prototype.slice.call(container.querySelectorAll('.application-card'));
                cards.forEach(function (card, index) {
                    card.classList.toggle('d-none', index >= visibleCount);
                });
                return;
            }

            var limit = parseInt(container.getAttribute('data-compact-limit'), 10);
            if (isNaN(limit) || limit <= 0) return;

            var legacyCards = Array.prototype.slice.call(container.querySelectorAll('.application-card'));
            var expanded = container.getAttribute('data-expanded') === 'true';
            legacyCards.forEach(function (card, index) {
                card.classList.toggle('d-none', !expanded && index >= limit);
            });
        }

        function updateCompactToggleUi(container) {
            if (!container) return;

            if (container.hasAttribute('data-visible-count')) {
                var pageSize = getApplicationsPageSize(container);
                var visibleCount = getApplicationsVisibleCount(container);
                var cards = Array.prototype.slice.call(container.querySelectorAll('.application-card'));
                var metaId = container.getAttribute('data-meta-id');
                var showMoreId = container.getAttribute('data-show-more-id');
                var meta = metaId ? document.getElementById(metaId) : null;
                var showMoreBtn = showMoreId ? document.getElementById(showMoreId) : null;
                var controlsWrapper = showMoreBtn ? showMoreBtn.closest('.applications-compact-controls') : null;

                if (cards.length === 0) {
                    if (controlsWrapper) {
                        controlsWrapper.classList.add('d-none');
                    }
                    return;
                }

                var showing = Math.min(visibleCount, cards.length);
                if (meta) {
                    meta.textContent = 'Showing ' + showing + ' of ' + cards.length;
                }

                if (visibleCount >= cards.length) {
                    if (controlsWrapper) {
                        controlsWrapper.classList.add('d-none');
                    }
                } else {
                    if (controlsWrapper) {
                        controlsWrapper.classList.remove('d-none');
                    }
                    if (showMoreBtn) {
                        var nextBatch = Math.min(pageSize, cards.length - visibleCount);
                        showMoreBtn.textContent = 'Show ' + nextBatch + ' more';
                    }
                }
                return;
            }

            var limit = parseInt(container.getAttribute('data-compact-limit'), 10);
            if (isNaN(limit) || limit <= 0) return;

            var legacyCards = Array.prototype.slice.call(container.querySelectorAll('.application-card'));
            var labelId = container.getAttribute('data-toggle-label-id');
            var iconId = container.getAttribute('data-toggle-icon-id');
            var label = labelId ? document.getElementById(labelId) : null;
            var icon = iconId ? document.getElementById(iconId) : null;

            if (legacyCards.length <= limit) {
                if (label && label.parentElement) {
                    label.parentElement.style.display = 'none';
                }
                return;
            }

            var expanded = container.getAttribute('data-expanded') === 'true';
            if (label) {
                label.textContent = expanded ? ('Show Top ' + limit) : ('Show All (' + legacyCards.length + ')');
            }
            if (icon) {
                icon.classList.toggle('fa-chevron-down', !expanded);
                icon.classList.toggle('fa-chevron-up', expanded);
            }
        }

        function initializeCompactContainers(scope) {
            var root = scope || document;
            root.querySelectorAll('.applications-column-cards[data-compact-limit]').forEach(function (container) {
                if (container.hasAttribute('data-visible-count')) {
                    var limit = parseInt(container.getAttribute('data-compact-limit'), 10) || 5;
                    if (!container.hasAttribute('data-page-size')) {
                        container.setAttribute('data-page-size', String(limit));
                    }
                }
                applyCompactState(container);
                updateCompactToggleUi(container);
            });
        }

        function showMoreApplications(containerId) {
            var container = document.getElementById(containerId);
            if (!container || !container.hasAttribute('data-visible-count')) return;

            var pageSize = getApplicationsPageSize(container);
            var visibleCount = getApplicationsVisibleCount(container);
            var cards = container.querySelectorAll('.application-card');
            var newCount = Math.min(visibleCount + pageSize, cards.length);
            container.setAttribute('data-visible-count', String(newCount));
            applyCompactState(container);
            updateCompactToggleUi(container);
        }

        function toggleNeedsReviewColumn(positionId) {
            var column = document.getElementById('needsReviewColumn-' + positionId);
            var topColumn = document.getElementById('topCandidatesColumn-' + positionId);
            var toggleBtn = document.getElementById('needsReviewToggle-' + positionId);
            var row = document.querySelector('.applications-columns-row[data-position-id="' + positionId + '"]');
            if (!column || !toggleBtn) return;

            var isVisible = !column.classList.contains('d-none');
            if (isVisible) {
                column.classList.add('d-none');
                if (topColumn) {
                    topColumn.classList.remove('col-lg-6');
                    topColumn.classList.add('col-12');
                }
                if (row) {
                    row.setAttribute('data-needs-review-visible', 'false');
                }
                toggleBtn.textContent = 'Show Needs Review (' + (toggleBtn.getAttribute('data-failed-count') || '0') + ')';
                toggleBtn.classList.remove('btn-danger');
                toggleBtn.classList.add('btn-outline-danger');
                return;
            }

            column.classList.remove('d-none');
            if (topColumn) {
                topColumn.classList.add('col-lg-6');
            }
            if (row) {
                row.setAttribute('data-needs-review-visible', 'true');
            }
            toggleBtn.textContent = 'Hide Needs Review';
            toggleBtn.classList.add('btn-danger');
            toggleBtn.classList.remove('btn-outline-danger');

            var failedContainer = column.querySelector('.applications-column-cards');
            if (failedContainer) {
                applyCompactState(failedContainer);
                updateCompactToggleUi(failedContainer);
            }
        }

        function initializeNeedsReviewColumns(scope) {
            var root = scope || document;
            root.querySelectorAll('.needs-review-toggle').forEach(function (btn) {
                var positionId = btn.getAttribute('data-position-id');
                var column = document.getElementById('needsReviewColumn-' + positionId);
                var topColumn = document.getElementById('topCandidatesColumn-' + positionId);
                var row = root.querySelector('.applications-columns-row[data-position-id="' + positionId + '"]');
                if (column) {
                    column.classList.add('d-none');
                }
                if (topColumn) {
                    topColumn.classList.remove('col-lg-6');
                    topColumn.classList.add('col-12');
                }
                if (row) {
                    row.setAttribute('data-needs-review-visible', 'false');
                }
                btn.textContent = 'Show Needs Review (' + (btn.getAttribute('data-failed-count') || '0') + ')';
                btn.classList.remove('btn-danger');
                btn.classList.add('btn-outline-danger');
            });
        }

        function toggleApplicationsCompact(containerId, labelId, iconId) {
            var container = document.getElementById(containerId);
            if (!container) return;

            var expanded = container.getAttribute('data-expanded') === 'true';
            container.setAttribute('data-expanded', expanded ? 'false' : 'true');

            if (labelId) container.setAttribute('data-toggle-label-id', labelId);
            if (iconId) container.setAttribute('data-toggle-icon-id', iconId);

            applyCompactState(container);
            updateCompactToggleUi(container);
        }

        function applyApplicationsSort() {
            var sortBy = document.getElementById('sortBy');
            if (!sortBy) return;

            var sortValue = sortBy.value;
            document.querySelectorAll('.applications-column-cards').forEach(function (container) {
                var cards = Array.prototype.slice.call(container.querySelectorAll('.application-card'));
                cards.sort(function (a, b) {
                    if (sortValue === 'score') return (+b.dataset.score) - (+a.dataset.score);
                    if (sortValue === 'date') return a.dataset.date.localeCompare(b.dataset.date);
                    return (a.dataset.name || '').localeCompare(b.dataset.name || '');
                });
                cards.forEach(function (card) { container.appendChild(card); });
                applyCompactState(container);
                updateCompactToggleUi(container);
            });
        }

        (function () {
            var sortBy = document.getElementById('sortBy');
            if (!sortBy || sortBy.dataset.bound === '1') return;

            sortBy.dataset.bound = '1';
            sortBy.addEventListener('change', applyApplicationsSort);
        })();

        initializeCompactContainers(document);
        initializeNeedsReviewColumns(document);

        (function () {
            var tokenInput = document.querySelector('#positionPassMarkTokenForm input[name="__RequestVerificationToken"]');
            var antiForgeryToken = tokenInput ? tokenInput.value : '';
            var errorBanner = document.getElementById('passmarkUpdateError');
            var updateUrl = '@Url.Action("UpdatePositionPassMark", "Applications")';
            var savingByPosition = {};

            function clamp(rawValue) {
                var parsed = parseInt(rawValue, 10);
                if (isNaN(parsed)) return 0;
                return Math.max(0, Math.min(100, parsed));
            }

            function setError(message) {
                if (!errorBanner) return;
                if (!message) {
                    errorBanner.classList.add('d-none');
                    errorBanner.textContent = '';
                    return;
                }

                errorBanner.textContent = message;
                errorBanner.classList.remove('d-none');
            }

            function postPassmark(positionId, passMark) {
                var payload = '__RequestVerificationToken=' + encodeURIComponent(antiForgeryToken)
                    + '&positionId=' + encodeURIComponent(positionId)
                    + '&passMark=' + encodeURIComponent(passMark);

                return fetch(updateUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: payload,
                    credentials: 'same-origin'
                }).then(function (response) {
                    if (!response.ok) {
                        throw new Error('Unable to update passmark.');
                    }
                    return response.json();
                });
            }

            function refreshPositionContainer(positionId) {
                var currentContainer = document.querySelector('[data-position-container-id="' + positionId + '"]');
                if (!currentContainer) {
                    return Promise.resolve();
                }

                var refreshUrl = window.location.pathname + window.location.search;
                return fetch(refreshUrl, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('Unable to refresh applicant columns.');
                        }
                        return response.text();
                    })
                    .then(function (html) {
                        var parser = new DOMParser();
                        var doc = parser.parseFromString(html, 'text/html');
                        var replacement = doc.querySelector('[data-position-container-id="' + positionId + '"]');
                        if (!replacement) {
                            throw new Error('Unable to refresh applicant columns.');
                        }

                        currentContainer.replaceWith(replacement);
                        bindPassmarkControl(replacement.querySelector('.passmark-control'));
                        initializeCompactContainers(replacement);
                        initializeNeedsReviewColumns(replacement);
                        applyApplicationsSort();
                    });
            }

            function bindPassmarkControl(control) {
                if (!control || control.dataset.passmarkBound === '1') {
                    return;
                }

                var positionId = control.getAttribute('data-position-id');
                var slider = control.querySelector('.position-passmark-slider');
                var number = control.querySelector('.position-passmark-number');
                var label = control.querySelector('.position-passmark-label');

                if (!positionId || !slider || !number || !label) {
                    return;
                }

                control.dataset.passmarkBound = '1';

                function sync(rawValue) {
                    var value = clamp(rawValue);
                    slider.value = value;
                    number.value = value;
                    label.textContent = value;
                    return value;
                }

                function setSaving(isSaving) {
                    slider.disabled = isSaving;
                    number.disabled = isSaving;
                }

                function persist() {
                    var value = sync(slider.value);
                    if (savingByPosition[positionId] === true) return;

                    savingByPosition[positionId] = true;
                    setSaving(true);
                    setError(null);

                    postPassmark(positionId, value)
                        .then(function (result) {
                            if (!result || result.success !== true) {
                                throw new Error(result && result.message ? result.message : 'Unable to update passmark.');
                            }

                            return refreshPositionContainer(positionId);
                        })
                        .catch(function (error) {
                            setError(error && error.message ? error.message : 'Unable to update passmark.');
                        })
                        .then(function () {
                            savingByPosition[positionId] = false;
                            setSaving(false);
                        });
                }

                slider.addEventListener('input', function () {
                    sync(slider.value);
                });

                slider.addEventListener('change', persist);

                number.addEventListener('input', function () {
                    sync(number.value);
                });

                number.addEventListener('change', function () {
                    sync(number.value);
                    persist();
                });
            }

            document.querySelectorAll('.passmark-control').forEach(bindPassmarkControl);
        })();
    </script>
}
