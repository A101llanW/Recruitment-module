                                    <button type="button" class="btn btn-success btn-sm" id="failedBulkTemplateSaveBtn" title="Apply edits to the form before sending">
                                        <i class="fas fa-save mr-1"></i>Save
                                    </button>
                                </div>
                                <div id="failedBulkTemplateSaveAck" class="alert alert-success py-2 px-3 small d-none" role="status">Edits saved in this form. Choose CC below, then send.</div>
                            </div>
                        </div>

                        <hr class="my-3" />
                        <p class="small font-weight-bold text-muted mb-2">Copy on send (optional)</p>
                        @Html.Partial("_CandidateEmailCcFields", new CandidateEmailCcFieldsModel
                        {
                            Prefix = "failedBulkEmailEditor",
                            Panelists = panelistsForCc,
                            HrContacts = hrContactsForCc,
                            ManageHrCcUrl = manageHrCcUrl
                        })
                    </div>
                    <div class="modal-footer flex-shrink-0 border-top">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-paper-plane mr-1"></i>Send to All Failed
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

