@model IEnumerable<HR.Web.ViewModels.UserManagementViewModel>

<div class="table-responsive">
    <table class="table table-hover table-system align-middle mb-0">
        <thead>
            <tr>
                <th>User Identity</th>
                <th>Role</th>
                <th>Company</th>
                <th>Recent Activity</th>
                <th>Status</th>
                <th class="text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="bg-white">
            @foreach (HR.Web.ViewModels.UserManagementViewModel user in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="avatar-circle mr-3">
                                @(!string.IsNullOrEmpty(user.FirstName) ? user.FirstName.Substring(0, 1).ToUpper() : (string.IsNullOrEmpty(user.UserName) ? "?" : user.UserName.Substring(0, 1).ToUpper()))
                            </div>
                            <div>
                                <div style="font-weight: 600; color: #0d2c4a;">@user.FirstName @user.LastName</div>
                                <div class="text-muted small">@user.UserName &bull; @user.Email</div>
                                @if (user.Role == "SuperAdmin")
                                {
                                    <span class="badge badge-danger" style="font-size: 0.65rem; padding: 2px 5px;">
                                        <i class="fas fa-crown mr-1"></i>SYSTEM MASTER
                                    </span>
                                }
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="role-text" style="font-weight: 600;">@user.Role</span>
                    </td>
                    <td>
                        <span class="text-secondary"><i class="fas @(user.CompanyName == "System" ? "fa-server" : "fa-building") mr-2"></i>@user.CompanyName</span>
                    </td>
                    <td>
                        @if (user.LastLoginDate.HasValue)
                        {
                            <div class="small">@user.LastLoginDate.Value.ToString("g")</div>
                            <div class="text-info x-small">@user.LastLoginIP</div>
                        }
                        else
                        {
                            <span class="text-muted small italic">Never Logged In</span>
                        }
                    </td>
                    <td>
                        <span class="badge badge-@(user.IsLocked ? "danger" : "success") badge-system">
                            @(user.IsLocked ? "LOCKED" : "ACTIVE")
                        </span>
                    </td>
                    <td class="text-right">
                        <div class="d-flex justify-content-end gap-2">
                            @if (user.IsLocked)
                            {
                                using (Html.BeginForm("UnlockUserAccount", "Admin", new { id = user.Id }, FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Unlock" onclick="return confirm('Unlock user?');">
                                        <i class="fas fa-unlock"></i>
                                    </button>
                                }
                            }
                            @if (user.Role != "SuperAdmin" && User.IsInRole("SuperAdmin") && ViewContext.RouteData.Values["action"] != null && ViewContext.RouteData.Values["action"].ToString() == "GlobalUserManagement")
                            {
                                using (Html.BeginForm("ElevateToSuperAdmin", "Admin", new { id = user.Id }, FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Elevate" onclick="return confirm('Promote to SuperAdmin?');">
                                        <i class="fas fa-crown"></i>
                                    </button>
                                }
                            }
                            <a href="@Url.Action("UpdateUserRole", "Admin", new { id = user.Id })" class="btn-blue" style="font-size: 0.8rem; padding: 4px 10px; text-decoration: none;">
                                <i class="fas fa-edit mr-1"></i> Edit
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .table-system { margin: 0; }
    .table-system th {
        background: #f8f9fa;
        color: #0d2c4a;
        font-weight: 600;
        border-top: none;
        padding: 12px 15px;
        font-size: 0.8rem;
        text-transform: uppercase;
    }
    .table-system td {
        padding: 12px 15px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f3f5;
    }
    .badge-system {
        padding: 5px 8px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.7rem;
    }
    .avatar-circle {
        width: 38px;
        height: 38px;
        background: #e9ecef;
        color: #495057;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        border: 1px solid #dee2e6;
    }
    .gap-2 { gap: 0.5rem; }
    .x-small { font-size: 0.7rem; }
</style>
