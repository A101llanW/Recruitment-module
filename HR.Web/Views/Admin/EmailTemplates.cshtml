@model HR.Web.ViewModels.EmailTemplateManagementViewModel
@using System
@using System.Web
@using Newtonsoft.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Email Templates";
}
<style>
    /* Keep footer above editor chrome on this full-page editor screen. */
    .tox-tinymce { z-index: 10 !important; }
    .tox-silver-sink, .tox-tinymce-aux { z-index: 950 !important; }
    .tox .tox-dialog-wrap {
        inset: 0 0 88px 0 !important;
    }
    .tox .tox-dialog {
        max-height: calc(100vh - 120px) !important;
    }
    .email-subject-compose { cursor: text; -webkit-user-modify: read-write; }

    .email-template-compose {
        transition: box-shadow 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
    }
    .email-template-compose.email-template-editing {
        border-color: #4a90d9 !important;
        box-shadow: 0 0 0 3px rgba(74, 144, 217, 0.35);
        background-color: #f8fbff !important;
    }
    .email-template-editing-banner {
        display: none;
        border-left: 4px solid #007bff;
    }
    .email-template-compose.email-template-editing .email-template-editing-banner {
        display: block;
    }
</style>

@functions
{
    /// <summary>Razor-local copies of chip markup (must match HR.Web.Helpers.EmailTemplateTokenChipSerializer for save/load).</summary>
    private string EmailChipShortLabel(string tokenName)
    {
        if (string.IsNullOrEmpty(tokenName))
        {
            return "Field";
        }

        switch (tokenName.Trim())
        {
            case "CandidateName":
                return "Candidate name";
            case "PositionTitle":
                return "Job title";
            case "CompanyName":
                return "Company name";
            case "CustomMessageBlock":
                return "Custom message";
            case "InterviewDateTime":
                return "Interview date & time";
            case "InterviewMode":
                return "Interview mode";
            case "InterviewerName":
                return "Interviewer name";
            case "StageTwoLink":
                return "Questionnaire stage link";
            case "ResetLink":
                return "Reset link";
            case "SecurityCode":
                return "Security code";
            default:
                return tokenName;
        }
    }

    private string EmailChipIconClass(string tokenName)
    {
        if (string.IsNullOrEmpty(tokenName))
        {
            return "fa-tag";
        }

        switch (tokenName.Trim())
        {
            case "CandidateName":
                return "fa-user";
            case "PositionTitle":
                return "fa-briefcase";
            case "CompanyName":
                return "fa-link";
            case "CustomMessageBlock":
                return "fa-comment-alt";
            case "InterviewDateTime":
                return "fa-clock";
            case "InterviewMode":
                return "fa-video";
            case "InterviewerName":
                return "fa-user-tie";
            case "StageTwoLink":
                return "fa-link";
            case "ResetLink":
                return "fa-key";
            case "SecurityCode":
                return "fa-shield-alt";
            default:
                return "fa-tag";
        }
    }

    private string EmailChipHelp(string tokenName)
    {
        if (string.IsNullOrEmpty(tokenName))
        {
            return "Filled in automatically when the email is sent.";
        }

        switch (tokenName.Trim())
        {
            case "CandidateName":
                return "The applicant's name.";
            case "PositionTitle":
                return "The role title.";
            case "CompanyName":
                return "Your company name.";
            case "CustomMessageBlock":
                return "Extra wording from the send screen, if provided.";
            case "InterviewDateTime":
                return "Interview date and time.";
            case "InterviewMode":
                return "How the interview is held.";
            case "InterviewerName":
                return "The interviewer's name.";
            case "StageTwoLink":
                return "Link to the next questionnaire stage.";
            case "ResetLink":
                return "Password reset link (filled in by the system).";
            case "SecurityCode":
                return "One-time code (filled in by the system).";
            default:
                return "Filled in automatically when the email is sent.";
        }
    }

    private bool ShouldShowTemplateTokenShortcut(string templateKey, string tokenName)
    {
        if (string.IsNullOrWhiteSpace(tokenName))
        {
            return false;
        }

        var normalizedTemplateKey = HR.Web.Services.EmailTemplateCatalog.NormalizeTemplateKey(templateKey);
        if (string.Equals(normalizedTemplateKey, HR.Web.Services.EmailTemplateCatalog.SecondaryStageInvitation, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(tokenName.Trim(), "StageTwoLink", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return true;
    }

    /// <summary>
    /// Embed JSON inside an HTML &lt;script&gt; block without the parser treating &lt;/script&gt; in string values as end-of-script.
    /// </summary>
    private static string JsonForInlineScript(string value)
    {
        var json = JsonConvert.SerializeObject(value ?? string.Empty);
        return json.Replace("<", "\\u003c");
    }

    private string EmailChipBuildHtml(string tokenName)
    {
        if (string.IsNullOrWhiteSpace(tokenName))
        {
            return string.Empty;
        }

        var name = tokenName.Trim();
        var label = HttpUtility.HtmlEncode(EmailChipShortLabel(name));
        var icon = HttpUtility.HtmlAttributeEncode(EmailChipIconClass(name));
        var safeName = HttpUtility.HtmlAttributeEncode(name);

        return string.Format(
            "<span class=\"hr-email-token mceNonEditable\" data-hr-token=\"{0}\" contenteditable=\"false\" style=\"display:inline-flex;align-items:center;gap:4px;vertical-align:middle;margin:0 2px;padding:2px 8px;border-radius:6px;background:#e8f0fe;border:1px solid #c6dafc;font-size:13px;color:#1a3a5c;white-space:nowrap;\">" +
            "<i class=\"fas {1}\" aria-hidden=\"true\"></i> {2}</span>",
            safeName,
            icon,
            label);
    }
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
        <div>
            <h2 class="mb-1">Email wording</h2>
            <p class="text-muted mb-0">
                Compose each email in one place. The message area works like a word processor - paragraphs, bold, and lists - not HTML tags. Personalized fields are icon pills, not code.
            </p>
        </div>
        <div class="mt-2 mt-md-0 d-flex flex-wrap align-items-center" style="gap:8px;">
            <a href="@Url.Action("RoleManagement", "Admin")" class="btn btn-outline-secondary">
                <i class="fas fa-user-tag mr-2"></i>Role Templates
            </a>
            @using (Html.BeginForm("SaveEmailTemplates", "Admin", new { tenant = ViewContext.RouteData.Values["tenant"] }, FormMethod.Post, new { @class = "d-inline", id = "resetEmailTemplatesForm", onsubmit = "return confirm('Reset every email template to the built-in defaults? Your current custom wording will be removed (you can edit again afterwards).');" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="resetAllEmailTemplatesToDefaults" value="true" />
                <button type="submit" class="btn btn-outline-danger" id="resetEmailTemplatesBtn" aria-describedby="resetEmailTemplatesHelp">
                    <i class="fas fa-undo-alt mr-2"></i>Reset all to built-in defaults
                </button>
            }
        </div>
    </div>
    <p id="resetEmailTemplatesHelp" class="small text-muted mb-4">
        Use reset to discard every saved customization and reload the system's default subjects and bodies (with the new field icons in the editor). This cannot be undone, but you can edit templates again after resetting.
    </p>

    <div class="alert alert-light border mb-4">
        <p class="mb-2"><strong>How this works</strong></p>
        <ul class="mb-0 pl-3">
            <li>Use the <strong>round icon buttons</strong> to drop a field into the subject line or the message (hover for a short explanation).</li>
            <li>Fields look like <strong>pills</strong> in the editor - do not delete the pill if you still want that information in the sent email.</li>
            <li><strong>CC</strong> is chosen when someone sends the email, not in this screen.</li>
            <li>Use <strong>Edit</strong> to focus the message editor; <strong>Save</strong> stores all templates on this page.</li>
            <li>While you work, the template shows a blue <strong>Edit mode</strong> banner and border so you always know which one is active.</li>
        </ul>
    </div>

    @using (Html.BeginForm("SaveEmailTemplates", "Admin", new { tenant = ViewContext.RouteData.Values["tenant"] }, FormMethod.Post, new { id = "emailTemplatesForm" }))
    {
        @Html.AntiForgeryToken()

        for (var i = 0; i < Model.Templates.Count; i++)
        {
            var defaultSubjectId = "defaultSubjectTemplate_" + i;
            var defaultBodyId = "defaultBodyTemplate_" + i;
            var bodyPreviewFrameId = "defaultBodyTemplatePreview_" + i;
            var subjectComposeId = "subjectCompose_" + i;

            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <div class="d-flex justify-content-between align-items-start flex-wrap">
                        <div>
                            <h5 class="mb-1">@Model.Templates[i].DisplayName</h5>
                            <div class="small text-muted">@Model.Templates[i].Category</div>
                            <div class="small text-muted mt-1">@Model.Templates[i].Description</div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @Html.HiddenFor(m => m.Templates[i].TemplateKey)
                    @Html.HiddenFor(m => m.Templates[i].DisplayName)
                    @Html.HiddenFor(m => m.Templates[i].Description)
                    @Html.HiddenFor(m => m.Templates[i].Category)

                    <div class="email-template-compose border rounded p-3 bg-white"
                         data-subject-compose-id="@subjectComposeId"
                         data-subject-storage-id="@defaultSubjectId"
                         data-body-id="@defaultBodyId">

                        <div class="email-template-editing-banner alert alert-primary mb-3 py-2 px-3" role="status" aria-live="polite">
                            <strong><i class="fas fa-pen mr-2" aria-hidden="true"></i>Edit mode</strong>
                            <span class="d-block small mb-0 mt-1 font-weight-normal">You are editing this template. The highlighted box shows which email you are working on. Click elsewhere on the page to leave edit mode.</span>
                        </div>

                        <h6 class="text-uppercase text-muted small font-weight-bold mb-3">Compose this email</h6>

                        <div class="form-group mb-2">
                            <label class="font-weight-bold d-block mb-1" for="@subjectComposeId">Subject line</label>
                            @Html.TextAreaFor(
                                m => m.Templates[i].DefaultSubjectTemplate,
                                new { id = defaultSubjectId, @class = "email-subject-storage", rows = 3, style = "position:absolute;left:-9999px;width:1px;height:1px;opacity:0;overflow:hidden;", autocomplete = "off" })
                            <div id="@subjectComposeId"
                                 class="email-subject-compose form-control"
                                 contenteditable="true"
                                 role="textbox"
                                 aria-multiline="true"
                                 data-subject-storage-id="@defaultSubjectId"
                                 style="min-height:3.25rem;white-space:pre-wrap;"></div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Templates[i].TokenHint))
                        {
                            <div class="mb-3">
                                <span class="d-block small font-weight-bold text-muted mb-2">Insert into subject</span>
                                <div class="d-flex flex-wrap align-items-center" style="gap:6px;">
                                    @foreach (var segment in Model.Templates[i].TokenHint.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        var tokenName = segment.Trim();
                                        if (tokenName.Length == 0)
                                        {
                                            continue;
                                        }
                                        if (!ShouldShowTemplateTokenShortcut(Model.Templates[i].TemplateKey, tokenName))
                                        {
                                            continue;
                                        }

                                        var iconClass = EmailChipIconClass(tokenName);
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary email-template-token-subj rounded-circle p-0 d-inline-flex align-items-center justify-content-center"
                                                style="width:2.35rem;height:2.35rem;"
                                                title="@EmailChipHelp(tokenName)"
                                                aria-label="Insert @EmailChipShortLabel(tokenName) into subject">
                                            <i class="fas @iconClass" aria-hidden="true"></i>
                                        </button>
                                        <template class="hr-email-chip-source" data-token-name="@tokenName">@Html.Raw(EmailChipBuildHtml(tokenName))</template>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <span class="d-block small font-weight-bold text-muted mb-2">Insert into message</span>
                                <div class="d-flex flex-wrap align-items-center" style="gap:6px;">
                                    @foreach (var segment in Model.Templates[i].TokenHint.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        var tokenName = segment.Trim();
                                        if (tokenName.Length == 0)
                                        {
                                            continue;
                                        }
                                        if (!ShouldShowTemplateTokenShortcut(Model.Templates[i].TemplateKey, tokenName))
                                        {
                                            continue;
                                        }

                                        var iconClass = EmailChipIconClass(tokenName);
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary email-template-token-body rounded-circle p-0 d-inline-flex align-items-center justify-content-center"
                                                style="width:2.35rem;height:2.35rem;"
                                                title="@EmailChipHelp(tokenName)"
                                                aria-label="Insert @EmailChipShortLabel(tokenName) into message">
                                            <i class="fas @iconClass" aria-hidden="true"></i>
                                        </button>
                                        <template class="hr-email-chip-source" data-token-name="@tokenName">@Html.Raw(EmailChipBuildHtml(tokenName))</template>
                                    }
                                </div>
                            </div>
                        }

                        <p class="small text-muted border-top pt-3 mb-3">
                            <strong>CC (copy):</strong> Recipients are selected when this email is sent (for example HR). You cannot set fixed CC addresses in this template.
                        </p>

                        <div class="form-group mb-0">
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                                <div class="flex-grow-1">
                                    <label class="font-weight-bold d-block mb-1" for="@defaultBodyId">Message</label>
                                    <small class="text-muted d-block">What you see here is what recipients get - use Enter for paragraphs; field pills match the sent email.</small>
                                </div>
                                <div class="d-flex flex-shrink-0 align-items-center" style="gap:8px;">
                                    <button type="button"
                                            class="btn btn-outline-primary btn-sm email-template-edit-btn"
                                            data-body-id="@defaultBodyId"
                                            title="Move focus to this message editor">
                                        <i class="fas fa-edit mr-1" aria-hidden="true"></i>Edit
                                    </button>
                                    <button type="submit"
                                            class="btn btn-success btn-sm"
                                            form="emailTemplatesForm"
                                            title="Save all email templates on this page">
                                        <i class="fas fa-save mr-1" aria-hidden="true"></i>Save
                                    </button>
                                </div>
                            </div>
                            <textarea name="@Html.NameFor(m => m.Templates[i].DefaultBodyTemplate)"
                                      id="@defaultBodyId"
                                      class="email-template-body-html"
                                      autocomplete="off"
                                      style="width:100%;min-height:280px;resize:vertical;"
                                      maxlength="200000"></textarea>
                            <script type="application/json" id="emailBodyInitialJson_@i">@Html.Raw(JsonForInlineScript(Model.Templates[i].DefaultBodyTemplate))</script>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-end mb-5">
            <button type="submit" class="btn btn-success btn-lg">
                <i class="fas fa-save mr-2"></i>Save all template changes
            </button>
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/tinymce@6.8.3/tinymce.min.js" referrerpolicy="origin"></script>
<script>
    (function () {
        function markEmailComposeEditing(compose) {
            if (!compose) {
                return;
            }
            document.querySelectorAll('.email-template-compose').forEach(function (c) {
                c.classList.toggle('email-template-editing', c === compose);
            });
        }

        function clearEmailComposeEditing() {
            document.querySelectorAll('.email-template-compose.email-template-editing').forEach(function (c) {
                c.classList.remove('email-template-editing');
            });
        }

        var subjectSelectionRanges = {};
        var bodySelectionBookmarks = {};

        function saveSubjectSelection(div) {
            if (!div || !div.id) {
                return;
            }
            var sel = window.getSelection ? window.getSelection() : null;
            if (!sel || sel.rangeCount === 0) {
                return;
            }
            var range = sel.getRangeAt(0);
            if (!range) {
                return;
            }
            var container = range.commonAncestorContainer;
            if (container && container.nodeType === 3) {
                container = container.parentNode;
            }
            if (!container || !div.contains(container)) {
                return;
            }
            subjectSelectionRanges[div.id] = range.cloneRange();
        }

        function restoreSubjectSelection(div) {
            if (!div || !div.id) {
                return false;
            }
            var range = subjectSelectionRanges[div.id];
            var sel = window.getSelection ? window.getSelection() : null;
            if (!range || !sel) {
                return false;
            }
            try {
                sel.removeAllRanges();
                sel.addRange(range);
                return true;
            } catch (err) {
                return false;
            }
        }

        function saveBodySelection(editor) {
            if (!editor || !editor.id || !editor.selection) {
                return;
            }
            try {
                bodySelectionBookmarks[editor.id] = editor.selection.getBookmark(2, true);
            } catch (err) { /* ignore */ }
        }

        document.addEventListener('focusin', function (ev) {
            var t = ev.target;
            if (!t || !t.closest) {
                return;
            }
            var compose = t.closest('.email-template-compose');
            if (compose) {
                markEmailComposeEditing(compose);
            }
        }, true);

        document.addEventListener('mousedown', function (ev) {
            var t = ev.target;
            if (!t || !t.closest) {
                return;
            }
            if (t.closest('.email-template-compose') ||
                t.closest('.tox-tinymce-aux') ||
                t.closest('.tox-dialog-wrap') ||
                t.closest('.tox-collection')) {
                return;
            }
            clearEmailComposeEditing();
        }, true);

        function getChipHtmlFromButton(btn) {
            if (!btn) {
                return '';
            }
            var tpl = btn.nextElementSibling;
            if (!tpl || !tpl.tagName || tpl.tagName.toUpperCase() !== 'TEMPLATE') {
                return '';
            }
            if (!tpl.content || !tpl.content.firstElementChild) {
                return '';
            }
            return tpl.content.firstElementChild.outerHTML;
        }

        function getTinyMceEditorForTextareaId(textareaId) {
            if (typeof tinymce === 'undefined' || !textareaId) {
                return null;
            }
            var ed = tinymce.get(textareaId);
            if (ed) {
                return ed;
            }
            var list = tinymce.editors;
            if (!list || !list.length) {
                return null;
            }
            for (var i = 0; i < list.length; i++) {
                var cand = list[i];
                if (cand && cand.id === textareaId) {
                    return cand;
                }
            }
            for (var j = 0; j < list.length; j++) {
                var c2 = list[j];
                try {
                    var el = c2.getElement && c2.getElement();
                    if (el && el.id === textareaId) {
                        return c2;
                    }
                } catch (ex) { /* ignore */ }
            }
            return null;
        }

        function insertChipIntoSubject(compose, btn) {
            var html = getChipHtmlFromButton(btn);
            if (!html) {
                return;
            }
            var id = compose.getAttribute('data-subject-compose-id');
            var div = document.getElementById(id);
            var ta = document.getElementById(compose.getAttribute('data-subject-storage-id'));
            if (!div) {
                return;
            }
            div.focus();
            restoreSubjectSelection(div);
            try {
                document.execCommand('insertHTML', false, html);
            } catch (e) {
                var sel = window.getSelection ? window.getSelection() : null;
                if (sel && sel.rangeCount > 0) {
                    var range = sel.getRangeAt(0);
                    var temp = document.createElement('div');
                    temp.innerHTML = html;
                    var frag = document.createDocumentFragment();
                    var child;
                    while ((child = temp.firstChild)) {
                        frag.appendChild(child);
                    }
                    range.deleteContents();
                    range.insertNode(frag);
                    range.collapse(false);
                    sel.removeAllRanges();
                    sel.addRange(range);
                } else {
                    div.innerHTML += html;
                }
            }
            if (ta) {
                ta.value = div.innerHTML;
            }
            saveSubjectSelection(div);
        }

        function insertChipIntoBody(compose, chipHtml, textareaId) {
            if (!chipHtml || !textareaId || !compose) {
                return;
            }
            function runInsert(ed) {
                if (!ed || !ed.getBody) {
                    return;
                }
                ed.focus();
                var bookmark = bodySelectionBookmarks[ed.id];
                if (bookmark && ed.selection) {
                    try {
                        ed.selection.moveToBookmark(bookmark);
                    } catch (bmErr) { /* ignore */ }
                }
                var body = ed.getBody();
                if (!body) {
                    return;
                }
                if (!body.hasChildNodes()) {
                    ed.setContent('<p>' + chipHtml + '</p>', { format: 'html' });
                    ed.save();
                    return;
                }
                try {
                    ed.insertContent(chipHtml, { format: 'html' });
                } catch (insEx) {
                    try {
                        ed.execCommand('mceInsertContent', false, chipHtml);
                    } catch (cmdEx) {
                        ed.selection.setContent(chipHtml, { format: 'html' });
                    }
                }
                ed.save();
                saveBodySelection(ed);
            }
            var editor = getTinyMceEditorForTextareaId(textareaId);
            if (editor) {
                runInsert(editor);
                return;
            }
            var attempts = 0;
            var timer = setInterval(function () {
                attempts++;
                var e2 = getTinyMceEditorForTextareaId(textareaId);
                if (e2) {
                    clearInterval(timer);
                    runInsert(e2);
                } else if (attempts > 50) {
                    clearInterval(timer);
                }
            }, 50);
        }

        document.addEventListener('click', function (ev) {
            var subBtn = ev.target.closest('.email-template-token-subj');
            if (subBtn) {
                ev.preventDefault();
                var compose = subBtn.closest('.email-template-compose');
                if (!compose) {
                    return;
                }
                if (getChipHtmlFromButton(subBtn)) {
                    insertChipIntoSubject(compose, subBtn);
                }
                return;
            }
            var bodyBtn = ev.target.closest('.email-template-token-body');
            if (bodyBtn) {
                ev.preventDefault();
                var composeB = bodyBtn.closest('.email-template-compose');
                if (!composeB) {
                    return;
                }
                var html = getChipHtmlFromButton(bodyBtn);
                var bid = composeB.getAttribute('data-body-id');
                if (html && bid) {
                    insertChipIntoBody(composeB, html, bid);
                }
            }
        });

        document.addEventListener('mousedown', function (ev) {
            var tokenBtn = ev.target.closest('.email-template-token-subj, .email-template-token-body');
            if (tokenBtn) {
                ev.preventDefault();
            }
        });

        function syncSubjectStorages() {
            document.querySelectorAll('.email-subject-compose').forEach(function (div) {
                var sid = div.getAttribute('data-subject-storage-id');
                var ta = document.getElementById(sid);
                if (ta) {
                    ta.value = div.innerHTML;
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            /* Layout may disable POST textareas for module read-only before this runs; editors need enabled targets. */
            document.querySelectorAll('#emailTemplatesForm textarea.email-template-body-html, #emailTemplatesForm textarea.email-subject-storage').forEach(function (ta) {
                ta.removeAttribute('disabled');
                ta.readOnly = false;
                ta.classList.remove('readonly-module-disabled');
                ta.style.pointerEvents = '';
                ta.style.opacity = '';
            });

            document.querySelectorAll('.email-subject-compose').forEach(function (div) {
                var sid = div.getAttribute('data-subject-storage-id');
                var ta = document.getElementById(sid);
                if (ta && div) {
                    div.innerHTML = ta.value;
                }
                div.addEventListener('input', function () {
                    if (ta) {
                        ta.value = div.innerHTML;
                    }
                    saveSubjectSelection(div);
                });
                div.addEventListener('keyup', function () { saveSubjectSelection(div); });
                div.addEventListener('mouseup', function () { saveSubjectSelection(div); });
                div.addEventListener('focus', function () { saveSubjectSelection(div); });
                div.addEventListener('blur', function () { saveSubjectSelection(div); });
            });

            document.querySelectorAll('.email-template-edit-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var composeEl = btn.closest('.email-template-compose');
                    if (composeEl) {
                        markEmailComposeEditing(composeEl);
                    }
                    var bid = btn.getAttribute('data-body-id');
                    var ed = bid ? getTinyMceEditorForTextareaId(bid) : null;
                    if (ed) {
                        ed.focus();
                        var host = ed.getContainer();
                        if (host && host.scrollIntoView) {
                            host.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        }
                    }
                });
            });

            var form = document.getElementById('emailTemplatesForm');
            if (form) {
                form.addEventListener('submit', function () {
                    syncSubjectStorages();
                    if (typeof tinymce !== 'undefined') {
                        tinymce.triggerSave();
                    }
                });
            }

            var index = 0;
            while (true) {
                var bodyId = 'defaultBodyTemplate_' + index;
                var bodyTa = document.getElementById(bodyId);
                var compose = bodyTa ? bodyTa.closest('.email-template-compose') : null;
                if (!bodyTa || !compose) {
                    break;
                }

                (function (idx, bid) {
                    tinymce.init({
                        selector: '#' + bid,
                        height: 340,
                        menubar: false,
                        branding: false,
                        plugins: 'link lists autoresize noneditable',
                        noneditable_class: 'mceNonEditable',
                        toolbar: 'undo redo | styles | bold italic underline | alignleft aligncenter alignright | bullist numlist | link removeformat',
                        content_style: 'body { font-family: Segoe UI, Arial, sans-serif; font-size: 15px; line-height: 1.6; }',
                        entity_encoding: 'raw',
                        valid_elements: '*[*]',
                        verify_html: false,
                        convert_urls: false,
                        setup: function (editor) {
                            editor.on('focus', function () {
                                markEmailComposeEditing(compose);
                                saveBodySelection(editor);
                            });
                            editor.on('NodeChange keyup mouseup', function () {
                                saveBodySelection(editor);
                            });
                            editor.on('change keyup SetContent Undo Redo', function () {
                                editor.save();
                            });
                        },
                        init_instance_callback: function (editor) {
                            var jsonEl = document.getElementById('emailBodyInitialJson_' + idx);
                            var html = '';
                            try {
                                if (jsonEl && jsonEl.textContent && jsonEl.textContent.trim()) {
                                    html = JSON.parse(jsonEl.textContent);
                                }
                            } catch (parseErr) {
                                if (typeof console !== 'undefined' && console.warn) {
                                    console.warn('email template body JSON parse failed', parseErr);
                                }
                                html = '';
                            }
                            if (typeof html !== 'string') {
                                html = '';
                            }
                            if (!html || !html.length) {
                                var ta = document.getElementById(bid);
                                if (ta && ta.value && ta.value.length) {
                                    html = ta.value;
                                }
                            }
                            editor.setContent(html && html.length ? html : '<p></p>', { format: 'html' });
                            editor.save();
                        }
                    });
                })(index, bodyId);

                index++;
            }
        });
    })();
</script>
