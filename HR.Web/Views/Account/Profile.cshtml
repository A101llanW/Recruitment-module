@model HR.Web.ViewModels.ProfileViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "My Profile";
}

<div class="container py-5" style="max-width: 900px;">
    @try {
        <div class="profile-card bg-white rounded-lg shadow-xl overflow-hidden animate-fadeIn" style="border: 1px solid #eef2f6;">
            <!-- Header Section -->
            <div class="profile-header bg-primary p-5 text-white position-relative overflow-hidden">
                <div class="position-absolute" style="top:-20px; right:-20px; opacity: 0.1; transform: rotate(15deg);">
                    <i class="fas fa-user-circle fa-10x"></i>
                </div>
                <div class="row align-items-center">
                    <div class="col-auto">
                        <div class="avatar-circle shadow-lg d-flex align-items-center justify-content-center bg-white text-primary font-weight-bold" 
                             style="width: 100px; height: 100px; border-radius: 50%; font-size: 2.5rem; border: 4px solid rgba(255,255,255,0.3);">
                            @(!string.IsNullOrEmpty(Model.FirstName) ? Model.FirstName.Substring(0, 1).ToUpper() : (!string.IsNullOrEmpty(Model.UserName) ? Model.UserName.Substring(0, 1).ToUpper() : "U"))
                        </div>
                    </div>
                    <div class="col pl-4">
                        <h1 class="h2 mb-1 font-weight-bold">@(Model.FirstName ?? "") @(Model.LastName ?? "")</h1>
                        <p class="text-white-50 mb-0 d-flex align-items-center">
                            <i class="fas fa-shield-alt mr-2"></i> @(Model.Role ?? "User") &bull; 
                            <i class="fas fa-building ml-2 mr-2"></i> @(Model.CompanyName ?? "System Global")
                        </p>
                    </div>
                    <div class="col-auto text-right">
                        @if (Model.IsEmailVerified)
                        {
                            <div class="badge badge-pill badge-success px-4 py-2 shadow-sm" style="font-size: 0.9rem;">
                                <i class="fas fa-check-circle mr-1"></i> Verified Account
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-warning btn-pill px-4 shadow-lg pulse-animation" onclick="sendVerificationOtp()">
                                <i class="fas fa-exclamation-triangle mr-1"></i> Verify Email Now
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="p-5">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert" style="border-left: 5px solid #28a745; border-radius: 12px;">
                        <i class="fas fa-check-circle mr-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                    </div>
                }

                @using (Html.BeginForm("Profile", "Account", FormMethod.Post, new { id = "profileForm" }))
                {
                    @Html.AntiForgeryToken()
                    
                    <div class="section-title mb-4 pb-2 border-bottom d-flex align-items-center">
                        <i class="fas fa-info-circle text-primary mr-2"></i>
                        <h4 class="h5 mb-0 font-weight-bold">Personal Information</h4>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="small font-weight-bold text-uppercase text-muted mb-2 d-block">First Name</label>
                            @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control profile-input", placeholder = "Enter first name" })
                            @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small" })
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="small font-weight-bold text-uppercase text-muted mb-2 d-block">Last Name</label>
                            @Html.TextBoxFor(m => m.LastName, new { @class = "form-control profile-input", placeholder = "Enter last name" })
                            @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small" })
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="small font-weight-bold text-uppercase text-muted mb-2 d-block">Email Address</label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control profile-input", placeholder = "email@example.com", type = "email" })
                                @if (Model.IsEmailVerified)
                                {
                                    <div class="input-group-append">
                                        <span class="input-group-text bg-white text-success border-left-0"><i class="fas fa-check-circle"></i></span>
                                    </div>
                                }
                            </div>
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="small font-weight-bold text-uppercase text-muted mb-2 d-block">Phone Number</label>
                            @Html.TextBoxFor(m => m.Phone, new { @class = "form-control profile-input", placeholder = "+1-234-567-8900" })
                            @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="section-title mt-4 mb-4 pb-2 border-bottom d-flex align-items-center">
                        <i class="fas fa-lock text-primary mr-2"></i>
                        <h4 class="h5 mb-0 font-weight-bold">Account Security</h4>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="small font-weight-bold text-uppercase text-muted mb-2 d-block">Username</label>
                            <div class="form-control profile-input-readonly bg-light">@Model.UserName</div>
                            <small class="text-muted">Username cannot be changed</small>
                        </div>
                        <div class="col-md-6 mb-4 d-flex align-items-end">
                            <a href="@Url.Action("ChangePassword", "Account")" class="btn btn-outline-primary btn-block rounded-lg py-2 font-weight-bold">
                                <i class="fas fa-key mr-2"></i> Change Password
                            </a>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top">
                        <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-lg font-weight-bold" id="btnSave">
                            <i class="fas fa-save mr-2"></i> Save Profile Changes
                        </button>
                    </div>
                }
            </div>
        </div>
    } catch (Exception ex) {
        <div class="alert alert-danger shadow-lg p-5">
            <h3 class="font-weight-bold"><i class="fas fa-exclamation-circle mr-2"></i> Internal Rendering Error</h3>
            <hr/>
            <p class="lead">We encountered a problem while displaying your profile information.</p>
            <p><strong>Error:</strong> @ex.Message</p>
            <div class="mt-3 p-3 bg-dark text-light rounded" style="font-family: monospace; font-size: 0.8rem; overflow-x: auto;">
                <pre class="text-light">@ex.StackTrace</pre>
            </div>
        </div>
    }
</div>

<!-- Email Verification Modal -->
<div class="modal fade" id="verifyOtpModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-2xl rounded-24">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="close p-4" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center p-5">
                <div class="mb-4 d-inline-flex p-4 rounded-circle bg-primary bg-opacity-10 text-primary">
                    <i class="fas fa-envelope-open-text fa-3x"></i>
                </div>
                <h3 class="h4 font-weight-bold mb-3">Verify Your Email</h3>
                <p class="text-muted mb-4 small">We've sent a 6-digit verification code to <br/><strong id="maskedEmail">your email</strong></p>
                
                <div class="form-group mb-4">
                    <input type="text" id="otpInput" class="form-control text-center font-weight-bold" maxlength="6" 
                           style="letter-spacing: 0.5rem; font-size: 1.5rem; height: 60px; border-radius: 12px; border: 2px solid #e2e8f0;"
                           placeholder="000000">
                </div>
                
                <button type="button" class="btn btn-primary btn-block rounded-pill py-3 font-weight-bold shadow-lg" onclick="verifyOtp()">
                    Submit Code
                </button>
                
                <p class="mt-4 small text-muted">
                    Didn't receive the code? <br/>
                    <a href="javascript:void(0)" onclick="sendVerificationOtp()" class="text-primary font-weight-bold">Resend OTP</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .profile-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .profile-input {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 12px 15px;
        height: auto;
        transition: all 0.2s;
    }
    .profile-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        outline: none;
    }
    .profile-input-readonly {
        border-radius: 10px;
        padding: 12px 15px;
        height: auto;
    }
    .btn-pill { border-radius: 50px; }
    .rounded-24 { border-radius: 24px; }
    
    .pulse-animation { animation: pulse 2s infinite; }
    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(255, 193, 7, 0); }
        100% { box-shadow: 0 0 0 0 rgba(255, 193, 7, 0); }
    }
    
    .animate-fadeIn { animation: fadeIn 0.6s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        toastr.options = { 
            "closeButton": true, 
            "progressBar": true, 
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };

        function sendVerificationOtp() {
            const token = $('input[name="__RequestVerificationToken"]').val();
            $.post('@Url.Action("SendVerificationEmail", "Account")', { __RequestVerificationToken: token }, function(response) {
                if (response.success) {
                    const email = '@Model.Email';
                    const parts = email.split('@@');
                    const masked = (parts[0].length > 2 ? parts[0].substring(0, 2) : parts[0]) + '****@@' + parts[1];
                    $('#maskedEmail').text(masked);
                    toastr.success('Verification code sent!');
                    $('#verifyOtpModal').modal('show');
                } else {
                    toastr.error(response.message);
                }
            }).fail(function() {
                toastr.error('Failed to connect to the server. Please check your connection.');
            });
        }

        function verifyOtp() {
            const token = $('input[name="__RequestVerificationToken"]').val();
            const code = $('#otpInput').val();
            if (code.length !== 6) {
                toastr.warning('Please enter the 6-digit code.');
                return;
            }

            $.post('@Url.Action("VerifyEmail", "Account")', { code: code, __RequestVerificationToken: token }, function(response) {
                if (response.success) {
                    toastr.success(response.message);
                    // Force a reload as requested/expected
                    setTimeout(() => {
                        window.location.href = '@Url.Action("Profile", "Account")';
                    }, 1500);
                } else {
                    toastr.error(response.message);
                }
            }).fail(function() {
                toastr.error('Verification failed due to a server error.');
            });
        }
    </script>
}
