@model HR.Web.Models.ResetPasswordViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Reset Password";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
    var tenantContext = ViewBag.TenantContext as HR.Web.Models.Company;
    var tenantCompanyName = tenantContext != null && !string.IsNullOrWhiteSpace(tenantContext.Name)
        ? tenantContext.Name
        : null;
}

<div class="mfa-setup-wrapper mfa-setup-wrapper-login animate-fadeIn">
    <div class="mfa-card auth-login-card">
        <div class="auth-login-layout">
            <aside class="auth-login-aside">
                <div class="login-icon-wrap">
                    <i class="fas fa-lock"></i>
                </div>
                @if (!string.IsNullOrEmpty(tenantCompanyName))
                {
                    <span class="auth-eyebrow">@tenantCompanyName</span>
                    <h3>Reset password</h3>
                    <p class="auth-login-aside__lead">Choose a new password for your @tenantCompanyName account. Use a strong password you don't use elsewhere.</p>
                }
                else
                {
                    <span class="auth-eyebrow">Account recovery</span>
                    <h3>Reset password</h3>
                    <p class="auth-login-aside__lead">Choose a new password for your account.</p>
                }
                <ul class="auth-login-features">
                    <li><i class="fas fa-check-circle"></i> 8+ characters with mixed case, numbers, and symbols</li>
                    <li><i class="fas fa-check-circle"></i> Avoid common words and sequential patterns</li>
                    <li><i class="fas fa-check-circle"></i> Reset links expire; request a new one if needed</li>
                </ul>
            </aside>

            <div class="auth-login-main">
                <div class="mfa-body auth-login-body">
                    @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
                    {
                        <div class="alert auth-alert alert-success">
                            <i class="fas fa-check-circle mr-2"></i> @ViewBag.SuccessMessage
                            <div class="auth-login-actions mt-3">
                                <a href="@Url.Action("Login", "Account", new { tenant = tenantToken })" class="btn-primary-mfa d-inline-block" style="width: auto; padding-left: 1.5rem; padding-right: 1.5rem;">
                                    <i class="fas fa-sign-in-alt mr-2"></i> Go to login
                                </a>
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                    {
                        <div class="alert auth-alert alert-danger">
                            <i class="fas fa-exclamation-triangle mr-2"></i> @ViewBag.ErrorMessage
                            <div class="auth-login-actions mt-3">
                                <a href="@Url.Action("ForgotPassword", "Account", new { tenant = tenantToken })" class="btn-outline-auth">
                                    <i class="fas fa-redo mr-1"></i> Request new link
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert auth-alert alert-info mb-4">
                            <i class="fas fa-info-circle mr-2"></i> Enter and confirm your new password below.
                        </div>

                        using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert auth-alert alert-danger mb-4" })
                            @Html.HiddenFor(m => m.Token)

                            <div class="login-field-group">
                                <label for="newPassword">New password</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-lock"></i></span>
                                    @Html.PasswordFor(m => m.NewPassword, new { @class = "login-input", id = "newPassword", placeholder = "Enter new password" })
                                    <button class="login-toggle-pwd" type="button" id="toggleNewPassword" tabindex="-1" title="Show/hide password">
                                        <i class="fas fa-eye" id="toggleNewIcon"></i>
                                    </button>
                                </div>
                                @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small mt-1 d-block" })
                            </div>

                            <div class="login-field-group">
                                <label for="confirmPassword">Confirm password</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-lock"></i></span>
                                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "login-input", id = "confirmPassword", placeholder = "Confirm new password" })
                                    <button class="login-toggle-pwd" type="button" id="toggleConfirmPassword" tabindex="-1" title="Show/hide password">
                                        <i class="fas fa-eye" id="toggleConfirmIcon"></i>
                                    </button>
                                </div>
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small mt-1 d-block" })
                            </div>

                            <div class="alert auth-alert alert-info mb-4 small">
                                <strong>Password requirements:</strong> 8+ characters, upper &amp; lower case, number, special character; avoid common or sequential patterns.
                            </div>

                            <div class="auth-login-actions">
                                <button type="submit" class="btn-primary-mfa">
                                    <i class="fas fa-check mr-2"></i> Reset password
                                </button>
                            </div>
                        }
                    }
                </div>

                @if (string.IsNullOrEmpty(ViewBag.SuccessMessage) && string.IsNullOrEmpty(ViewBag.ErrorMessage))
                {
                    <div class="mfa-footer auth-login-footer">
                        <a href="@Url.Action("Login", "Account", new { tenant = tenantToken })" class="btn-link-mfa">
                            <i class="fas fa-arrow-left mr-1"></i> Back to login
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        function setupToggle(btnId, inputId, iconId) {
            var btn = document.getElementById(btnId);
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);
            if (!btn || !input || !icon) return;
            btn.addEventListener('click', function () {
                var type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                icon.className = type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
            });
        }
        setupToggle('toggleNewPassword', 'newPassword', 'toggleNewIcon');
        setupToggle('toggleConfirmPassword', 'confirmPassword', 'toggleConfirmIcon');
    });
</script>
