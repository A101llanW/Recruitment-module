@model HR.Web.Models.RegisterViewModel
@using HR.Web.Helpers
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Register";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    bool isSuperAdmin = ViewBag.IsSuperAdmin != null && (bool)ViewBag.IsSuperAdmin;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
}

<div class="row justify-content-center mfa-setup-wrapper mfa-setup-wrapper-wide animate-fadeIn">
    <div class="col-md-12">
        <div class="mfa-card">
            <div class="mfa-header">
                <div class="login-icon-wrap">
                    <i class="fas fa-user-plus"></i>
                </div>
                <span class="auth-eyebrow">Join the portal</span>
                <h3>Create an account</h3>
                <p>Register to apply for positions and track your applications.</p>
            </div>

            <div class="mfa-body">
                @{
                    if (!string.IsNullOrEmpty(ViewBag.ApplicationMessage))
                    {
                        <div class="alert auth-alert alert-warning mb-4">
                            <i class="fas fa-info-circle mr-2"></i> <strong>Application Required:</strong> @ViewBag.ApplicationMessage
                        </div>
                    }
                }
                
                <div class="alert auth-alert alert-info mb-4">
                    <i class="fas fa-shield-alt mr-2"></i> <strong>Enhanced Password Security:</strong> Must be 8+ characters, with uppercase, lowercase, numbers, and special characters (!@@#$%^&*).
                </div>

                @using (Html.BeginForm("Register", "Account", new { tenant = tenantToken }, FormMethod.Post, new { autocomplete = "off", id = "registerForm" })) {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger small font-weight-bold mb-3 d-block" })
                    
                    @Html.Hidden("ReturnUrl", ViewBag.ReturnUrl as string)
                    
                    <div class="row">
                        <div class="col-md-6 login-field-group mb-4">
                            <label for="FirstName">First Name</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-user"></i></span>
                                @Html.TextBoxFor(m => m.FirstName, new { @class = "login-input", placeholder = "First name" })
                            </div>
                            @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                        </div>
                        <div class="col-md-6 login-field-group mb-4">
                            <label for="LastName">Last Name</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-user-tag"></i></span>
                                @Html.TextBoxFor(m => m.LastName, new { @class = "login-input", placeholder = "Last name" })
                            </div>
                            @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 login-field-group mb-4">
                            <label for="UserName">Username</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-id-badge"></i></span>
                                @Html.TextBoxFor(m => m.UserName, new { @class = "login-input", autocomplete = "off", placeholder = "Unique username" })
                            </div>
                            @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                        </div>
                        <div class="col-md-6 login-field-group mb-4">
                            <label for="Email">Email Address</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-envelope"></i></span>
                                @Html.TextBoxFor(m => m.Email, new { @class = "login-input", placeholder = "your-email@example.com" })
                            </div>
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                        </div>
                    </div>
                    
                    <div class="row">
                        @if (isSuperAdmin)
                        {
                            <div class="col-md-6 login-field-group mb-4">
                                <label for="CompanyId">Company</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-building"></i></span>
                                    @Html.DropDownListFor(m => m.CompanyId, new SelectList(Model.Companies, "Id", "Name", Model.CompanyId), "-- Select Company --", new { @class = "login-input" })
                                </div>
                                @Html.ValidationMessageFor(m => m.CompanyId, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                            </div>
                            <div class="col-md-6 login-field-group mb-4">
                                <label for="Phone">Phone</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-phone"></i></span>
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "login-input", placeholder = "Enter phone number" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                            </div>
                        }
                        else
                        {
                            <div class="col-md-12 login-field-group mb-4">
                                <label for="Phone">Phone</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-phone"></i></span>
                                    @Html.TextBoxFor(m => m.Phone, new { @class = "login-input", placeholder = "Enter phone number" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                            </div>
                        }
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 login-field-group mb-4">
                            <label for="Password">Password</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-lock"></i></span>
                                @Html.PasswordFor(m => m.Password, new { @class = "login-input", id = "passwordInput", placeholder = "Enter secure password", autocomplete = "new-password" })
                                <button type="button" class="login-toggle-pwd" id="togglePassword" tabindex="-1">
                                    <i class="fas fa-eye" id="toggleIcon"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                        </div>
                        
                        <div class="col-md-6 login-field-group mb-4">
                            <label for="ConfirmPassword">Confirm Password</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-lock"></i></span>
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "login-input", id = "confirmPasswordInput", placeholder = "Confirm password" })
                                <button type="button" class="login-toggle-pwd" id="toggleConfirmPassword" tabindex="-1">
                                    <i class="fas fa-eye" id="toggleConfirmIcon"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                        </div>
                    </div>

                    <!-- Password strength indicator moved uniformly below the row -->
                    <div class="mb-4 text-center px-2 auth-strength">
                        <div class="progress">
                            <div id="passwordStrength" class="progress-bar" role="progressbar" style="width: 0%;"></div>
                        </div>
                        <small id="strengthText" class="form-text text-muted font-weight-bold mt-2">Enter a password to check strength</small>
                    </div>

                    <div class="form-group mb-3 auth-legal-links">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.AcceptLegalTerms, new { @class = "form-check-input", id = "acceptLegalTerms", required = "required" })
                            <label class="form-check-label small text-muted" for="acceptLegalTerms">
                                I agree to the
                                <a href="@Url.Action("Terms", "Home", new { tenant = tenantToken })" target="_blank" rel="noopener">Terms &amp; Conditions</a>
                                and
                                <a href="@Url.Action("Privacy", "Home", new { tenant = tenantToken })" target="_blank" rel="noopener">Privacy Policy</a>.
                            </label>
                        </div>
                        @Html.ValidationMessageFor(m => m.AcceptLegalTerms, "", new { @class = "text-danger small font-weight-bold mt-1 d-block" })
                    </div>
                    
                    <div class="mt-4">
                        <button type="submit" class="btn-primary-mfa" id="submitBtn">
                            <i class="fas fa-user-plus mr-2"></i> Create Account
                        </button>
                    </div>
                }
            </div>

            <div class="mfa-footer">
                <span class="text-muted small">Already have an account?</span>
                <a href="@Url.Action("Login", "Account", new { tenant = tenantToken, returnUrl = ViewBag.ReturnUrl as string })" class="btn-link-mfa ml-1">
                    <i class="fas fa-sign-in-alt mr-1"></i> Sign in
                </a>
            </div>
        </div>
    </div>
</div>

<!-- client validation bundle removed to avoid Scripts helper compilation issue in this environment -->

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('passwordInput');
        const toggleIcon = document.getElementById('toggleIcon');
        const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');
        const confirmPasswordInput = document.getElementById('confirmPasswordInput');
        const toggleConfirmIcon = document.getElementById('toggleConfirmIcon');
        const passwordStrength = document.getElementById('passwordStrength');
        const strengthText = document.getElementById('strengthText');
        const submitBtn = document.getElementById('submitBtn');
        const registerForm = document.getElementById('registerForm');
        const acceptLegalTerms = document.getElementById('acceptLegalTerms');

        // Toggle password visibility
        function setupToggle(toggleBtn, inputField, icon) {
            toggleBtn.addEventListener('click', function() {
                const type = inputField.getAttribute('type') === 'password' ? 'text' : 'password';
                inputField.setAttribute('type', type);
                
                if (type === 'text') {
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                } else {
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }
            });
        }

        setupToggle(togglePassword, passwordInput, toggleIcon);
        setupToggle(toggleConfirmPassword, confirmPasswordInput, toggleConfirmIcon);

        // Password strength checker
        function checkPasswordStrength(password) {
            let strength = 0;
            let feedback = [];

            // Length check
            if (password.length >= 8) strength += 20;
            else feedback.push('At least 8 characters');

            // Uppercase check
            var uppercaseRegex = new RegExp('[A-Z]');
            if (uppercaseRegex.test(password)) strength += 20;
            else feedback.push('Uppercase letter');

            // Lowercase check
            var lowercaseRegex = new RegExp('[a-z]');
            if (lowercaseRegex.test(password)) strength += 20;
            else feedback.push('Lowercase letter');

            // Number check
            var numberRegex = new RegExp('\\d');
            if (numberRegex.test(password)) strength += 20;
            else feedback.push('Number');

            // Special character check
            var specialChars = String.fromCharCode(33) + String.fromCharCode(64) + String.fromCharCode(35) + String.fromCharCode(36) + String.fromCharCode(37) + String.fromCharCode(94) + String.fromCharCode(38) + String.fromCharCode(42) + '()_+-=[]{}|;:,.<>?';
            var specialCharRegex = new RegExp('[' + specialChars + ']');
            if (specialCharRegex.test(password)) strength += 20;
            else feedback.push('Special character');

            // Common patterns check (deduct points if found)
            const commonPatterns = ['password', '123456', 'qwerty', 'admin', 'letmein'];
            if (commonPatterns.some(pattern => password.toLowerCase().includes(pattern))) {
                strength = Math.max(0, strength - 30);
                feedback.push('Avoid common patterns');
            }

            // Sequential characters check (deduct points if found)
            if (hasSequentialChars(password)) {
                strength = Math.max(0, strength - 20);
                feedback.push('Avoid sequential characters');
            }

            return { strength, feedback };
        }

        function hasSequentialChars(password) {
            const lower = password.toLowerCase();
            for (let i = 0; i < lower.length - 2; i++) {
                if (lower.charCodeAt(i) + 1 === lower.charCodeAt(i + 1) && 
                    lower.charCodeAt(i + 1) + 1 === lower.charCodeAt(i + 2)) {
                    return true;
                }
            }
            return false;
        }

        // Update password strength indicator
        passwordInput.addEventListener('input', function() {
            const password = this.value;
            const { strength, feedback } = checkPasswordStrength(password);

            // Update progress bar
            passwordStrength.style.width = strength + '%';
            
            // Update color based on strength
            passwordStrength.className = 'progress-bar';
            if (strength < 40) {
                passwordStrength.classList.add('bg-danger');
                strengthText.textContent = 'Weak password: ' + feedback.join(', ');
                strengthText.className = 'form-text text-danger';
            } else if (strength < 70) {
                passwordStrength.classList.add('bg-warning');
                strengthText.textContent = 'Medium strength: ' + feedback.join(', ');
                strengthText.className = 'form-text text-warning';
            } else {
                passwordStrength.classList.add('bg-success');
                strengthText.textContent = 'Strong password!';
                strengthText.className = 'form-text text-success';
            }

            // Check if passwords match
            checkPasswordMatch();
        });

        // Check if passwords match
        function checkPasswordMatch() {
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            
            if (confirmPassword && password !== confirmPassword) {
                confirmPasswordInput.classList.add('is-invalid');
            } else if (confirmPassword && password === confirmPassword) {
                confirmPasswordInput.classList.remove('is-invalid');
                confirmPasswordInput.classList.add('is-valid');
            } else {
                confirmPasswordInput.classList.remove('is-invalid', 'is-valid');
            }
        }

        confirmPasswordInput.addEventListener('input', checkPasswordMatch);

        function setSubmitBusy(btn, iconClass, label) {
            while (btn.firstChild) {
                btn.removeChild(btn.firstChild);
            }
            btn.disabled = true;
            var icon = document.createElement('i');
            icon.className = iconClass;
            btn.appendChild(icon);
            btn.appendChild(document.createTextNode(label));
        }

        if (registerForm) {
            registerForm.addEventListener('submit', function(event) {
                if (acceptLegalTerms && !acceptLegalTerms.checked) {
                    event.preventDefault();
                    alert('Please agree to the Terms & Conditions and Privacy Policy (candidate) to continue.');
                    return;
                }

                setSubmitBusy(submitBtn, 'fas fa-circle-notch fa-spin mr-2', ' Creating Account...');
            });
        }
    });
</script>

