@{
    Layout = null;
    ViewBag.Title = "License Expired";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Recruitment Module</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/css/font-awesome.min.css")" />
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
        }

        .expired-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 50px 40px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
            max-width: 600px;
            width: 90%;
            border: 1px solid rgba(255, 255, 255, 0.15);
            animation: fadeIn 0.8s ease-out;
        }

        .icon-wrapper {
            font-size: 70px;
            color: #ff6b6b;
            margin-bottom: 25px;
            text-shadow: 0 0 20px rgba(255, 107, 107, 0.5);
            animation: pulseIcon 2s infinite ease-in-out;
            display: inline-block;
        }

        .expired-title {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 15px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .expired-text {
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 35px;
            color: rgba(255, 255, 255, 0.9);
        }

        .contact-support {
            background-color: rgba(0, 0, 0, 0.25);
            padding: 18px;
            border-radius: 12px;
            margin-bottom: 35px;
            font-size: 0.95rem;
            border-left: 4px solid #f39c12;
            text-align: left;
        }

        .contact-support i {
            color: #f39c12;
        }

        .btn-logout {
            background: #ff6b6b;
            color: #fff;
            border: none;
            padding: 14px 35px;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-block;
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.4);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-logout:hover {
            background: #ff5252;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 107, 107, 0.6);
            text-decoration: none;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes pulseIcon {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); text-shadow: 0 0 30px rgba(255, 107, 107, 0.8); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body>
    <div class="expired-container">
        <div class="icon-wrapper">
            <i class="fas fa-lock"></i>
        </div>
        <h1 class="expired-title">License Expired</h1>
        
        <p class="expired-text">
            Access to the Recruitment System has been temporarily suspended because your company's software license has expired.
        </p>

        <div class="contact-support d-flex align-items-center">
            <i class="fas fa-exclamation-circle fa-2x mr-3"></i>
            <div>
                <strong>Action Required:</strong> Please contact your system administrator or our support team to renew your license and restore operations.
            </div>
        </div>
        
        <a href="@Url.Action("Logout", "Account")" class="btn-logout">
            <i class="fas fa-sign-out-alt mr-2"></i> Return to Login
        </a>
    </div>
</body>
</html>
