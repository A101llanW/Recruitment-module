@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Security Setup";
    ViewBag.HideNavbar = true;
}

<div class="row justify-content-center mfa-setup-wrapper animate-fadeIn">
    <div class="col-md-5">
        <div class="mfa-card shadow-lg border-0">
            <div class="mfa-header text-white bg-primary p-4 rounded-top">
                <div class="login-icon-wrap bg-white text-primary mb-3 mx-auto d-flex align-items-center justify-content-center shadow-sm" style="width: 70px; height: 70px; border-radius: 50%;">
                    <i class="fas fa-lock fa-2x"></i>
                </div>
                <h3 class="font-weight-bold">Secure Your Account</h3>
                <p class="mb-0 opacity-75">Verify your email address to enable two-factor authentication.</p>
            </div>

            <div class="mfa-body p-4 bg-white rounded-bottom">
                <div class="alert alert-info border-0 shadow-sm mb-4 text-center" style="border-radius: 12px;">
                    <i class="fas fa-info-circle mr-2"></i>
                    We'll send a 6-digit code to your registered email:<br/>
                    <strong>@ViewBag.Email</strong>
                </div>

                <div class="text-center mb-4">
                    <button type="button" class="btn btn-outline-primary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm btn-send-code" data-method="Email" style="border-width: 2px;">
                        <i class="fas fa-paper-plane mr-2"></i>
                        <span class="btn-text">Send Verification Code</span>
                        <span class="btn-loader d-none"><i class="fas fa-circle-notch fa-spin ml-1"></i></span>
                    </button>
                    <div id="firstSendStatus" class="small mt-2 font-weight-bold d-none"></div>
                </div>

                @using (Html.BeginForm("SetupMFA", "Account", FormMethod.Post, new { id = "mfaForm" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="method" value="Email" />

                    <div class="login-field-group mb-4">
                        <label for="code" class="font-weight-bold text-muted small text-uppercase">Verification Code</label>
                        <div class="login-input-wrap position-relative">
                            <span class="login-input-icon position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #6c757d;">
                                <i class="fas fa-key"></i>
                            </span>
                            <input class="form-control form-control-lg text-center font-weight-bold" 
                                   id="code" name="code" type="text" maxlength="6" 
                                   placeholder="000000" required autocomplete="off" 
                                   style="padding-left: 45px; height: 60px; border-radius: 12px; letter-spacing: 0.5rem; font-size: 1.5rem; border: 2px solid #e9ecef;" />
                        </div>
                        @Html.ValidationSummary(true, "", new { @class = "text-danger small font-weight-bold mt-2 d-block" })
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-lg btn-block shadow-lg font-weight-bold" 
                                style="height: 55px; border-radius: 12px;" id="btnSubmit">
                            <i class="fas fa-check-circle mr-2"></i> Enable Two-Factor
                        </button>
                    </div>
                }

                <div class="mt-4 text-center">
                    <p class="text-muted small mb-2 font-weight-bold">Didn't receive the code?</p>
                    <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm" style="border-width: 2px;" onclick="$('.btn-send-code').click()">
                        <i class="fas fa-redo-alt mr-1"></i> Resend now
                    </button>
                </div>

                <div class="mt-5 pt-3 border-top text-center">
                    <a href="@Url.Action("Logout", "Account")" class="text-muted small" style="text-decoration: none;">
                        <i class="fas fa-arrow-left mr-1"></i> Return to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.btn-send-code').on('click', function () {
                var btn = $(this);
                btn.prop('disabled', true);
                btn.find('.btn-text').text('Sending Code...');
                btn.find('.btn-loader').removeClass('d-none');
                $('#firstSendStatus').removeClass('d-none text-success text-danger').text('').hide();

                $.post('@Url.Action("SendSetupCode", "Account")', { method: 'Email' }, function (res) {
                    btn.find('.btn-loader').addClass('d-none');
                    if (res.success) {
                        btn.removeClass('btn-outline-primary').addClass('btn-success').find('.btn-text').text('Code Sent!');
                        $('#firstSendStatus').addClass('text-success').text('✓ A Verification Code was sent!').fadeIn();
                        $('#code').focus();
                        setTimeout(function () {
                            btn.prop('disabled', false).removeClass('btn-success').addClass('btn-outline-primary').find('.btn-text').text('Resend Code');
                            $('#firstSendStatus').fadeOut();
                        }, 10000);
                    } else {
                        btn.prop('disabled', false).find('.btn-text').text('Send Verification Code');
                        $('#firstSendStatus').addClass('text-danger').text('✕ ' + (res.message || 'Error sending code.')).fadeIn();
                    }
                }).fail(function() {
                    btn.find('.btn-loader').addClass('d-none');
                    btn.prop('disabled', false).find('.btn-text').text('Send Verification Code');
                    $('#firstSendStatus').addClass('text-danger').text('Failed to connect to server.').fadeIn();
                });
            });

            $('#mfaForm').submit(function() {
                var btn = $('#btnSubmit');
                var originalHtml = btn.html();
                btn.html('<i class="fas fa-spinner fa-spin mr-2"></i> Verifying...').prop('disabled', true);
            });

            $('#code').focus();
        });
    </script>
}

@Html.Partial("_AuthStyles")
