@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Security Setup";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
    var tenantContext = ViewBag.TenantContext as HR.Web.Models.Company;
    var tenantCompanyName = tenantContext != null && !string.IsNullOrWhiteSpace(tenantContext.Name)
        ? tenantContext.Name
        : null;
}

<div class="mfa-setup-wrapper mfa-setup-wrapper-login animate-fadeIn">
    <div class="mfa-card auth-login-card">
        <div class="auth-login-layout">
            <aside class="auth-login-aside">
                <div class="login-icon-wrap">
                    <i class="fas fa-lock"></i>
                </div>
                @if (!string.IsNullOrEmpty(tenantCompanyName))
                {
                    <span class="auth-eyebrow">@tenantCompanyName</span>
                    <h3>Security setup</h3>
                    <p class="auth-login-aside__lead">Enable two-factor authentication for your @tenantCompanyName admin account.</p>
                }
                else
                {
                    <span class="auth-eyebrow">Security setup</span>
                    <h3>Secure your account</h3>
                    <p class="auth-login-aside__lead">Verify your email to enable two-factor authentication.</p>
                }
                <ul class="auth-login-features">
                    <li><i class="fas fa-check-circle"></i> We'll email a 6-digit code to your registered address</li>
                    <li><i class="fas fa-check-circle"></i> Required for privileged admin access</li>
                    <li><i class="fas fa-check-circle"></i> Check spam if the message doesn't arrive</li>
                </ul>
            </aside>

            <div class="auth-login-main">
                <div class="mfa-body auth-login-body">
                    <div class="alert auth-alert alert-info mb-4">
                        <i class="fas fa-info-circle mr-2"></i>
                        We'll send a 6-digit code to your registered email:
                        <strong>@ViewBag.Email</strong>
                    </div>

                    <div class="text-center mb-4">
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm btn-send-code" data-method="Email" style="border-width: 2px;">
                            <i class="fas fa-paper-plane mr-2"></i>
                            <span class="btn-text">Send verification code</span>
                            <span class="btn-loader d-none"><i class="fas fa-circle-notch fa-spin ml-1"></i></span>
                        </button>
                        <div id="firstSendStatus" class="small mt-2 font-weight-bold d-none"></div>
                    </div>

                    @using (Html.BeginForm("SetupMFA", "Account", FormMethod.Post, new { id = "mfaForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="method" value="Email" />

                        <div class="login-field-group mb-4">
                            <label for="code">Verification code</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-key"></i></span>
                                <input class="login-input mfa-verify-code-input"
                                       id="code" name="code" type="text" maxlength="6"
                                       placeholder="000000" required autocomplete="off" />
                            </div>
                        </div>
                        @Html.ValidationSummary(true, "", new { @class = "text-danger small font-weight-bold mt-2 d-block" })

                        <div class="auth-login-actions mt-4">
                            <button type="submit" class="btn-primary-mfa" id="btnSubmit">
                                <i class="fas fa-check-circle mr-2"></i> Enable two-factor
                            </button>
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <p class="text-muted small mb-2 font-weight-bold">Didn't receive the code?</p>
                        <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm" style="border-width: 2px;" onclick="$('.btn-send-code').click()">
                            <i class="fas fa-redo-alt mr-1"></i> Resend now
                        </button>
                    </div>
                </div>

                <div class="mfa-footer auth-login-footer">
                    <a href="@Url.Action("Logout", "Account", new { tenant = tenantToken })" class="btn-link-mfa">
                        <i class="fas fa-arrow-left mr-1"></i> Return to login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.btn-send-code').on('click', function () {
                var btn = $(this);
                btn.prop('disabled', true);
                btn.find('.btn-text').text('Sending code...');
                btn.find('.btn-loader').removeClass('d-none');
                $('#firstSendStatus').removeClass('d-none text-success text-danger').text('').hide();

                $.post('@Url.Action("SendSetupCode", "Account", new { tenant = tenantToken })', {
                    method: 'Email',
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }, function (res) {
                    btn.find('.btn-loader').addClass('d-none');
                    if (res.success) {
                        btn.removeClass('btn-outline-primary').addClass('btn-success').find('.btn-text').text('Code sent!');
                        $('#firstSendStatus').addClass('text-success').text('A verification code was sent.').fadeIn();
                        $('#code').focus();
                        setTimeout(function () {
                            btn.prop('disabled', false).removeClass('btn-success').addClass('btn-outline-primary').find('.btn-text').text('Resend code');
                            $('#firstSendStatus').fadeOut();
                        }, 10000);
                    } else {
                        btn.prop('disabled', false).find('.btn-text').text('Send verification code');
                        $('#firstSendStatus').addClass('text-danger').text(res.message || 'Error sending code.').fadeIn();
                    }
                }).fail(function() {
                    btn.find('.btn-loader').addClass('d-none');
                    btn.prop('disabled', false).find('.btn-text').text('Send verification code');
                    $('#firstSendStatus').addClass('text-danger').text('Failed to connect to server.').fadeIn();
                });
            });

            $('#mfaForm').submit(function() {
                $('#btnSubmit').html('<i class="fas fa-spinner fa-spin mr-2"></i> Verifying...').prop('disabled', true);
            });

            $('#code').focus();
        });
    </script>
}
