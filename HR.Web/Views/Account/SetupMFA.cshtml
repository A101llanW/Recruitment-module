@{
    ViewBag.Title = "Security Setup";
}

<div class="row justify-content-center mfa-setup-wrapper">
    <div class="col-md-6">
        <div class="mfa-card">
            <div class="mfa-header">
                <h3>Secure Your Account</h3>
                <p>Verify your email address to enable two-factor authentication.</p>
            </div>

            <div class="mfa-body">
                <div class="email-setup-box mb-4">
                    <div class="setup-icon-wrap">
                        <i class="fas fa-envelope-open-text"></i>
                    </div>
                    <h5 class="mt-3 mb-1" style="font-weight: 700; color: var(--mfa-text-main);">Email Verification</h5>
                    <p class="text-muted" style="font-size: 0.9rem; margin-bottom: 16px;">We'll send a 6-digit code to your registered email:</p>
                    <div class="masked-email">@ViewBag.Email</div>
                    <button type="button" class="btn-action btn-send-code mt-4" data-method="Email">
                        <i class="fas fa-paper-plane mr-2"></i>
                        <span class="btn-text">Send Verification Code</span>
                        <span class="btn-loader d-none"><i class="fas fa-circle-notch fa-spin"></i></span>
                    </button>
                </div>

                <div class="verification-form-area pt-4 border-top">
                    @using (Html.BeginForm("SetupMFA", "Account", FormMethod.Post, new { id = "mfaForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="method" value="Email" />

                        <div class="verification-input-group">
                            <label for="code">Enter the 6-digit code</label>
                            <div class="digit-input-wrapper">
                                <input class="form-control" id="code" name="code" type="text"
                                       placeholder="123456" maxlength="6" required autocomplete="off" />
                            </div>
                            @Html.ValidationSummary(true, "", new { @class = "text-danger-custom mt-2" })
                            <p class="resend-hint mt-3">Didn't receive a code? <a href="javascript:void(0)" onclick="$('.btn-send-code').click()">Resend now</a></p>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn-primary-mfa">Enable Two-Factor Authentication</button>
                        </div>
                    }
                </div>
            </div>

            <div class="mfa-footer">
                <a href="@Url.Action("Login")"><i class="fas fa-long-arrow-left mr-2"></i>Return to Login</a>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(function () {
        $('.btn-send-code').on('click', function () {
            var btn = $(this);
            btn.prop('disabled', true);
            btn.find('.btn-text').text('Sending Code...');
            btn.find('.btn-loader').removeClass('d-none');

            $.post('@Url.Action("SendSetupCode", "Account")', { method: 'Email' }, function (res) {
                btn.find('.btn-loader').addClass('d-none');
                if (res.success) {
                    btn.addClass('btn-success-state').find('.btn-text').text('Code Sent!');
                    $('#code').focus();
                    setTimeout(function () {
                        btn.prop('disabled', false).removeClass('btn-success-state').find('.btn-text').text('Resend Code');
                    }, 10000);
                } else {
                    btn.prop('disabled', false).find('.btn-text').text('Send Verification Code');
                    alert(res.message || 'Error sending code.');
                }
            });
        });

        $('#code').focus();
    });
</script>

<style>
    :root {
        --mfa-primary: #4f46e5;
        --mfa-primary-hover: #4338ca;
        --mfa-bg: #f8fafc;
        --mfa-text-main: #1e293b;
        --mfa-text-muted: #64748b;
        --mfa-border: #e2e8f0;
        --mfa-success: #10b981;
    }

    .mfa-setup-wrapper {
        padding: 20px 0;
        background: var(--mfa-bg);
        min-height: 80vh;
    }

    .mfa-card {
        background: #ffffff;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        border: 1px solid var(--mfa-border);
    }

    .mfa-header {
        padding: 20px 20px 10px;
        text-align: center;
        background: linear-gradient(to bottom, #fdfbfb 0%, #ebedee 100%);
        border-bottom: 1px solid var(--mfa-border);
    }

    .mfa-header h3 {
        font-weight: 700;
        color: var(--mfa-text-main);
        margin-bottom: 5px;
        font-size: 1.5rem;
    }

    .mfa-header p {
        color: var(--mfa-text-muted);
        font-size: 0.9rem;
        margin: 0;
    }

    .mfa-body {
        padding: 24px;
    }

    .email-setup-box {
        background: #f1f5f9;
        padding: 28px 24px;
        border-radius: 12px;
        text-align: center;
    }

    .setup-icon-wrap {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, var(--mfa-primary), #818cf8);
        border-radius: 50%;
        box-shadow: 0 8px 20px rgba(79,70,229,0.25);
    }

    .setup-icon-wrap i {
        font-size: 26px;
        color: white;
    }

    .masked-email {
        font-family: 'Courier New', monospace;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--mfa-primary);
        background: white;
        display: inline-block;
        padding: 8px 20px;
        border-radius: 8px;
        border: 1px dashed var(--mfa-border);
        margin-top: 8px;
    }

    .btn-action {
        background: var(--mfa-text-main);
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
    }

    .btn-action:hover { background: #000; transform: translateY(-1px); }
    .btn-success-state { background: var(--mfa-success) !important; }

    .verification-input-group { text-align: center; }

    .verification-input-group label {
        display: block;
        font-weight: 700;
        color: var(--mfa-text-main);
        margin-bottom: 16px;
        font-size: 1.05rem;
    }

    .digit-input-wrapper {
        display: flex;
        justify-content: center;
    }

    #code {
        width: 200px;
        height: 50px;
        font-size: 24px;
        text-align: center;
        letter-spacing: 8px;
        font-weight: 700;
        border-radius: 8px;
        border: 2px solid var(--mfa-border);
        color: var(--mfa-text-main);
        transition: all 0.2s;
        padding: 0;
    }

    #code:focus {
        border-color: var(--mfa-primary);
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        outline: none;
    }

    .btn-primary-mfa {
        width: 100%;
        height: 56px;
        background: var(--mfa-primary);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.2);
    }

    .btn-primary-mfa:hover {
        background: var(--mfa-primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 20px 25px -5px rgba(79, 70, 229, 0.25);
    }

    .resend-hint {
        font-size: 0.9rem;
        color: var(--mfa-text-muted);
        margin-top: 12px;
    }

    .resend-hint a {
        color: var(--mfa-primary);
        font-weight: 600;
        text-decoration: none;
    }

    .mfa-footer {
        padding: 15px;
        text-align: center;
        border-top: 1px solid var(--mfa-border);
    }

    .mfa-footer a {
        color: var(--mfa-text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .text-danger-custom {
        color: #ef4444;
        font-size: 0.85rem;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .mfa-body { padding: 20px; }
        #code { width: 100%; }
    }
</style>
