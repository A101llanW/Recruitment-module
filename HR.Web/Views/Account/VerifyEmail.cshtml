@model HR.Web.Models.User
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Verify Your Email";
    ViewBag.HideNavbar = true;
    string tenantToken = ViewContext.RouteData.Values["tenant"] as string;
}

<div class="row justify-content-center mfa-setup-wrapper animate-fadeIn">
    <div class="col-md-5">
        <div class="mfa-card shadow-lg border-0">
            <div class="mfa-header text-white bg-primary p-4 rounded-top">
                <div class="login-icon-wrap bg-white text-primary mb-3 mx-auto d-flex align-items-center justify-content-center shadow-sm" style="width: 70px; height: 70px; border-radius: 50%;">
                    <i class="fas fa-envelope-open-text fa-2x"></i>
                </div>
                <h3 class="font-weight-bold">Email Verification</h3>
                <p class="mb-0 opacity-75">Secure your account by verifying your email address.</p>
            </div>

            <div class="mfa-body p-4 bg-white rounded-bottom">

                @if (string.IsNullOrEmpty(Model.Email) || Model.Email.StartsWith("PENDING_"))
                {
                    <div class="alert alert-warning border-0 shadow-sm mb-4" style="border-radius: 12px;">
                        <i class="fas fa-exclamation-circle mr-2"></i>
                        Please provide your official email address to continue.
                    </div>

                    using (Html.BeginForm("UpdateAndSendVerification", "Account", FormMethod.Post, new { id = "updateEmailForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="login-field-group mb-4">
                            <label for="newEmail" class="font-weight-bold text-muted small text-uppercase">Email Address</label>
                            <div class="login-input-wrap position-relative">
                                <span class="login-input-icon position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #6c757d;">
                                    <i class="fas fa-envelope"></i>
                                </span>
                                <input class="form-control form-control-lg" 
                                       id="newEmail" name="newEmail" type="email" 
                                       placeholder="your-email@company.com" required 
                                       style="padding-left: 45px; height: 55px; border-radius: 12px; border: 2px solid #e9ecef;" />
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary btn-lg btn-block shadow-lg font-weight-bold" 
                                    style="height: 55px; border-radius: 12px;" id="btnUpdateEmail">
                                <i class="fas fa-magic mr-2"></i> Set Email & Send Code
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info border-0 shadow-sm mb-4" style="border-radius: 12px;">
                        <i class="fas fa-info-circle mr-2"></i>
                        We've sent a 6-digit verification code to <strong>@Model.Email</strong>. 
                        Please enter it below to complete your login.
                    </div>

                    using (Html.BeginForm("VerifyEmailSubmit", "Account", FormMethod.Post, new { id = "verifyOtpForm" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="login-field-group mb-4">
                            <label for="code" class="font-weight-bold text-muted small text-uppercase">Verification Code</label>
                            <div class="login-input-wrap position-relative">
                                <span class="login-input-icon position-absolute" style="left: 15px; top: 50%; transform: translateY(-50%); color: #6c757d;">
                                    <i class="fas fa-key"></i>
                                </span>
                                <input class="form-control form-control-lg text-center font-weight-bold" 
                                       id="code" name="code" type="text" maxlength="6" 
                                       placeholder="000000" required 
                                       style="padding-left: 45px; height: 60px; border-radius: 12px; letter-spacing: 0.5rem; font-size: 1.5rem; border: 2px solid #e9ecef;" />
                            </div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary btn-lg btn-block shadow-lg font-weight-bold" 
                                    style="height: 55px; border-radius: 12px;" id="btnSubmit">
                                <i class="fas fa-check-circle mr-2"></i> Verify & Continue
                            </button>
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <p class="text-muted small mb-2 font-weight-bold">Didn't receive the code?</p>
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm" style="border-width: 2px;" onclick="resendOtp()">
                            <i class="fas fa-sync-alt mr-1"></i> Resend Verification Code
                        </button>
                        <div id="resendMessage" class="small mt-2 font-weight-bold"></div>
                    </div>
                }

                <div class="mt-5 pt-3 border-top text-center">
                    <a href="@Url.Action("Logout", "Account", new { tenant = tenantToken })" class="text-muted small">
                        <i class="fas fa-arrow-left mr-1"></i> Use a different account
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resendOtp() {
            const btn = event.target.closest('button');
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Sending...';

            const token = $('input[name="__RequestVerificationToken"]').val();
            
            $.post('@Url.Action("SendVerificationEmail", "Account", new { tenant = tenantToken })', { __RequestVerificationToken: token }, function(response) {
                if (response.success) {
                    $('#resendMessage').removeClass('text-danger').addClass('text-success').text(response.message);
                } else {
                    $('#resendMessage').removeClass('text-success').addClass('text-danger').text(response.message);
                }
                
                setTimeout(() => {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                    setTimeout(() => $('#resendMessage').fadeOut(), 3000);
                }, 1000);
            }).fail(function() {
                $('#resendMessage').removeClass('text-success').addClass('text-danger').text('Failed to connect to server.');
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            });
        }

        // Auto-focus input
        $(document).ready(function() {
            $('#code').focus();
            
            $('#verifyOtpForm').submit(function() {
                $('#btnSubmit').html('<i class="fas fa-circle-notch fa-spin mr-2"></i> Verifying...').prop('disabled', true);
            });
        });
    </script>
}

@Html.Partial("_AuthStyles")
