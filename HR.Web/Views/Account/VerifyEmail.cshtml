@model HR.Web.Models.User
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Verify Your Email";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
    var tenantContext = ViewBag.TenantContext as HR.Web.Models.Company;
    var tenantCompanyName = tenantContext != null && !string.IsNullOrWhiteSpace(tenantContext.Name)
        ? tenantContext.Name
        : null;
    var needsEmail = string.IsNullOrEmpty(Model.Email) || Model.Email.StartsWith("PENDING_");
}

<div class="mfa-setup-wrapper mfa-setup-wrapper-login animate-fadeIn">
    <div class="mfa-card auth-login-card">
        <div class="auth-login-layout">
            <aside class="auth-login-aside">
                <div class="login-icon-wrap">
                    <i class="fas fa-envelope-open-text"></i>
                </div>
                @if (!string.IsNullOrEmpty(tenantCompanyName))
                {
                    <span class="auth-eyebrow">@tenantCompanyName</span>
                    <h3>Verify your email</h3>
                    <p class="auth-login-aside__lead">Confirm your email address to finish signing in to @tenantCompanyName.</p>
                }
                else
                {
                    <span class="auth-eyebrow">Account security</span>
                    <h3>Verify your email</h3>
                    <p class="auth-login-aside__lead">Confirm your email address before you can access the portal.</p>
                }
                <ul class="auth-login-features">
                    @if (needsEmail)
                    {
                        <li><i class="fas fa-check-circle"></i> Use your official work email address</li>
                        <li><i class="fas fa-check-circle"></i> We'll send a 6-digit verification code</li>
                    }
                    else
                    {
                        <li><i class="fas fa-check-circle"></i> Enter the 6-digit code from your inbox</li>
                        <li><i class="fas fa-check-circle"></i> Codes expire after 15 minutes</li>
                    }
                    <li><i class="fas fa-check-circle"></i> Check spam if the message doesn't arrive</li>
                </ul>
            </aside>

            <div class="auth-login-main">
                <div class="mfa-body auth-login-body">
                    @if (needsEmail)
                    {
                        <div class="alert auth-alert alert-warning mb-4">
                            <i class="fas fa-exclamation-circle mr-2"></i>
                            Please provide your official email address to continue.
                        </div>

                        using (Html.BeginForm("UpdateAndSendVerification", "Account", FormMethod.Post, new { id = "updateEmailForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <div class="login-field-group">
                                <label for="newEmail">Email address</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-envelope"></i></span>
                                    <input class="login-input" id="newEmail" name="newEmail" type="email"
                                           placeholder="your-email@company.com" required autocomplete="email" />
                                </div>
                            </div>

                            <div class="auth-login-actions mt-4">
                                <button type="submit" class="btn-primary-mfa" id="btnUpdateEmail">
                                    <i class="fas fa-paper-plane mr-2"></i> Set email &amp; send code
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert auth-alert alert-info mb-4">
                            <i class="fas fa-info-circle mr-2"></i>
                            We've sent a 6-digit verification code to <strong>@Model.Email</strong>.
                            Please enter it below to complete your login.
                        </div>

                        using (Html.BeginForm("VerifyEmailSubmit", "Account", FormMethod.Post, new { id = "verifyOtpForm" }))
                        {
                            @Html.AntiForgeryToken()

                            <div class="login-field-group mb-4">
                                <label for="code">Verification code</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-key"></i></span>
                                    <input class="login-input mfa-verify-code-input"
                                           id="code" name="code" type="text" maxlength="6"
                                           placeholder="000000" required autocomplete="off" autofocus />
                                </div>
                            </div>

                            <div class="auth-login-actions mt-4">
                                <button type="submit" class="btn-primary-mfa" id="btnSubmit">
                                    <i class="fas fa-check-circle mr-2"></i> Verify &amp; continue
                                </button>
                            </div>
                        }

                        <div class="mt-4 text-center">
                            <p class="text-muted small mb-2 font-weight-bold">Didn't receive the code?</p>
                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm" style="border-width: 2px;" onclick="resendOtp()">
                                <i class="fas fa-sync-alt mr-1"></i> Resend verification code
                            </button>
                            <div id="resendMessage" class="small mt-2 font-weight-bold"></div>
                        </div>
                    }
                </div>

                <div class="mfa-footer auth-login-footer">
                    <a href="@Url.Action("Logout", "Account", new { tenant = tenantToken })" class="btn-link-mfa">
                        <i class="fas fa-arrow-left mr-1"></i> Use a different account
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function rememberButtonNodes(btn) {
            if (!btn._savedNodes) {
                btn._savedNodes = Array.prototype.slice.call(btn.childNodes).map(function (node) {
                    return node.cloneNode(true);
                });
            }
        }

        function setButtonBusy(btn, iconClass, label) {
            rememberButtonNodes(btn);
            clearElement(btn);
            btn.disabled = true;
            var icon = document.createElement('i');
            icon.className = iconClass;
            btn.appendChild(icon);
            btn.appendChild(document.createTextNode(label));
        }

        function restoreButton(btn) {
            clearElement(btn);
            btn.disabled = false;
            (btn._savedNodes || []).forEach(function (node) {
                btn.appendChild(node.cloneNode(true));
            });
        }

        function clearElement(el) {
            while (el && el.firstChild) {
                el.removeChild(el.firstChild);
            }
        }

        function resendOtp() {
            var btn = event.target.closest('button');

            setButtonBusy(btn, 'fas fa-spinner fa-spin mr-1', ' Sending...');

            var token = $('input[name="__RequestVerificationToken"]').val();

            $.post('@Url.Action("SendVerificationEmail", "Account", new { tenant = tenantToken })', { __RequestVerificationToken: token }, function(response) {
                if (response.success) {
                    $('#resendMessage').removeClass('text-danger').addClass('text-success').text(response.message);
                } else {
                    $('#resendMessage').removeClass('text-success').addClass('text-danger').text(response.message);
                }

                setTimeout(function() {
                    restoreButton(btn);
                    setTimeout(function() { $('#resendMessage').fadeOut(); }, 3000);
                }, 1000);
            }).fail(function() {
                $('#resendMessage').removeClass('text-success').addClass('text-danger').text('Failed to connect to server.');
                restoreButton(btn);
            });
        }

        $(document).ready(function() {
            if ($('#code').length) {
                $('#code').focus();
            } else if ($('#newEmail').length) {
                $('#newEmail').focus();
            }

            $('#verifyOtpForm').submit(function() {
                var btn = $('#btnSubmit')[0];
                if (btn) {
                    setButtonBusy(btn, 'fas fa-circle-notch fa-spin mr-2', ' Verifying...');
                }
            });

            $('#updateEmailForm').submit(function() {
                var btn = $('#btnUpdateEmail')[0];
                if (btn) {
                    setButtonBusy(btn, 'fas fa-circle-notch fa-spin mr-2', ' Sending...');
                }
            });
        });
    </script>
}
