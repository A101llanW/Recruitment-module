@using HR.Web.Helpers
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Login";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
    var showLegalModal = ViewBag.ShowLegalConsentModal as bool? == true;
    var tenantContext = ViewBag.TenantContext as HR.Web.Models.Company;
    var tenantCompanyName = tenantContext != null && !string.IsNullOrWhiteSpace(tenantContext.Name)
        ? tenantContext.Name
        : null;
}

<div class="mfa-setup-wrapper mfa-setup-wrapper-login animate-fadeIn">
    <div class="mfa-card auth-login-card">
        <div class="auth-login-layout">
            <aside class="auth-login-aside">
                <div class="login-icon-wrap">
                    <i class="fas fa-shield-alt"></i>
                </div>
                @if (!string.IsNullOrEmpty(tenantCompanyName))
                {
                    <span class="auth-eyebrow">@tenantCompanyName</span>
                    <h3>HR sign-in</h3>
                    <p class="auth-login-aside__lead">Sign in to apply, complete questionnaires, and follow applications and interviews for @tenantCompanyName.</p>
                }
                else
                {
                    <span class="auth-eyebrow">HR administration</span>
                    <h3>Sign in</h3>
                    <p class="auth-login-aside__lead">Sign in to apply for roles, complete questionnaires, and follow your hiring progress in one place.</p>
                }
                <ul class="auth-login-features">
                    <li><i class="fas fa-check-circle"></i> Structured questionnaires with scoring at each stage</li>
                    <li><i class="fas fa-check-circle"></i> Track applications and your next steps</li>
                    <li><i class="fas fa-check-circle"></i> Interview schedules and updates in one place</li>
                </ul>
            </aside>

            <div class="auth-login-main">
            <div class="mfa-body auth-login-body">

                @if (Request.QueryString["reason"] == "session_invalid")
                {
                    <div class="alert auth-alert alert-warning alert-dismissible fade show mb-4" role="alert">
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        <i class="fas fa-exclamation-triangle mr-2"></i>
                        <strong>Security Update:</strong> Your account credentials have been updated. Please sign in again.
                    </div>
                }

                @if (Request.QueryString["reason"] == "session_hijack")
                {
                    <div class="alert auth-alert alert-danger alert-dismissible fade show mb-4" role="alert">
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        <i class="fas fa-shield-alt mr-2"></i>
                        <strong>Security Alert:</strong> Session terminated from unrecognized device. Change your password if this wasn't you.
                    </div>
                }

                @if (Request.QueryString["reason"] == "idle_timeout")
                {
                    <div class="alert auth-alert alert-info alert-dismissible fade show mb-4" role="alert">
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        <i class="fas fa-clock mr-2"></i>
                        <strong>Session Expired:</strong> Signed out after inactivity. Please log in again.
                    </div>
                }

                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert auth-alert alert-success alert-dismissible fade show mb-4" role="alert">
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        <i class="fas fa-check-circle mr-2"></i> @ViewBag.SuccessMessage
                    </div>
                }

                @if (ViewBag.PreferredCompanyName != null)
                {
                    <div class="company-welcome-card mb-4 text-center">
                        <div class="company-logo-mini mb-3">
                            <i class="fas fa-building"></i>
                        </div>
                        <h5 class="mb-1">Continue to @ViewBag.PreferredCompanyName</h5>
                        <p class="text-muted small mb-3">Resume where you left off.</p>
                        <div class="d-flex flex-column align-items-center mt-3">
                            <a href="@Url.Action("Login", "Account", new { tenant = ViewBag.PreferredCompanySlug, returnUrl = ViewBag.ReturnUrl })" class="btn btn-outline-auth btn-sm mb-3">
                                Go to Portal <i class="fas fa-arrow-right ml-2"></i>
                            </a>
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="this.closest('.company-welcome-card').style.display='none'">
                                Use a different account
                            </button>
                        </div>
                    </div>
                }

                @if (ViewBag.MultiCandidates != null)
                {
                    var multiCandidates = ((IEnumerable<HR.Web.Models.User>)ViewBag.MultiCandidates).ToList();
                    <div class="multi-candidate-picker mb-4">
                        @if (multiCandidates.Count > 1)
                        {
                            <div class="alert alert-info py-2 px-3 small mb-3">
                                <i class="fas fa-info-circle mr-1"></i> We found multiple accounts for this email.
                            </div>
                        }
                        <div class="list-group">
                            @foreach (var candidate in multiCandidates)
                            {
                                var tenantSlug = candidate.Company != null ? candidate.Company.Slug : "";
                                var companyName = candidate.Company != null ? candidate.Company.Name : "Main System";
                                
                                <a href="@Url.Action("Login", "Account", new { tenant = tenantSlug, returnUrl = ViewBag.ReturnUrl })" 
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3" style="border-radius: 8px; margin-bottom: 8px; border: 1px solid #e2e8f0;">
                                    <div>
                                        <div style="font-weight: 600; color: #1e293b;">@companyName</div>
                                        <div class="text-muted" style="font-size: 0.8rem;">Username: @candidate.UserName</div>
                                    </div>
                                    <i class="fas fa-chevron-right text-muted"></i>
                                </a>
                            }
                        </div>
                        <div class="text-center mt-2">
                            <button type="button" class="btn-link-mfa small" onclick="location.reload()">
                                <i class="fas fa-undo mr-1"></i> Back to login
                            </button>
                        </div>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        @TempData["ErrorMessage"]
                    </div>
                }

                @Html.ValidationSummary(true, "", new { @class = "alert auth-alert alert-danger mb-4" })

                @using (Html.BeginForm("Login", "Account", new { tenant = tenantToken }, FormMethod.Post, new { autocomplete = "off", id = "loginForm" })) {
                    @Html.AntiForgeryToken()

                    <div class="row auth-login-fields">
                        <div class="col-md-6 login-field-group">
                            <label for="username">Username or Email</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-user"></i></span>
                                <input class="login-input" id="username" name="username" type="text"
                                       placeholder="Username or email" required autocomplete="off" />
                            </div>
                        </div>

                        <div class="col-md-6 login-field-group">
                            <label for="password">Password</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-lock"></i></span>
                                <input class="login-input" id="password" name="password" type="password"
                                       placeholder="Password" required autocomplete="new-password" />
                                <button class="login-toggle-pwd" type="button" id="togglePwd" tabindex="-1" title="Show/hide password">
                                    <i class="fas fa-eye" id="togglePwdIcon"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="auth-login-captcha">
                        @Html.Partial("_CaptchaPartial")
                    </div>

                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    <div class="auth-login-actions">
                        <button type="submit" class="btn-primary-mfa" id="loginSubmitBtn">
                            <i class="fas fa-sign-in-alt mr-2"></i> Sign In
                        </button>
                        <a href="@Url.Action("ForgotPassword", "Account")" class="btn-link-mfa auth-login-forgot">
                            <i class="fas fa-question-circle mr-1"></i> Forgot Password?
                        </a>
                    </div>
                }
            </div>

            <div class="mfa-footer auth-login-footer">
                <span class="text-muted small">Don't have an account?</span>
                <a href="@Url.Action("Register", "Account", new { tenant = tenantToken, returnUrl = ViewBag.ReturnUrl as string })" class="btn-link-mfa ml-1">Register here</a>
            </div>
            </div>
        </div>
    </div>
</div>

@if (showLegalModal)
{
    var termsLink = ViewBag.LegalTermsUrl as string;
    var privacyLink = ViewBag.LegalPrivacyUrl as string;
    var displayName = ViewBag.LegalConsentDisplayName as string;
    <div class="modal fade legal-consent-modal" id="legalConsentModal" tabindex="-1" role="dialog" aria-labelledby="legalConsentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="legalConsentModalLabel">Updated policies</h5>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">Hello <strong>@(string.IsNullOrWhiteSpace(displayName) ? "there" : displayName)</strong>, one quick step before you continue.</p>
                    <p class="mb-3">Please review the current <strong>Terms &amp; Conditions</strong> and <strong>Privacy Policy</strong>, then accept below to finish signing in.</p>
                    <p class="mb-4">
                        <a href="@privacyLink" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary me-2">View Privacy Policy</a>
                        <a href="@termsLink" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">View Terms &amp; Conditions</a>
                    </p>
                    @using (Html.BeginForm("ConfirmLegalConsent", "Account", new { tenant = tenantToken }, FormMethod.Post, new { id = "legalConsentForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="acceptLegalTerms" id="legalConsentAccept" value="true" required />
                            <label class="form-check-label small" for="legalConsentAccept">
                                I have read and agree to the Terms &amp; Conditions and Privacy Policy.
                            </label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Continue</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Captcha image selector
        var captchaButtons = document.querySelectorAll('.captcha-image-btn');
        var captchaHidden = document.getElementById('captcha');
        captchaButtons.forEach(function(btn) {
            btn.addEventListener('click', function () {
                captchaButtons.forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                captchaHidden.value = btn.dataset.index;
            });
        });

        // Password visibility toggle
        var toggleBtn = document.getElementById('togglePwd');
        var pwdInput  = document.getElementById('password');
        var toggleIcon = document.getElementById('togglePwdIcon');

        if (toggleBtn && pwdInput) {
            toggleBtn.addEventListener('click', function () {
                var type = pwdInput.getAttribute('type') === 'password' ? 'text' : 'password';
                pwdInput.setAttribute('type', type);
                toggleIcon.classList.toggle('fa-eye');
                toggleIcon.classList.toggle('fa-eye-slash');
            });
        }

        function setSubmitBusy(btn, iconClass, label) {
            while (btn.firstChild) {
                btn.removeChild(btn.firstChild);
            }
            btn.disabled = true;
            var icon = document.createElement('i');
            icon.className = iconClass;
            btn.appendChild(icon);
            btn.appendChild(document.createTextNode(label));
        }

        // Subtle submit button animation on click
        var form = document.getElementById('loginForm');
        var btn  = document.getElementById('loginSubmitBtn');
        if (form && btn) {
            form.addEventListener('submit', function () {
                setSubmitBusy(btn, 'fas fa-circle-notch fa-spin mr-2', ' Signing In...');
            });
        }

        // Auto-focus username (skip when policy modal is open)
        var uInput = document.getElementById('username');
        @if (!showLegalModal)
        {
            <text>
        if (uInput) { uInput.focus(); }
            </text>
        }

        @if (showLegalModal)
        {
            <text>
        var legalModalEl = document.getElementById('legalConsentModal');
        if (legalModalEl && typeof jQuery !== 'undefined') {
            if (legalModalEl.parentElement !== document.body) {
                document.body.appendChild(legalModalEl);
            }
            var $legalModal = jQuery(legalModalEl);
            $legalModal.off('shown.bs.modal.legalConsent');
            $legalModal.on('shown.bs.modal.legalConsent', function () {
                var backdrops = document.querySelectorAll('.modal-backdrop');
                if (backdrops.length > 1) {
                    for (var i = 0; i < backdrops.length - 1; i++) {
                        backdrops[i].parentNode.removeChild(backdrops[i]);
                    }
                }
            });
            $legalModal.modal({ backdrop: 'static', keyboard: false, show: true });
        }
            </text>
        }
    });
</script>
