@model HR.Web.Models.ForgotPasswordViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Forgot Password";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
    var tenantContext = ViewBag.TenantContext as HR.Web.Models.Company;
    var tenantCompanyName = tenantContext != null && !string.IsNullOrWhiteSpace(tenantContext.Name)
        ? tenantContext.Name
        : null;
}

<div class="mfa-setup-wrapper mfa-setup-wrapper-login animate-fadeIn">
    <div class="mfa-card auth-login-card">
        <div class="auth-login-layout">
            <aside class="auth-login-aside">
                <div class="login-icon-wrap">
                    <i class="fas fa-key"></i>
                </div>
                @if (!string.IsNullOrEmpty(tenantCompanyName))
                {
                    <span class="auth-eyebrow">@tenantCompanyName</span>
                    <h3>Account recovery</h3>
                    <p class="auth-login-aside__lead">Reset your password for @tenantCompanyName. We'll send a secure link to the email on your account.</p>
                }
                else
                {
                    <span class="auth-eyebrow">Account recovery</span>
                    <h3>Forgot password</h3>
                    <p class="auth-login-aside__lead">We'll email you a secure link to reset your password.</p>
                }
                <ul class="auth-login-features">
                    <li><i class="fas fa-check-circle"></i> Reset links expire for your security</li>
                    <li><i class="fas fa-check-circle"></i> Use the email registered on your account</li>
                    <li><i class="fas fa-check-circle"></i> Check spam if the message doesn't arrive</li>
                </ul>
            </aside>

            <div class="auth-login-main">
                <div class="mfa-body auth-login-body">
                    @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
                    {
                        <div class="alert auth-alert alert-success">
                            <i class="fas fa-check-circle mr-2"></i> @ViewBag.SuccessMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                    {
                        <div class="alert auth-alert alert-danger">
                            <i class="fas fa-exclamation-triangle mr-2"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    @if (string.IsNullOrEmpty(ViewBag.SuccessMessage))
                    {
                        <div class="alert auth-alert alert-info mb-4">
                            <i class="fas fa-info-circle mr-2"></i> Enter the email address associated with your account.
                        </div>

                        using (Html.BeginForm())
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert auth-alert alert-danger mb-4" })

                            <div class="login-field-group">
                                <label for="Email">Email address</label>
                                <div class="login-input-wrap">
                                    <span class="login-input-icon"><i class="fas fa-envelope"></i></span>
                                    @Html.TextBoxFor(m => m.Email, new { @class = "login-input", placeholder = "your-email@example.com" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small mt-1 d-block" })
                            </div>

                            <div class="auth-login-actions mt-4">
                                <button type="submit" class="btn-primary-mfa">
                                    <i class="fas fa-paper-plane mr-2"></i> Send reset link
                                </button>
                            </div>
                        }
                    }
                </div>

                <div class="mfa-footer auth-login-footer">
                    <a href="@Url.Action("Login", "Account", new { tenant = tenantToken })" class="btn-link-mfa">
                        <i class="fas fa-arrow-left mr-1"></i> Back to login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
