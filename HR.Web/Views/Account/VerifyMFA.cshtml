@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Authentication Required";
    ViewBag.HideNavbar = true;
    ViewBag.SuppressPageHero = true;
    var tenantToken = ViewContext.RouteData.Values["tenant"] as string;
    var tenantContext = ViewBag.TenantContext as HR.Web.Models.Company;
    var tenantCompanyName = tenantContext != null && !string.IsNullOrWhiteSpace(tenantContext.Name)
        ? tenantContext.Name
        : null;
}

<div class="mfa-setup-wrapper mfa-setup-wrapper-login animate-fadeIn">
    <div class="mfa-card auth-login-card">
        <div class="auth-login-layout">
            <aside class="auth-login-aside">
                <div class="login-icon-wrap">
                    <i class="fas fa-shield-alt"></i>
                </div>
                @if (!string.IsNullOrEmpty(tenantCompanyName))
                {
                    <span class="auth-eyebrow">@tenantCompanyName</span>
                    <h3>Two-step verification</h3>
                    <p class="auth-login-aside__lead">Enter the verification code sent to your email to sign in to @tenantCompanyName.</p>
                }
                else
                {
                    <span class="auth-eyebrow">Two-step verification</span>
                    <h3>Verify your identity</h3>
                    <p class="auth-login-aside__lead">Complete verification to access your account.</p>
                }
                <ul class="auth-login-features">
                    <li><i class="fas fa-check-circle"></i> Enter the 6-digit code from your inbox</li>
                    <li><i class="fas fa-check-circle"></i> Codes expire after 10 minutes</li>
                    <li><i class="fas fa-check-circle"></i> Check spam if the message doesn't arrive</li>
                </ul>
            </aside>

            <div class="auth-login-main">
                <div class="mfa-body auth-login-body">
                    @if (ViewBag.MfaSendError != null)
                    {
                        <div class="alert auth-alert alert-warning mb-4">
                            <i class="fas fa-exclamation-triangle mr-2"></i> @ViewBag.MfaSendError
                        </div>
                    }

                    @Html.ValidationSummary(true, "", new { @class = "alert auth-alert alert-danger mb-4" })

                    <div class="alert auth-alert alert-info mb-4">
                        <i class="fas fa-info-circle mr-2"></i>
                        We've sent a 6-digit verification code to <strong>@ViewBag.EmailHint</strong>.
                        Please enter it below to complete your login.
                    </div>

                    @using (Html.BeginForm("VerifyMFA", "Account", FormMethod.Post, new { id = "mfaVerifyForm" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="login-field-group mb-4">
                            <label for="code">Verification code</label>
                            <div class="login-input-wrap">
                                <span class="login-input-icon"><i class="fas fa-key"></i></span>
                                <input class="login-input mfa-verify-code-input"
                                       id="code" name="code" type="text" maxlength="6"
                                       placeholder="000000" required autocomplete="off" autofocus />
                            </div>
                        </div>

                        <div class="auth-login-actions mt-4">
                            <button type="submit" class="btn-primary-mfa" id="btnSubmit">
                                <i class="fas fa-check-circle mr-2"></i> Verify &amp; sign in
                            </button>
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <p class="text-muted small mb-2 font-weight-bold">Didn't receive the code?</p>
                        <button type="button" id="btnResend" class="btn btn-outline-primary btn-sm rounded-pill font-weight-bold px-4 py-2 mt-1 shadow-sm" style="border-width: 2px;">
                            <i class="fas fa-sync-alt mr-1"></i> Resend verification code
                        </button>
                        <div id="resendMessage" class="small mt-2 font-weight-bold"></div>
                    </div>
                </div>

                <div class="mfa-footer auth-login-footer">
                    <a href="@Url.Action("Logout", "Account", new { tenant = tenantToken })" class="btn-link-mfa">
                        <i class="fas fa-arrow-left mr-1"></i> Return to login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function() {
            $('#code').focus();

            $('#mfaVerifyForm').submit(function() {
                var btn = $('#btnSubmit');
                btn.html('<i class="fas fa-spinner fa-spin mr-2"></i> Verifying...').prop('disabled', true);
            });

            $('#btnResend').on('click', function() {
                var btn = this;
                var originalHtml = btn.innerHTML;

                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Sending...';

                $.post('@Url.Action("ResendCode", "Account", new { tenant = tenantToken })', function(re) {
                    if (re.success) {
                        $('#resendMessage').removeClass('text-danger').addClass('text-success').text('A new code has been sent.');
                    } else {
                        $('#resendMessage').removeClass('text-success').addClass('text-danger').text(re.message || 'Failed to resend code.');
                    }

                    setTimeout(function() {
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                        setTimeout(function() { $('#resendMessage').fadeOut(); }, 3000);
                    }, 1000);
                }).fail(function() {
                    $('#resendMessage').removeClass('text-success').addClass('text-danger').text('Failed to connect to server.');
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                });
            });
        });
    </script>
}
